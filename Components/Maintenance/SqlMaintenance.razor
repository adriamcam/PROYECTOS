@using ITQS.SupportOperationsCenter.Models.Maintenance

<div class="sql-maintenance-page">

    @if (IsLoading)
    {
        <div class="sql-card">
            <span>Cargando mantenimiento SQL...</span>
        </div>
    }
    else if (!CanAccess)
    {
        <div class="sql-card sql-denied">
            <h3>Acceso denegado</h3>
            <p>Este módulo solo está disponible para administradores.</p>
        </div>
    }
    else
    {
        <div class="sql-header">
            <div>
                <span class="sql-section">Mantenimiento</span>
                <h1>Mantenimiento / SQL</h1>
                <p>Limpieza controlada de tablas históricas conservando los últimos @RetentionDays días.</p>
            </div>

            <button class="btn-refresh" @onclick="LoadDashboardAsync" disabled="@IsExecuting">
                Actualizar
            </button>
        </div>

        <div class="sql-retention">
            <strong>Retención de información</strong>

            <div class="retention-actions">
                <label>Mantener últimos:</label>

                <select @bind="RetentionDays" disabled="@IsExecuting">
                    <option value="30">30 días</option>
                    <option value="60">60 días</option>
                    <option value="90">90 días</option>
                    <option value="180">180 días</option>
                </select>
            </div>
        </div>

        @if (LastExecution is not null)
        {
            <div class="sql-result @(LastExecution.Succeeded ? "ok" : "error")">
                <strong>@(LastExecution.Succeeded ? "Limpieza ejecutada correctamente" : "Error en la limpieza")</strong>
                <span>@LastExecution.TableName - @LastExecution.RowsAffected.ToString("N0") registros afectados</span>
                <small>@LastExecution.Message</small>
            </div>
        }

        <div class="sql-table-list">
            @foreach (var table in Dashboard.Tables)
            {
                <div class="sql-table-card">

                    <div class="table-icon">
                        @GetIcon(table.TableName)
                    </div>

                    <div class="table-info">
                        <h3>@table.TableName</h3>
                        <p>@table.RecommendedAction</p>
                    </div>

                    <div class="table-metric">
                        <span>Registros actuales</span>
                        <strong>@table.TotalRows.ToString("N0")</strong>
                    </div>

                    @if (table.TableName == "AzureAlertCloseQueue")
                    {
                        <div class="table-metric">
                            <span>Pending</span>
                            <strong>@table.PendingRows.ToString("N0")</strong>
                        </div>

                        <div class="table-metric">
                            <span>Processed</span>
                            <strong>@table.ProcessedRows.ToString("N0")</strong>
                        </div>

                        <div class="table-metric">
                            <span>NotFound</span>
                            <strong>@table.NotFoundRows.ToString("N0")</strong>
                        </div>
                    }
                    else
                    {
                        <div class="table-metric">
                            <span>Activas</span>
                            <strong>@table.ActiveRows.ToString("N0")</strong>
                        </div>

                        <div class="table-metric">
                            <span>Cerradas</span>
                            <strong>@table.ClosedRows.ToString("N0")</strong>
                        </div>
                    }

                    <div class="table-metric danger">
                        <span>A eliminar</span>
                        <strong>@table.EligibleToDelete.ToString("N0")</strong>
                    </div>

                    <div class="table-actions">
                        <button class="btn-preview" disabled="@(table.EligibleToDelete <= 0)">
                            Vista Previa
                        </button>

                        <button class="btn-clean"
                                disabled="@(IsExecuting || table.EligibleToDelete <= 0)"
                                @onclick="() => ExecuteCleanupAsync(table)">
                            Ejecutar Limpieza
                        </button>
                    </div>

                </div>
            }
        </div>

        <div class="sql-note">
            <strong>Información importante</strong>
            <p>Este módulo elimina únicamente información histórica según la política de retención seleccionada. No afecta alertas activas ni configuración del sistema.</p>
        </div>
    }
</div>