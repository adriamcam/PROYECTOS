@namespace ITQS.SupportOperationsCenter.Components.Administration.WebCertificates
@using ITQS.SupportOperationsCenter.Models.Administration.WebCertificates
@using ITQS.SupportOperationsCenter.Services.Interfaces
@inject IWebCertificatesService WebCertificatesService

<section class="cert-page">
    <section class="cert-hero">
        <div>
            <span class="cert-eyebrow">ADMINISTRACIÓN</span>
            <h1>Certificados Web</h1>
            <p>Inventario operativo de certificados asociados a Application Gateway/WAF, App Services, Key Vault y servicios críticos.</p>
        </div>

        <div class="cert-hero-actions">
            <div class="cert-last-run">
                <span>ÚLTIMA EJECUCIÓN</span>
                <strong>@FormatDateTime(Dashboard.LastScanAt)</strong>
            </div>

            <button type="button" class="cert-info-button" @onclick="OpenInfo">
                ⓘ Información
            </button>

            <button type="button" class="cert-refresh-button" @onclick="LoadAsync" disabled="@IsLoading">
                @(IsLoading ? "Actualizando..." : "↻ Actualizar")
            </button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="cert-message @(HasError ? "error" : "ok")">@Message</div>
    }

    <section class="cert-kpis">
        <button type="button" class="@KpiCardClass("")" @onclick='() => SetStatusFilter("")'>
            <span>Certificados activos</span>
            <strong>@Dashboard.ActiveCertificates</strong>
            <small>Inventario operativo sin duplicados</small>
        </button>

        <button type="button" class="@KpiCardClass("Expired", "expired")" @onclick='() => SetStatusFilter("Expired")'>
            <span>Vencidos</span>
            <strong>@Dashboard.Expired</strong>
            <small>Atención inmediata</small>
        </button>

        <button type="button" class="@KpiCardClass("Critical", "critical")" @onclick='() => SetStatusFilter("Critical")'>
            <span>Críticos &lt; 30 días</span>
            <strong>@Dashboard.Critical</strong>
            <small>Prioridad alta</small>
        </button>

        <button type="button" class="@KpiCardClass("Warning", "warning")" @onclick='() => SetStatusFilter("Warning")'>
            <span>Warning &lt; 90 días</span>
            <strong>@Dashboard.Warning</strong>
            <small>Preventivo</small>
        </button>

        <button type="button" class="@KpiCardClass("Healthy", "healthy")" @onclick='() => SetStatusFilter("Healthy")'>
            <span>Healthy</span>
            <strong>@Dashboard.Healthy</strong>
            <small>Sin riesgo cercano</small>
        </button>

        <button type="button" class="@KpiCardClass("Unknown", "unknown")" @onclick='() => SetStatusFilter("Unknown")'>
            <span>Unknown</span>
            <strong>@Dashboard.Unknown</strong>
            <small>Validación requerida</small>
        </button>
    </section>

    <section class="cert-toolbar">
        <select @bind="SelectedCustomer">
            <option value="">Todos los clientes</option>
            @foreach (var item in CustomerOptions)
            {
                <option value="@item">@item</option>
            }
        </select>

        <select @bind="SelectedStatus">
            <option value="">Todos los estados</option>
            @foreach (var item in StatusOptions)
            {
                <option value="@item">@item</option>
            }
        </select>

        <select @bind="SelectedSource">
            <option value="">Todos los orígenes</option>
            @foreach (var item in SourceOptions)
            {
                <option value="@item">@SourceText(item)</option>
            }
        </select>

        <input placeholder="Buscar certificado, recurso, subscription o cliente..."
               @bind="Search"
               @bind:event="oninput" />

        <button type="button" title="Limpiar filtros" @onclick="ClearFilters">🔎</button>
    </section>

    <section class="cert-status-filter">
        <button type="button" class="@StatusChipClass("")" @onclick='() => SetStatusFilter("")'>Todos</button>
        <button type="button" class="@StatusChipClass("Expired")" @onclick='() => SetStatusFilter("Expired")'>Expired</button>
        <button type="button" class="@StatusChipClass("Critical")" @onclick='() => SetStatusFilter("Critical")'>Critical</button>
        <button type="button" class="@StatusChipClass("Warning")" @onclick='() => SetStatusFilter("Warning")'>Warning</button>
        <button type="button" class="@StatusChipClass("Healthy")" @onclick='() => SetStatusFilter("Healthy")'>Healthy</button>
        <button type="button" class="@StatusChipClass("Unknown")" @onclick='() => SetStatusFilter("Unknown")'>Unknown</button>
    </section>

    <section class="cert-table-card">
        <div class="cert-section-header">
            <div>
                <h3>Inventario de Certificados</h3>
                <p>Mostrando <strong>@PageStart</strong> - <strong>@PageEnd</strong> de <strong>@FilteredCount</strong> certificados presentes.</p>
            </div>

            <div class="cert-pagination">
                <select value="@PageSize" @onchange="SetPageSize">
                    <option value="10">10 por página</option>
                    <option value="25">25 por página</option>
                    <option value="50">50 por página</option>
                    <option value="100">100 por página</option>
                </select>

                <button type="button" disabled="@(SafePage <= 1)" @onclick="() => GoToPage(1)">«</button>
                <button type="button" disabled="@(SafePage <= 1)" @onclick="() => GoToPage(SafePage - 1)">‹</button>
                <span>Página @SafePage de @TotalPages</span>
                <button type="button" disabled="@(SafePage >= TotalPages)" @onclick="() => GoToPage(SafePage + 1)">›</button>
                <button type="button" disabled="@(SafePage >= TotalPages)" @onclick="() => GoToPage(TotalPages)">»</button>
            </div>
        </div>

        <div class="cert-row cert-head">
            <span><button type="button" class="sort-link" @onclick='() => SortBy("CustomerName")'>Cliente <small>@SortIcon("CustomerName")</small></button></span>
            <span><button type="button" class="sort-link" @onclick='() => SortBy("Source")'>Origen <small>@SortIcon("Source")</small></button></span>
            <span><button type="button" class="sort-link" @onclick='() => SortBy("ResourceName")'>Recurso <small>@SortIcon("ResourceName")</small></button></span>
            <span><button type="button" class="sort-link" @onclick='() => SortBy("CertName")'>Certificado <small>@SortIcon("CertName")</small></button></span>
            <span><button type="button" class="sort-link" @onclick='() => SortBy("NotAfter")'>Expira <small>@SortIcon("NotAfter")</small></button></span>
            <span><button type="button" class="sort-link" @onclick='() => SortBy("DaysToExpire")'>Días <small>@SortIcon("DaysToExpire")</small></button></span>
            <span><button type="button" class="sort-link" @onclick='() => SortBy("Status")'>Estado <small>@SortIcon("Status")</small></button></span>
            <span><button type="button" class="sort-link" @onclick='() => SortBy("SubscriptionName")'>Subscription <small>@SortIcon("SubscriptionName")</small></button></span>
            <span>Acciones</span>
        </div>

        @if (IsLoading)
        {
            <div class="cert-empty">Cargando inventario de certificados...</div>
        }
        else if (!PagedItems.Any())
        {
            <div class="cert-empty">No hay certificados con los filtros actuales.</div>
        }
        else
        {
            @foreach (var item in PagedItems)
            {
                <div class="cert-row cert-data-row">
                    <span>
                        <strong class="main-text">@item.CustomerName</strong>
                        <small>@item.ResourceGroup</small>
                    </span>

                    <span>@SourceText(item.Source)</span>

                    <span>
                        <strong class="main-text">@ResourceDisplayName(item)</strong>
                        <small title="@item.ResourceName">@TrimText(item.ResourceName, 48)</small>
                    </span>

                    <span>
                        <strong class="main-text">@CertificateDisplayName(item)</strong>
                        <small title="@CertificateSubText(item)">@TrimText(CertificateSubText(item), 60)</small>
                    </span>

                    <span>@FormatDate(item.NotAfter)</span>
                    <span class="@DaysCss(item)">@DaysText(item)</span>
                    <span><span class="cert-status @StatusCss(item.Status)">@item.Status</span></span>

                    <span>
                        <strong class="main-text">@item.SubscriptionName</strong>
                        <small>@ShortGuid(item.SubscriptionId)</small>
                    </span>

                    <span>
                        <button type="button" class="cert-action-button" @onclick="() => OpenDetail(item)">
                            Detalle
                        </button>
                    </span>
                </div>
            }
        }
    </section>

    @if (SelectedCertificate is not null)
    {
        <div class="cert-modal-backdrop">
            <div class="cert-modal cert-detail-modal">
                <button type="button" class="cert-modal-close" @onclick="CloseDetail">×</button>

                <div class="cert-modal-header">
                    <span>DETALLE DEL CERTIFICADO</span>
                    <h2>@CertificateDisplayName(SelectedCertificate)</h2>
                    <p>@SelectedCertificate.CustomerName · @SourceText(SelectedCertificate.Source) · @SelectedCertificate.Status</p>
                </div>

                <div class="detail-status-line">
                    <span class="cert-status @StatusCss(SelectedCertificate.Status)">@SelectedCertificate.Status</span>
                    <span class="@DaysCss(SelectedCertificate)">@DaysText(SelectedCertificate) días</span>
                    <span>Expira: <strong>@FormatDate(SelectedCertificate.NotAfter)</strong></span>
                    <span>Último scan: <strong>@FormatDateTime(SelectedCertificate.LastScanAt)</strong></span>
                </div>

                <div class="cert-detail-grid">
                    <div class="cert-info-card">
                        <h3>Cliente y suscripción</h3>
                        <dl>
                            <dt>Cliente</dt><dd>@SelectedCertificate.CustomerName</dd>
                            <dt>TenantId</dt><dd>@Dash(SelectedCertificate.TenantId)</dd>
                            <dt>Subscription</dt><dd>@Dash(SelectedCertificate.SubscriptionName)</dd>
                            <dt>SubscriptionId</dt><dd>@Dash(SelectedCertificate.SubscriptionId)</dd>
                            <dt>Resource Group</dt><dd>@Dash(SelectedCertificate.ResourceGroup)</dd>
                        </dl>
                    </div>

                    <div class="cert-info-card">
                        <h3>Recurso Azure</h3>
                        <dl>
                            <dt>Origen</dt><dd>@SourceText(SelectedCertificate.Source)</dd>
                            <dt>Resource Type</dt><dd>@Dash(SelectedCertificate.ResourceType)</dd>
                            <dt>Resource Name</dt><dd>@Dash(SelectedCertificate.ResourceName)</dd>
                            <dt>App Service</dt><dd>@Dash(SelectedCertificate.AppServiceSiteName)</dd>
                            <dt>Application Gateway</dt><dd>@Dash(SelectedCertificate.ApplicationGatewayName)</dd>
                        </dl>
                    </div>

                    <div class="cert-info-card">
                        <h3>Certificado</h3>
                        <dl>
                            <dt>Cert Name</dt><dd>@Dash(SelectedCertificate.CertName)</dd>
                            <dt>HostName</dt><dd>@Dash(SelectedCertificate.HostName)</dd>
                            <dt>Subject</dt><dd>@Dash(SelectedCertificate.Subject)</dd>
                            <dt>Issuer</dt><dd>@Dash(SelectedCertificate.Issuer)</dd>
                            <dt>Thumbprint</dt><dd class="mono">@Dash(SelectedCertificate.Thumbprint)</dd>
                        </dl>
                    </div>

                    <div class="cert-info-card">
                        <h3>Fechas y estado</h3>
                        <dl>
                            <dt>NotBefore</dt><dd>@FormatDateTime(SelectedCertificate.NotBefore)</dd>
                            <dt>NotAfter</dt><dd>@FormatDateTime(SelectedCertificate.NotAfter)</dd>
                            <dt>Días</dt><dd>@DaysText(SelectedCertificate)</dd>
                            <dt>SSL State</dt><dd>@Dash(SelectedCertificate.SslState)</dd>
                            <dt>Uso</dt><dd>@Dash(SelectedCertificate.UsageStatus)</dd>
                            <dt>Activo</dt><dd>@(SelectedCertificate.IsActive ? "Sí" : "No")</dd>
                            <dt>Presente</dt><dd>@(SelectedCertificate.IsPresent ? "Sí" : "No")</dd>
                        </dl>
                    </div>

                    <div class="cert-info-card">
                        <h3>Tipo y proveedor</h3>
                        <dl>
                            <dt>Binding Type</dt><dd>@Dash(SelectedCertificate.BindingType)</dd>
                            <dt>Certificate Type</dt><dd>@Dash(SelectedCertificate.CertificateType)</dd>
                            <dt>Domain Provider</dt><dd>@Dash(SelectedCertificate.DomainProvider)</dd>
                            <dt>Managed Certificate</dt><dd>@(SelectedCertificate.IsManagedCertificate ? "Sí" : "No")</dd>
                            <dt>Uses Key Vault</dt><dd>@(SelectedCertificate.UsesKeyVault ? "Sí" : "No")</dd>
                        </dl>
                    </div>

                    <div class="cert-info-card">
                        <h3>Key Vault</h3>
                        <dl>
                            <dt>Key Vault Name</dt><dd>@Dash(SelectedCertificate.KeyVaultName)</dd>
                            <dt>Secret Name</dt><dd>@Dash(SelectedCertificate.KeyVaultSecretName)</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (ShowInfo)
    {
        <div class="cert-modal-backdrop">
            <div class="cert-modal">
                <button type="button" class="cert-modal-close" @onclick="CloseInfo">×</button>

                <div class="cert-modal-header">
                    <span>INFORMACIÓN TÉCNICA</span>
                    <h2>Certificados Web</h2>
                    <p>Arquitectura, objetos SQL, fuentes de inventario y flujo operativo del módulo.</p>
                    <p>
                        RunId:
                        <strong>@Dash(Dashboard.LastRunId)</strong>
                        · Clientes:
                        <strong>@Dashboard.ProcessedCustomers</strong>
                        · OK:
                        <strong>@Dashboard.SuccessfulCustomers</strong>
                        · Error:
                        <strong>@Dashboard.FailedCustomers</strong>
                        · Stored:
                        <strong>@Dashboard.StoredCertificates</strong>
                    </p>
                </div>

                <div class="cert-info-grid">
                    <div class="cert-info-card">
                        <h3>🎯 Objetivo</h3>
                        <p>Centralizar el inventario y seguimiento de certificados web utilizados en servicios Azure, detectando vencimientos, certificados críticos y recursos afectados.</p>
                    </div>

                    <div class="cert-info-card">
                        <h3>🗄️ Base de Datos</h3>
                        <strong>Tablas</strong>
                        <ul>
                            <li>dbo.ITQS_APP_CertInventory_Current</li>
                            <li>dbo.ITQS_APP_CertInventory_History</li>
                            <li>dbo.ITQS_APP_CertInventory_RunCustomers</li>
                            <li>dbo.ITQS_APP_CertInventory_Stage</li>
                        </ul>
                        <strong>Llave operativa</strong>
                        <ul>
                            <li>SourceObjectKeyHash</li>
                        </ul>

                        <strong>Stored Procedures</strong>
                        <ul>
                            <li>dbo.ITQS_APP_sp_MergeCertInventoryCurrent</li>
                            <li>dbo.ITQS_APP_sp_UpsertCertInventoryRunCustomer</li>
                        </ul>
                    </div>

                    <div class="cert-info-card">
                        <h3>☁️ Fuentes</h3>
                        <ul>
                            <li>Application Gateway / WAF</li>
                            <li>App Services</li>
                            <li>Key Vault Certificates</li>
                            <li>Extensión futura: on-prem / ADSelfService Plus</li>
                        </ul>
                    </div>
                </div>

                <div class="cert-flow-card">
                    <h3>🔄 Flujo Operativo</h3>
                    <div class="cert-flow-line">
                        <div>Azure Automation</div>
                        <span>→</span>
                        <div>Azure Resources</div>
                        <span>→</span>
                        <div>Stage</div>
                        <span>→</span>
                        <div>Run Customers</div>
                        <span>→</span>
                        <div>Merge Current</div>
                        <span>→</span>
                        <div>Certificados Web</div>
                        <span>→</span>
                        <div>Reportes / Alertas</div>
                    </div>
                </div>

                <div class="cert-flow-card">
                    <h3>📊 KPIs utilizados</h3>
                    <div class="cert-chip-grid">
                        <span>Certificados activos</span>
                        <span>Stored / históricos</span>
                        <span>Clientes procesados</span>
                        <span>Clientes exitosos / fallidos</span>
                        <span>Vencidos</span>
                        <span>Críticos &lt; 30 días</span>
                        <span>Warning &lt; 90 días</span>
                        <span>Healthy</span>
                        <span>Unknown</span>
                        <span>App Gateway / WAF</span>
                        <span>App Services</span>
                        <span>Key Vault</span>
                    </div>
                </div>
            </div>
        </div>
    }
</section>

@code {
    private WebCertificateDashboardModel Dashboard { get; set; } = new();
    private List<WebCertificateInventoryModel> Items { get; set; } = new();

    private bool ShowInfo { get; set; }
    private WebCertificateInventoryModel? SelectedCertificate { get; set; }

    private bool IsLoading { get; set; }
    private bool HasError { get; set; }
    private string Message { get; set; } = string.Empty;

    private string SelectedCustomer { get; set; } = string.Empty;
    private string SelectedStatus { get; set; } = string.Empty;
    private string SelectedSource { get; set; } = string.Empty;
    private string Search { get; set; } = string.Empty;

    private string SortColumn { get; set; } = "StatusPriority";
    private bool SortAscending { get; set; } = true;

    private int Page { get; set; } = 1;
    private int PageSize { get; set; } = 10;

    private List<string> CustomerOptions => Items.Select(x => x.CustomerName).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();
    private List<string> StatusOptions => Items.Select(x => x.Status).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();
    private List<string> SourceOptions => Items.Select(x => x.Source).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();

    private IEnumerable<WebCertificateInventoryModel> FilteredItems => Items.Where(MatchesFilters);
    private List<WebCertificateInventoryModel> SortedItems => ApplySort(FilteredItems).ToList();
    private int FilteredCount => SortedItems.Count;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredCount / (double)PageSize));
    private int SafePage => Math.Min(Math.Max(Page, 1), TotalPages);
    private int PageStart => FilteredCount == 0 ? 0 : ((SafePage - 1) * PageSize) + 1;
    private int PageEnd => Math.Min(SafePage * PageSize, FilteredCount);
    private List<WebCertificateInventoryModel> PagedItems => SortedItems.Skip((SafePage - 1) * PageSize).Take(PageSize).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        HasError = false;
        Message = string.Empty;

        try
        {
            Dashboard = await WebCertificatesService.GetDashboardAsync();
            Items = (await WebCertificatesService.GetCertificatesAsync()).ToList();
            Page = 1;
        }
        catch (Exception ex)
        {
            HasError = true;
            Message = $"Error cargando certificados web: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private bool MatchesFilters(WebCertificateInventoryModel item)
    {
        if (!string.IsNullOrWhiteSpace(SelectedCustomer) &&
            !string.Equals(item.CustomerName, SelectedCustomer, StringComparison.OrdinalIgnoreCase))
            return false;

        if (!string.IsNullOrWhiteSpace(SelectedStatus) &&
            !string.Equals(item.Status, SelectedStatus, StringComparison.OrdinalIgnoreCase))
            return false;

        if (!string.IsNullOrWhiteSpace(SelectedSource) &&
            !string.Equals(item.Source, SelectedSource, StringComparison.OrdinalIgnoreCase))
            return false;

        if (string.IsNullOrWhiteSpace(Search))
            return true;

        var text = Search.Trim();

        return Contains(item.CustomerName, text)
            || Contains(item.SubscriptionName, text)
            || Contains(item.ResourceGroup, text)
            || Contains(item.ResourceName, text)
            || Contains(item.CertName, text)
            || Contains(item.HostName, text)
            || Contains(item.Subject, text)
            || Contains(item.Issuer, text)
            || Contains(item.Thumbprint, text);
    }

    private static bool Contains(string value, string search)
        => !string.IsNullOrWhiteSpace(value) && value.Contains(search, StringComparison.OrdinalIgnoreCase);

    private IEnumerable<WebCertificateInventoryModel> ApplySort(IEnumerable<WebCertificateInventoryModel> source)
    {
        Func<WebCertificateInventoryModel, object?> selector = SortColumn switch
        {
            "CustomerName" => x => x.CustomerName,
            "Source" => x => x.Source,
            "ResourceName" => x => x.ResourceName,
            "CertName" => x => x.CertName,
            "NotAfter" => x => x.NotAfter ?? DateTime.MaxValue,
            "DaysToExpire" => x => x.DaysToExpire ?? int.MaxValue,
            "Status" => x => x.Status,
            "SubscriptionName" => x => x.SubscriptionName,
            "StatusPriority" => x => x.StatusPriority,
            _ => x => x.StatusPriority
        };

        return SortAscending
            ? source.OrderBy(selector).ThenBy(x => x.DaysToExpire ?? int.MaxValue)
            : source.OrderByDescending(selector).ThenBy(x => x.DaysToExpire ?? int.MaxValue);
    }

    private void SortBy(string column)
    {
        if (SortColumn == column)
            SortAscending = !SortAscending;
        else
        {
            SortColumn = column;
            SortAscending = column is "CustomerName" or "Source" or "ResourceName" or "CertName" or "Status" or "SubscriptionName";
        }

        Page = 1;
    }

    private string SortIcon(string column)
    {
        if (SortColumn != column)
            return "↕";

        return SortAscending ? "↑" : "↓";
    }

    private void ClearFilters()
    {
        SelectedCustomer = string.Empty;
        SelectedStatus = string.Empty;
        SelectedSource = string.Empty;
        Search = string.Empty;
        Page = 1;
    }

    private void SetStatusFilter(string status)
    {
        SelectedStatus = status;
        Page = 1;
    }

    private string StatusChipClass(string status)
    {
        var active = string.Equals(SelectedStatus, status, StringComparison.OrdinalIgnoreCase);
        return active ? "cert-chip active" : "cert-chip";
    }

    private string KpiCardClass(string status, string extraClass = "")
    {
        var active = string.Equals(SelectedStatus, status, StringComparison.OrdinalIgnoreCase);
        var classes = string.IsNullOrWhiteSpace(extraClass) ? "cert-kpi clickable" : $"cert-kpi clickable {extraClass}";

        return active ? $"{classes} active" : classes;
    }

    private void GoToPage(int page)
    {
        Page = Math.Min(Math.Max(page, 1), TotalPages);
    }

    private void SetPageSize(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            PageSize = Math.Clamp(size, 10, 100);
            Page = 1;
        }
    }

    private void OpenInfo() => ShowInfo = true;
    private void CloseInfo() => ShowInfo = false;

    private void OpenDetail(WebCertificateInventoryModel item) => SelectedCertificate = item;
    private void CloseDetail() => SelectedCertificate = null;

    private static string FormatDate(DateTime? value)
        => value.HasValue ? value.Value.ToString("dd/MM/yyyy") : "-";

    private static string FormatDateTime(DateTime? value)
        => value.HasValue ? value.Value.ToString("dd/MM/yyyy HH:mm") : "-";

    private static string ShortGuid(string value)
        => string.IsNullOrWhiteSpace(value) || value.Length < 8 ? value : value[..8];

    private static string Dash(string value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string TrimText(string value, int max)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "-";

        return value.Length <= max ? value : $"{value[..max]}...";
    }

    private static string SourceText(string value)
    {
        return value switch
        {
            "AppServiceCertificateResource" => "App Service Cert",
            "AppServiceBinding" => "App Service Binding",
            "ApplicationGatewayListener" => "App Gateway / WAF",
            "KeyVaultCertificate" => "Key Vault",
            _ => string.IsNullOrWhiteSpace(value) ? "-" : value
        };
    }

    private static string ResourceDisplayName(WebCertificateInventoryModel item)
    {
        if (!string.IsNullOrWhiteSpace(item.AppServiceSiteName))
            return TrimText(item.AppServiceSiteName, 42);

        if (!string.IsNullOrWhiteSpace(item.ApplicationGatewayName))
            return TrimText(item.ApplicationGatewayName, 42);

        if (!string.IsNullOrWhiteSpace(item.KeyVaultName))
            return TrimText(item.KeyVaultName, 42);

        return TrimText(item.ResourceName, 42);
    }

    private static string CertificateDisplayName(WebCertificateInventoryModel item)
    {
        if (!string.IsNullOrWhiteSpace(item.HostName) && !item.HostName.Contains(".azurewebsites.net", StringComparison.OrdinalIgnoreCase))
            return TrimText(item.HostName, 46);

        if (!string.IsNullOrWhiteSpace(item.Subject))
            return TrimText(item.Subject, 46);

        if (!string.IsNullOrWhiteSpace(item.CertName))
            return TrimText(item.CertName, 46);

        if (!string.IsNullOrWhiteSpace(item.HostName))
            return TrimText(item.HostName, 46);

        return "-";
    }

    private static string CertificateSubText(WebCertificateInventoryModel item)
    {
        if (!string.IsNullOrWhiteSpace(item.CertName))
            return item.CertName;

        if (!string.IsNullOrWhiteSpace(item.CertificateType))
            return item.CertificateType;

        if (!string.IsNullOrWhiteSpace(item.Issuer))
            return item.Issuer;

        return item.HostName;
    }

    private static string DaysText(WebCertificateInventoryModel item)
    {
        if (!item.HasExpiryDate || !item.DaysToExpire.HasValue)
            return "-";

        return item.DaysToExpire.Value.ToString();
    }

    private static string DaysCss(WebCertificateInventoryModel item)
    {
        return item.Status switch
        {
            "Expired" => "days expired",
            "Critical" => "days critical",
            "Warning" => "days warning",
            "Healthy" => "days healthy",
            _ => "days unknown"
        };
    }

    private static string StatusCss(string status)
    {
        return status switch
        {
            "Expired" => "expired",
            "Critical" => "critical",
            "Warning" => "warning",
            "Healthy" => "healthy",
            _ => "unknown"
        };
    }
}
