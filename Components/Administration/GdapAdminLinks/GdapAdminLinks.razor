@using ITQS.SupportOperationsCenter.Models.Administration.GdapAdminLinks

<div class="gdap-page">
    @if (IsLoading)
    {
        <section class="gdap-empty">
            <strong>Cargando Admin Links GDAP...</strong>
            <span>Consultando vistas GDAP en SQL Server.</span>
        </section>
    }
    else
    {
        <section class="gdap-hero">
            <div>
                <span>Administración</span>
                <h1>Admin Links GDAP</h1>
                <p>Gestión operativa de relaciones GDAP, enlaces de aprobación, vencimientos y correos a clientes.</p>
            </div>

            <div class="hero-actions">
                <div class="scan-box">
                    <span>Última ejecución</span>
                    <strong>@Dashboard.LastExecutionText</strong>
                </div>
                <button class="btn-primary" type="button" @onclick="RefreshAsync">↻ Actualizar</button>
            </div>
        </section>

        <section class="gdap-tabs">
            <button class="@(ActiveTab == "Dashboard" ? "active" : "")" @onclick='() => ChangeTabAsync("Dashboard")'>Dashboard</button>
            <button class="@(ActiveTab == "Customers" ? "active" : "")" @onclick='() => ChangeTabAsync("Customers")'>Clientes GDAP</button>
            <button class="@(ActiveTab == "Mail" ? "active" : "")" @onclick='() => ChangeTabAsync("Mail")'>Centro de Correos</button>
            <button class="@(ActiveTab == "Expiring" ? "active" : "")" @onclick='() => ChangeTabAsync("Expiring")'>Vencimientos</button>
        </section>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="@MessageCss">@Message</div>
        }

        @if (ActiveTab == "Dashboard")
        {
            <section class="gdap-kpis">
                <div class="kpi"><span>Total clientes</span><strong>@Dashboard.TotalCustomers</strong><small>Partner Center</small></div>
                <div class="kpi ok"><span>GDAP activos</span><strong>@Dashboard.ActiveGdap</strong><small>Vigentes</small></div>
                <div class="kpi warn"><span>Approval Pending</span><strong>@Dashboard.ApprovalPending</strong><small>Requieren aprobación</small></div>
                <div class="kpi danger"><span>Sin GDAP</span><strong>@Dashboard.WithoutGdap</strong><small>Atención</small></div>
                <div class="kpi warn"><span>Vencen &lt; 30 días</span><strong>@Dashboard.ExpiringIn30Days</strong><small>Preventivo</small></div>
                <div class="kpi high"><span>Vencen &lt; 15 días</span><strong>@Dashboard.ExpiringIn15Days</strong><small>Prioridad alta</small></div>
                <div class="kpi danger"><span>Vencen &lt; 5 días</span><strong>@Dashboard.ExpiringIn5Days</strong><small>Crítico</small></div>
                <div class="kpi"><span>Correos pendientes</span><strong>@Dashboard.PendingEmails</strong><small>Listos para enviar</small></div>
                <div class="kpi muted"><span>Desactivados</span><strong>@Dashboard.DisabledCustomers</strong><small>No procesar</small></div>
                <div class="kpi danger"><span>Errores</span><strong>@Dashboard.AutomationErrors</strong><small>Últimas ejecuciones</small></div>
            </section>

            <section class="gdap-summary-grid">
                <div class="summary-card">
                    <h3>Salud GDAP</h3>
                    <div class="health-ring"><strong>@HealthPercent%</strong></div>
                    <span class="health-label">@(HealthPercent >= 90 ? "HEALTHY" : "ATENCIÓN")</span>
                </div>

                <div class="summary-card">
                    <h3>Próximos vencimientos</h3>
                    @if (!ExpiringItems.Any())
                    {
                        <p class="muted-text">No hay vencimientos cargados.</p>
                    }
                    else
                    {
                        @foreach (var item in ExpiringItems.Take(5))
                        {
                            <div class="gdap-mini-item">
                                <strong>@(item.DaysToExpire?.ToString() ?? "-") días</strong>
                                <span>@item.CustomerName</span>
                                <small>@item.PartnerTenant</small>
                            </div>
                        }
                    }
                </div>

                <div class="summary-card">
                    <h3>Correo GDAP</h3>
                    <div class="connection-line"><span>Listos para enviar</span><b>@Dashboard.PendingEmails</b></div>
                    <div class="connection-line"><span>Approval Pending</span><b>@Dashboard.ApprovalPending</b></div>
                    <div class="connection-line"><span>Envío automático</span><b>Preparado</b></div>
                    <button class="btn-primary full-button" @onclick='() => ChangeTabAsync("Mail")'>Ir al Centro de Correos</button>
                </div>
            </section>
        }
        else if (ActiveTab == "Customers")
        {
            <section class="gdap-toolbar">
                <select @bind="Filters.PartnerTenant" @bind:after="ApplyFiltersAsync">
                    <option value="">Todos los partners</option>
                    @foreach (var item in PartnerOptions)
                    {
                        <option value="@item">@item</option>
                    }
                </select>

                <select @bind="Filters.StatusFound" @bind:after="ApplyFiltersAsync">
                    <option value="">Todos los estados</option>
                    <option value="active">Active</option>
                    <option value="approvalPending">Approval Pending</option>
                    <option value="Sin GDAP">Sin GDAP</option>
                    <option value="expired">Expired</option>
                    <option value="terminated">Terminated</option>
                </select>

                <select @bind="Filters.ActiveFilter" @bind:after="ApplyFiltersAsync">
                    <option value="">Activos e inactivos</option>
                    <option value="Active">Solo activos</option>
                    <option value="Inactive">Solo desactivados</option>
                </select>

                <select @bind="Filters.EmailFilter" @bind:after="ApplyFiltersAsync">
                    <option value="">Todos los correos</option>
                    <option value="Ready">Correo listo</option>
                    <option value="Missing">Sin correo</option>
                </select>

                <div class="search-box">
                    <input placeholder="Buscar cliente, tenant o partner..."
                           @bind="Filters.Search"
                           @bind:event="oninput"
                           @onkeydown="SearchKeyDownAsync" />
                    <button type="button" @onclick="ApplyFiltersAsync">🔎</button>
                </div>
            </section>

            <section class="gdap-table-card">
                <div class="gdap-row head">
                    <span>Partner</span>
                    <span>Cliente</span>
                    <span>Estado</span>
                    <span>Vence</span>
                    <span>Días</span>
                    <span>Correo</span>
                    <span>Último correo</span>
                    <span>Activo</span>
                    <span>Acciones</span>
                </div>

                @foreach (var item in PagedItems)
                {
                    <div class="gdap-row">
                        <span><strong>@item.PartnerTenant</strong></span>
                        <span><strong>@item.CustomerName</strong><small>@item.CustomerTenantId</small></span>
                        <span><span class="status @StatusCss(item)">@StatusText(item)</span></span>
                        <span>@FormatDate(item.ActiveEndDate)</span>
                        <span class="@DaysCss(item)">@(item.DaysToExpire?.ToString() ?? "-")</span>
                        <span><span class="mail-state @(item.CanSendEmail ? "ready" : "missing")">@(item.CanSendEmail ? "Listo" : "No listo")</span></span>
                        <span>@FormatDateTime(item.LastEmailSentAt)</span>
                        <span><span class="active-pill @(item.IsActive ? "yes" : "no")">@(item.IsActive ? "Sí" : "No")</span></span>
                        <span class="row-actions">
                            <button type="button" title="Ver detalle" @onclick="() => OpenDetailAsync(item.Id)">👁</button>
                            <button type="button" title="Ejecutar Automation" disabled="@(!item.IsActive)" @onclick="() => OpenAutomationConfirm(item)">▶</button>
                            <button type="button" title="Editar cliente" @onclick="() => OpenEditAsync(item)">✏</button>
                            <button type="button" title="Abrir Approval URL" disabled="@string.IsNullOrWhiteSpace(item.ApprovalPendingLink)" @onclick="() => OpenApprovalUrl(item)">🔗</button>
                            <button type="button" title="Copiar Approval URL" disabled="@string.IsNullOrWhiteSpace(item.ApprovalPendingLink)" @onclick="() => CopyApprovalUrlAsync(item)">📋</button>
                            @if (item.IsActive)
                            {
                                <button type="button" title="Desactivar" @onclick="() => DisableAsync(item)">🚫</button>
                            }
                            else
                            {
                                <button type="button" title="Reactivar" @onclick="() => EnableAsync(item)">✔</button>
                            }
                        </span>
                    </div>
                }

                <div class="table-footer">
                    <span>Mostrando @FirstItemNumber a @LastItemNumber de @FilteredItems.Count registros</span>
                    <div class="pagination">
                        <button disabled="@(PageNumber <= 1)" @onclick="PreviousPageAsync">‹</button>
                        @foreach (var pageItem in VisiblePages)
                        {
                            <button class="@(pageItem == PageNumber ? "active" : "")" @onclick="() => GoToPageAsync(pageItem)">@pageItem</button>
                        }
                        <button disabled="@(PageNumber >= TotalPages)" @onclick="NextPageAsync">›</button>
                    </div>
                    <select @bind="PageSize" @bind:after="PageSizeChangedAsync">
                        <option value="10">10 por página</option>
                        <option value="25">25 por página</option>
                        <option value="50">50 por página</option>
                    </select>
                </div>
            </section>
        }
        else if (ActiveTab == "Mail")
        {
            <section class="gdap-table-card">
                <div class="section-header">
                    <div>
                        <h3>Centro de Correos</h3>
                        <p>Clientes con approvalPending, Approval URL generado y correo configurado.</p>
                    </div>
                    <button class="btn-primary" @onclick="LoadPendingEmailsAsync">↻ Refrescar correos</button>
                </div>

                <div class="gdap-row mail-head">
                    <span>Cliente</span>
                    <span>Contacto</span>
                    <span>Correo</span>
                    <span>CC</span>
                    <span>Approval URL</span>
                    <span>Último envío</span>
                    <span>Acciones</span>
                </div>

                @foreach (var item in PendingEmailItems)
                {
                    <div class="gdap-row mail-head">
                        <span><strong>@item.CustomerName</strong><small>@item.PartnerTenant</small></span>
                        <span>@item.PrimaryContactName</span>
                        <span>@item.PrimaryEmail</span>
                        <span>@item.CCEmails</span>
                        <span><button class="link-button" @onclick="() => OpenApprovalUrl(item)">Abrir link</button></span>
                        <span>@FormatDateTime(item.LastEmailSentAt)</span>
                        <span class="row-actions"><button title="Vista previa">👁</button><button title="Enviar correo">📧</button></span>
                    </div>
                }
            </section>
        }
        else if (ActiveTab == "Expiring")
        {
            <section class="gdap-table-card">
                <div class="section-header">
                    <div>
                        <h3>Próximos vencimientos</h3>
                        <p>Clientes con GDAP por vencer en 30, 15 o 5 días.</p>
                    </div>
                    <button class="btn-primary" @onclick="LoadExpiringAsync">↻ Refrescar vencimientos</button>
                </div>

                <div class="gdap-row exp-head">
                    <span>Partner</span>
                    <span>Cliente</span>
                    <span>Estado</span>
                    <span>Fecha vencimiento</span>
                    <span>Días</span>
                    <span>Acciones</span>
                </div>

                @foreach (var item in ExpiringItems)
                {
                    <div class="gdap-row exp-head">
                        <span>@item.PartnerTenant</span>
                        <span><strong>@item.CustomerName</strong><small>@item.CustomerTenantId</small></span>
                        <span><span class="status @StatusCss(item)">@StatusText(item)</span></span>
                        <span>@FormatDate(item.ActiveEndDate)</span>
                        <span class="@DaysCss(item)">@(item.DaysToExpire?.ToString() ?? "-")</span>
                        <span class="row-actions"><button @onclick="() => OpenDetailAsync(item.Id)">👁</button><button disabled="@(!item.IsActive)" @onclick="() => OpenAutomationConfirm(item)">▶</button></span>
                    </div>
                }
            </section>
        }
    }

    @if (ShowDetail && SelectedDetail is not null)
    {
        <div class="gdap-modal-backdrop">
            <div class="gdap-side-panel">
                <div class="modal-header">
                    <div>
                        <h3>@SelectedDetail.CustomerName</h3>
                        <small>@SelectedDetail.CustomerTenantId</small>
                    </div>
                    <button @onclick="CloseDetail">×</button>
                </div>

                <div class="detail-body">
                    <h4>Estado GDAP</h4>
                    <div class="detail-line"><span>Partner</span><b>@SelectedDetail.PartnerTenant</b></div>
                    <div class="detail-line"><span>Estado</span><b>@SelectedDetail.StatusFound</b></div>
                    <div class="detail-line"><span>Relaciones</span><b>@SelectedDetail.RelationshipQty</b></div>
                    <div class="detail-line"><span>Fecha vencimiento</span><b>@FormatDate(SelectedDetail.ActiveEndDate)</b></div>
                    <div class="detail-line"><span>Días restantes</span><b>@(SelectedDetail.DaysToExpire?.ToString() ?? "-")</b></div>
                    <div class="detail-line"><span>Activo</span><b>@(SelectedDetail.IsActive ? "Sí" : "No")</b></div>

                    <h4>Contacto</h4>
                    <div class="detail-line"><span>Contacto</span><b>@SelectedDetail.PrimaryContactName</b></div>
                    <div class="detail-line"><span>Correo</span><b>@SelectedDetail.PrimaryEmail</b></div>
                    <div class="detail-line"><span>CC</span><b>@SelectedDetail.CCEmails</b></div>

                    <h4>Approval URL</h4>
                    <div class="approval-box">@(string.IsNullOrWhiteSpace(SelectedDetail.ApprovalPendingLink) ? "Sin link generado" : SelectedDetail.ApprovalPendingLink)</div>
                    <button class="btn-primary full-button" disabled="@(!SelectedDetail.IsActive)" @onclick="() => OpenAutomationConfirm(SelectedDetail)">Ejecutar Automation para este cliente</button>
                    <button class="btn-secondary full-button" disabled="@string.IsNullOrWhiteSpace(SelectedDetail.ApprovalPendingLink)" @onclick="() => OpenApprovalUrl(SelectedDetail)">Abrir Approval URL</button>
                    <button class="btn-secondary full-button" disabled="@string.IsNullOrWhiteSpace(SelectedDetail.ApprovalPendingLink)" @onclick="() => CopyApprovalUrlAsync(SelectedDetail)">Copiar Approval URL</button>
                    <button class="btn-secondary full-button" @onclick="() => OpenEditAsync(SelectedDetail)">Editar datos del cliente</button>
                </div>
            </div>
        </div>
    }

    @if (ShowEdit)
    {
        <div class="gdap-modal-backdrop">
            <div class="gdap-edit-modal">
                <div class="modal-header">
                    <div>
                        <h3>Mantenimiento cliente GDAP</h3>
                        <small>@EditCustomerName</small>
                    </div>
                    <button @onclick="CloseEdit">×</button>
                </div>

                <div class="edit-body">
                    <label>Contacto
                        <input @bind="EditRequest.PrimaryContactName" />
                    </label>
                    <label>Correo principal
                        <input @bind="EditRequest.PrimaryEmail" />
                    </label>
                    <label>Correos CC
                        <input @bind="EditRequest.CCEmails" />
                    </label>
                    <label class="checkbox-line">
                        <input type="checkbox" @bind="EditRequest.AutoSendEmail" /> Envío automático
                    </label>
                    <label class="checkbox-line">
                        <input type="checkbox" @bind="EditRequest.IsActive" /> Cliente activo
                    </label>
                    <label class="full">Motivo exclusión / observaciones
                        <textarea @bind="EditRequest.ExcludeReason"></textarea>
                    </label>
                </div>

                <div class="modal-actions">
                    <button class="btn-secondary" @onclick="CloseEdit">Cancelar</button>
                    <button class="btn-primary" @onclick="SaveCustomerAsync">Guardar cambios</button>
                </div>
            </div>
        </div>
    }

    @if (ShowAutomationConfirm && AutomationCustomer is not null)
    {
        <div class="gdap-modal-backdrop">
            <div class="gdap-confirm-modal">
                <div class="modal-header">
                    <div>
                        <h3>Ejecutar Automation GDAP</h3>
                        <small>ITQS-SOC-GENERA-GDAP-PC-CLIENTES</small>
                    </div>
                    <button disabled="@IsAutomationRunning" @onclick="CloseAutomationConfirm">×</button>
                </div>

                <div class="confirm-body">
                    <p>Se ejecutará la Automation únicamente para este cliente.</p>

                    <div class="detail-line"><span>Cliente</span><b>@AutomationCustomer.CustomerName</b></div>
                    <div class="detail-line"><span>Partner Tenant</span><b>@AutomationCustomer.PartnerTenant</b></div>
                    <div class="detail-line"><span>Customer TenantId</span><b>@AutomationCustomer.CustomerTenantId</b></div>
                    <div class="detail-line"><span>Modo</span><b>Producción / TestMode = false</b></div>

                    <div class="automation-note">
                        La ejecución solicitará generación/renovación GDAP y, si aplica, generará el Approval URL.
                        Después de iniciar el Job, use Actualizar para refrescar el estado cuando la Automation termine.
                    </div>
                </div>

                <div class="modal-actions">
                    <button class="btn-secondary" disabled="@IsAutomationRunning" @onclick="CloseAutomationConfirm">Cancelar</button>
                    <button class="btn-primary" disabled="@IsAutomationRunning" @onclick="ExecuteAutomationAsync">
                        @(IsAutomationRunning ? "Ejecutando..." : "Ejecutar Automation")
                    </button>
                </div>
            </div>
        </div>
    }

</div>
