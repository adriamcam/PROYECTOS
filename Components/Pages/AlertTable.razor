@using ITQS.SupportOperationsCenter.Models

<div class="table-card">
    <div class="table-header">
        <div>
            <h2>@Title</h2>
            <span>@Subtitle</span>
        </div>
        <span class="page-size-label">Máximo 50 registros por página</span>
    </div>
    <div class="table-scroll">
        <table>
            <thead>
                <tr>
                    <th>Alerta</th>
                    <th>Cliente</th>
                    <th>Severidad</th>
                    <th>KPI</th>
                    <th>Recurso</th>
                    <th>Eventos</th>
                    <th>Estado</th>
                    <th>Asignado a</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (Items.Count == 0)
                {
                    <tr><td colspan="9" class="empty">No hay registros para mostrar.</td></tr>
                }
                else
                {
                    @foreach (var item in Items)
                    {
                        <tr>
                            <td class="truncate">@item.AlertName</td>
                            <td class="truncate">@item.CustomerName</td>
                            <td><span class="severity @GetSeverityClass(item.Severity)">@item.Severity</span></td>
                            <td>@item.KPIType</td>
                            <td class="truncate">@item.ResourceName</td>
                            <td>@(item.Events ?? 0)</td>
                            <td><span class="status-pill @GetStatusClass(item)">@GetStatus(item)</span></td>
                            <td class="truncate">@(string.IsNullOrWhiteSpace(item.AssignedTo) ? "-" : item.AssignedTo)</td>
                            <td class="actions slim">
                                @if (ShowAssign && string.IsNullOrWhiteSpace(item.AssignedEmail))
                                {
                                    <button class="btn primary small" @onclick="() => OnAssign.InvokeAsync(item.Id)">Asignar</button>
                                }
                                else
                                {
                                    <button class="btn info small" @onclick="() => OnViewDetail.InvokeAsync(item.Id)">Ver Detalle</button>
                                    <button class="btn small" @onclick="() => OnAssign.InvokeAsync(item.Id)">In Progress</button>
                                    <button class="btn danger small" @onclick="() => OnClose.InvokeAsync(item.Id)">Cerrar</button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="pagination">
        <button class="btn" disabled="@(PageNumber <= 1)" @onclick="() => OnPageChanged.InvokeAsync(PageNumber - 1)">Anterior</button>
        <span>Página @PageNumber</span>
        <button class="btn" disabled="@(Items.Count < 50)" @onclick="() => OnPageChanged.InvokeAsync(PageNumber + 1)">Siguiente</button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter, EditorRequired] public IReadOnlyList<AlertListItemDto> Items { get; set; } = [];
    [Parameter] public int PageNumber { get; set; }
    [Parameter] public bool ShowAssign { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter, EditorRequired] public EventCallback<long> OnViewDetail { get; set; }
    [Parameter, EditorRequired] public EventCallback<long> OnAssign { get; set; }
    [Parameter, EditorRequired] public EventCallback<long> OnClose { get; set; }

    private static string GetStatus(AlertListItemDto item)
        => string.IsNullOrWhiteSpace(item.AssignedEmail) ? "Sin asignar" : "Asignada";

    private static string GetStatusClass(AlertListItemDto item)
        => string.IsNullOrWhiteSpace(item.AssignedEmail) ? "unassigned" : "assigned";

    private static string GetSeverityClass(string? severity)
    {
        var value = (severity ?? string.Empty).Trim().ToLowerInvariant();
        return value switch
        {
            "sev0" or "critical" or "crítica" or "critica" => "sev0",
            "sev1" or "high" or "alta" => "sev1",
            "sev2" or "medium" or "media" => "sev2",
            "sev3" or "low" or "baja" => "sev3",
            _ => "sev4"
        };
    }
}
