@page "/portal"

<PageTitle>Portal - ITQS SOC</PageTitle>

<section class="portal-shell">

    <div class="portal-actions">
        <a class="back-button" href="/">
            ← Volver al Inicio
        </a>
    </div>

    <div class="portal-header">
        <div class="portal-logo">ITQS</div>
        <h1>Support Operations Center</h1>
        <p>Seleccione el módulo de trabajo.</p>
    </div>

    <div class="portal-modules">

        <article class="portal-card cloud">
            <div class="portal-icon">☁</div>

            <h2>Support Cloud</h2>

            <p>
                Alertas, clientes, inventario, Azure,
                monitoreo y operación Cloud.
            </p>

            <a class="portal-button cloud-button" href="/support-cloud">
                Ingresar →
            </a>
        </article>

        <article class="portal-card modern">
            <div class="portal-icon">▣</div>

            <h2>Support Modern Work</h2>

            <p>
                Microsoft 365, Exchange, Teams,
                SharePoint, OneDrive y licenciamiento.
            </p>

            <a class="portal-button modern-button" href="/support-modern-work">
                Ingresar →
            </a>
        </article>

    </div>

</section>