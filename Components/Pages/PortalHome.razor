@page "/portal"
@inject NavigationManager Navigation

<PageTitle>Portal - ITQS SOC</PageTitle>

<section class="portal-shell">
    <div class="portal-header">
        <div class="portal-logo">ITQS</div>
        <h1>Support Operations Center</h1>
        <p>Seleccione el módulo de trabajo.</p>
    </div>

    <div class="portal-modules">
        <article class="portal-card cloud">
            <div class="portal-icon">☁</div>
            <h2>Support Cloud</h2>
            <p>Alertas, clientes, inventario, Azure, monitoreo y operación Cloud.</p>
            <button @onclick='() => Navigation.NavigateTo("/support-cloud")'>
                Ingresar →
            </button>
        </article>

        <article class="portal-card modern">
            <div class="portal-icon">▣</div>
            <h2>Support Modern Work</h2>
            <p>Microsoft 365, Exchange, Teams, SharePoint, OneDrive y licenciamiento.</p>
            <button @onclick='() => Navigation.NavigateTo("/support-modern-work")'>
                Ingresar →
            </button>
        </article>
    </div>
</section>