@page "/support-cloud"

<PageTitle>Support Cloud - ITQS SOC</PageTitle>

<section class="module-shell">

    <div class="module-actions">
        <a class="back-button" href="/portal">
            ← Volver al Portal
        </a>
    </div>

    <div class="module-header">
        <div class="module-logo">☁</div>
        <h1>Support Cloud</h1>
        <p>
            Operación Cloud, monitoreo, clientes,
            inventario y administración.
        </p>
    </div>

    <div class="module-grid">

        <a class="module-card" href="/dashboard-alertas">
            <div class="module-icon blue">◈</div>
            <h2>Dashboard</h2>
            <p>
                Vista general de alertas,
                métricas y estado operativo.
            </p>
            <span>Ingresar →</span>
        </a>

        <a class="module-card" href="/alertas-asignadas">
            <div class="module-icon green">👤</div>
            <h2>Asignadas a mí</h2>
            <p>
                Alertas asignadas al usuario
                actual para seguimiento.
            </p>
            <span>Ingresar →</span>
        </a>

        <a class="module-card" href="/alertas-sin-asignar">
            <div class="module-icon purple">☰</div>
            <h2>Sin asignar</h2>
            <p>
                Alertas pendientes de
                asignación operativa.
            </p>
            <span>Ingresar →</span>
        </a>

        <a class="module-card" href="/alertas-manager">
            <div class="module-icon orange">⚙</div>
            <h2>Manager</h2>
            <p>
                Gestión general de alertas,
                configuración y administración.
            </p>
            <span>Ingresar →</span>
        </a>

    </div>

</section>