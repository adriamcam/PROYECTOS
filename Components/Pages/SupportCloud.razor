@page "/support-cloud"

<PageTitle>Support Cloud - ITQS SOC</PageTitle>

<section class="module-shell">

    <div class="module-actions">
        <a class="back-button" href="/portal">
            ← Volver al Portal
        </a>
    </div>

    <div class="module-header">
        <div class="module-logo">☁</div>
        <h1>Support Cloud</h1>
        <p>Operación Cloud, monitoreo, clientes, inventario y administración.</p>
    </div>

    <div class="module-grid">

        <a class="module-card" href="/cloud/monitoreo-alertas">
            <div class="module-icon blue">◇</div>
            <h2>Monitoreo de Alertas</h2>
            <p>Dashboard operativo, gestor de alertas, asignación y seguimiento.</p>
            <span>Ingresar →</span>
        </a>

        <a class="module-card" href="/cloud/info-clientes">
            <div class="module-icon green">👥</div>
            <h2>Info Clientes</h2>
            <p>Información de clientes, tenants, suscripciones y contactos operativos.</p>
            <span>Ingresar →</span>
        </a>

        <a class="module-card" href="/cloud/inventory">
            <div class="module-icon purple">▦</div>
            <h2>Inventory</h2>
            <p>Inventario multi-tenant de recursos Azure, servidores y servicios.</p>
            <span>Ingresar →</span>
        </a>

        <a class="module-card" href="/cloud/admin-manager">
            <div class="module-icon orange">⚙</div>
            <h2>Admin / Manager</h2>
            <p>Administración, configuración, reglas, usuarios y gestión operativa.</p>
            <span>Ingresar →</span>
        </a>

    </div>

</section>