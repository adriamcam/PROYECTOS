@page "/support-cloud"
@rendermode @(new InteractiveServerRenderMode())

@using ITQS.SupportOperationsCenter.Components.Dashboard

<PageTitle>Support Cloud - ITQS SOC</PageTitle>

<section class="cloud-layout">

    <aside class="cloud-sidebar">
        <div class="cloud-brand">
            <span>☁</span>
            <strong>Support Cloud</strong>
        </div>

        <nav class="cloud-menu">

            <div class="menu-group">
                <button type="button"
                        class="menu-title menu-button"
                        @onclick="SelectAlertMonitoring">
                    🔔 Monitoreo de Alertas
                </button>

                <div class="menu-links @(ShowAlertMenu ? "show" : "")">
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Alertas")'>Dashboard</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Alertas")'>Asignadas a mí</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Alertas")'>Sin asignar</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Alertas")'>Todas las alertas</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Alertas")'>Alertas críticas</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Clientes")'>Info Clientes</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Admin")'>Admin / Manager View</button>
                </div>
            </div>

        </nav>

        <a class="cloud-logout" href="/portal">← Volver al Portal</a>
    </aside>

    <main class="cloud-main">
        <header class="cloud-topbar">
            <div class="hamburger">☰</div>
            <strong>Support Cloud</strong>

            <div class="cloud-user">
                <div class="avatar">A</div>
                <div>
                    <strong>Administrador</strong>
                    <span>ITQS SOC</span>
                </div>
            </div>
        </header>

        <section class="cloud-content">

            @if (CurrentModule == "Alertas")
            {
                <AlertDashboard UserEmail="wcambronero@itqscr.com" />
            }
            else if (CurrentModule == "Clientes")
            {
                <CustomerDashboard />
            }
            else if (CurrentModule == "Admin")
            {
                <AdminDashboard />
            }
            else
            {
                <h1>Support Cloud</h1>
                <p>Seleccione un módulo del menú lateral.</p>
                <div class="cloud-divider"></div>
            }

        </section>
    </main>

</section>

@code {
    private string CurrentModule = "";
    private bool ShowAlertMenu = false;

    private void SelectAlertMonitoring()
    {
        CurrentModule = "Alertas";
        ShowAlertMenu = !ShowAlertMenu;
    }

    private void SelectModule(string module)
    {
        CurrentModule = module;
        ShowAlertMenu = true;
    }
}
