@page "/support-cloud"
@rendermode @(new InteractiveServerRenderMode())
@using ITQS.SupportOperationsCenter.Components.Dashboard
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Support Cloud - ITQS SOC</PageTitle>

<section class="cloud-layout">

    <aside class="cloud-sidebar">
        <div class="cloud-brand">
            <span>☁</span>
            <strong>Support Cloud</strong>
        </div>

        <nav class="cloud-menu">
            <div class="menu-group">
                <button type="button"
                        class="menu-title menu-button"
                        @onclick="SelectAlertMonitoring">
                    🔔 Monitoreo de Alertas
                </button>

                <div class="menu-links @(ShowAlertMenu ? "show" : "")">
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Dashboard")'>Dashboard</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Asignadas")'>Asignadas a mí</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("SinAsignar")'>Sin asignar</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Todas")'>Todas las alertas</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Criticas")'>Alertas críticas</button>
                </div>
            </div>
        </nav>

        <a class="cloud-logout" href="/portal">← Volver al Portal</a>
    </aside>

    <main class="cloud-main">
        <header class="cloud-topbar">
            <div class="hamburger">☰</div>
            <strong>@CurrentTitle</strong>

            <div class="cloud-user">
                <div class="avatar">@UserInitial</div>

                <div>
                    <strong>@UserName</strong>
                    <span>@UserEmail</span>
                </div>
            </div>
        </header>

        <section class="cloud-content">

            @if (!HasAccess)
            {
                <h1>Acceso denegado</h1>
                <p>No tienes permisos para ingresar a Support Cloud.</p>

                <div class="cloud-divider"></div>

                <h4>Group Claims detectados</h4>

                @if (GroupClaims.Any())
                {
                    @foreach (var claim in GroupClaims)
                    {
                        <div>@claim</div>
                    }
                }
                else
                {
                    <p>No llegaron claims de grupo en el token.</p>
                }

                <div class="cloud-divider"></div>

                <h4>Todos los Claims</h4>

                @if (AllClaims.Any())
                {
                    @foreach (var claim in AllClaims)
                    {
                        <div>@claim.Type = @claim.Value</div>
                    }
                }
                else
                {
                    <p>No llegaron claims en el token.</p>
                }
            }
            else if (CurrentModule == "Alertas")
            {
                <AlertDashboard UserEmail="@UserEmail" />
            }
            else if (CurrentModule == "Dashboard")
            {
                <DashboardAlerts UserEmail="@UserEmail" UserName="@UserName" />
            }
            else if (CurrentModule == "Asignadas")
            {
                <AssignedToMeAlerts />
            }
            else if (CurrentModule == "SinAsignar")
            {
                <UnassignedAlerts />
            }
            else if (CurrentModule == "Todas")
            {
                <AllAlerts />
            }
            else if (CurrentModule == "Criticas")
            {
                <CriticalAlerts />
            }
            else if (CurrentModule == "Clientes")
            {
                <CustomerDashboard />
            }
            else if (CurrentModule == "Admin")
            {
                <AdminDashboard />
            }
            else
            {
                <AlertDashboard UserEmail="@UserEmail" />
            }

        </section>
    </main>
</section>

@code {
    private const string CloudGroupId = "bf276a6b-a93f-4725-9f28-75ea0b055ad4";

    private bool HasAccess = false;
    private string CurrentModule = "";
    private bool ShowAlertMenu = false;

    private string UserName = "";
    private string UserEmail = "";
    private string UserInitial = "?";

    private List<string> GroupClaims = new();
    private List<Claim> AllClaims = new();

    private string CurrentTitle =>
        CurrentModule switch
        {
            "Alertas" => "Monitoreo de Alertas",
            "Dashboard" => "Dashboard",
            "Asignadas" => "Asignadas a mí",
            "SinAsignar" => "Sin asignar",
            "Todas" => "Todas las alertas",
            "Criticas" => "Alertas críticas",
            "Clientes" => "Info Clientes",
            "Admin" => "Admin / Manager View",
            _ => "Monitoreo de Alertas"
        };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        AllClaims = user.Claims.ToList();

        GroupClaims = user.Claims
            .Where(c => c.Type.Contains("group", StringComparison.OrdinalIgnoreCase))
            .Select(c => $"{c.Type}: {c.Value}")
            .ToList();

        UserName =
            user.FindFirst("name")?.Value
            ?? user.Identity?.Name
            ?? "Usuario";

        UserEmail =
            user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.FindFirst("email")?.Value
            ?? user.FindFirst("preferred_username")?.Value
            ?? user.Identity?.Name
            ?? "";

        HasAccess =
            user.HasClaim("groups", CloudGroupId) ||
            user.HasClaim("http://schemas.microsoft.com/ws/2008/06/identity/claims/groups", CloudGroupId);

        if (!string.IsNullOrWhiteSpace(UserName))
        {
            UserInitial = UserName.Substring(0, 1).ToUpper();
        }
    }

    private void SelectAlertMonitoring()
    {
        CurrentModule = "Alertas";
        ShowAlertMenu = !ShowAlertMenu;
        StateHasChanged();
    }

    private void SelectModule(string module)
    {
        CurrentModule = module;
        ShowAlertMenu = true;
        StateHasChanged();
    }
}