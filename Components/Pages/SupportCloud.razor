@page "/support-cloud"
@rendermode @(new InteractiveServerRenderMode())

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using ITQS.SupportOperationsCenter.Components.Dashboard
@using ITQS.SupportOperationsCenter.Components.Maintenance
@using ITQS.SupportOperationsCenter.Components.Maintenance.SqlOperations
@using ITQS.SupportOperationsCenter.Components.Administration.Customers
@using ITQS.SupportOperationsCenter.Components.Administration.AppRegistrationsITQS
@using ITQS.SupportOperationsCenter.Components.Administration.GdapAdminLinks

@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Support Cloud - ITQS SOC</PageTitle>

<section class="cloud-layout">

    <aside class="cloud-sidebar">
        <div class="cloud-brand">
            <span>☁</span>
            <strong>Support Cloud</strong>
        </div>

        <nav class="cloud-menu">
            <div class="menu-group">
                <button type="button" class="menu-title menu-button" @onclick="SelectAlertMonitoring">
                    🔔 Monitoreo de Alertas
                </button>

                <div class="menu-links @(ShowAlertMenu ? "show" : "")">
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Dashboard")'>Dashboard</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("Asignadas")'>Asignadas a mí</button>
                    <button type="button" class="menu-link" @onclick='() => SelectModule("AdminManagerView")'>Admin / Manager View</button>
                </div>
            </div>

            @if (IsAdmin)
            {
                <div class="menu-group">
                    <button type="button" class="menu-title menu-button" @onclick="SelectAdministration">
                        ⚙️ Administración
                    </button>

                    <div class="menu-links @(ShowAdministrationMenu ? "show" : "")">
                        <button type="button" class="menu-link" @onclick='() => SelectModule("CustomerAdmin")'>
                            Clientes
                        </button>

                        <button type="button" class="menu-link" @onclick='() => SelectModule("AppRegistrationsITQS")'>
                            App Registrations ITQS
                        </button>

                        <button type="button" class="menu-link" @onclick='() => SelectModule("GdapAdminLinks")'>
                            Admin Links GDAP
                        </button>
                    </div>
                </div>
            }

            @if (IsAdmin)
            {
                <div class="menu-group">
                    <button type="button" class="menu-title menu-button" @onclick="SelectMaintenance">
                        🛠️ Mantenimiento
                    </button>

                    <div class="menu-links @(ShowMaintenanceMenu ? "show" : "")">

                        <button type="button" class="menu-link menu-link-parent" @onclick="SelectSqlMenu">
                            @(ShowSqlMenu ? "▼ SQL" : "▶ SQL")
                        </button>

                        @if (ShowSqlMenu)
                        {
                            <div class="menu-subtitle">Dashboard</div>

                            <button type="button" class="menu-link menu-link-child" @onclick='() => SelectModule("SqlDashboard")'>
                                • Dashboard
                            </button>

                            <div class="menu-subtitle">Mantenimiento</div>

                            <button type="button" class="menu-link menu-link-child" @onclick='() => SelectModule("SqlMaintenance")'>
                                • Mantenimiento
                            </button>

                            <div class="menu-subtitle">Monitor</div>

                            <button type="button" class="menu-link menu-link-child" @onclick='() => SelectModule("SqlJobs")'>
                                • Jobs SQL
                            </button>

                            <button type="button" class="menu-link menu-link-child" @onclick='() => SelectModule("SqlBlocking")'>
                                • Bloqueos
                            </button>

                            <button type="button" class="menu-link menu-link-child" @onclick='() => SelectModule("SqlActiveSessions")'>
                                • Sesiones
                            </button>

                            <button type="button" class="menu-link menu-link-child" @onclick='() => SelectModule("SqlSlowQueries")'>
                                • Consultas Lentas
                            </button>
                        }
                    </div>
                </div>
            }
        </nav>

        <a class="cloud-logout" href="/portal">← Volver al Portal</a>
    </aside>

    <main class="cloud-main">
        <header class="cloud-topbar">
            <div class="hamburger">☰</div>
            <strong>@CurrentTitle</strong>

            <div class="cloud-user">
                <div class="avatar">@UserInitial</div>

                <div>
                    <strong>@UserName</strong>
                    <span>@UserEmail</span>
                </div>
            </div>
        </header>

        <section class="cloud-content">

            @if (!HasAccess)
            {
                <h1>Acceso denegado</h1>
                <p>No tienes permisos para ingresar a Support Cloud.</p>
            }
            else if (CurrentModule == "Alertas")
            {
                <AlertDashboard UserEmail="@UserEmail" />
            }
            else if (CurrentModule == "Dashboard")
            {
                <DashboardAlerts UserEmail="@UserEmail" UserName="@UserName" />
            }
            else if (CurrentModule == "Asignadas")
            {
                <AssignedToMeAlerts />
            }
            else if (CurrentModule == "AdminManagerView")
            {
                <AdminManager />
            }
            else if (CurrentModule == "CustomerAdmin")
            {
                <CustomerAdmin />
            }
            else if (CurrentModule == "AppRegistrationsITQS")
            {
                <AppRegistrationsITQS />
            }
            else if (CurrentModule == "GdapAdminLinks")
            {
                <GdapAdminLinks />
            }
            else if (CurrentModule == "SqlDashboard")
            {
                <SqlOperationsDashboard NavigateModule="SelectModule" />
            }
            else if (CurrentModule == "SqlMaintenance")
            {
                <SqlMaintenance />
            }
            else if (CurrentModule == "SqlJobs")
            {
                <SqlJobs />
            }
            else if (CurrentModule == "SqlBlocking")
            {
                <SqlBlocking />
            }
            else if (CurrentModule == "SqlActiveSessions")
            {
                <SqlActiveSessions />
            }
            else if (CurrentModule == "SqlSlowQueries")
            {
                <SqlSlowQueries />
            }
            else if (CurrentModule == "Todas")
            {
                <AllAlerts />
            }
            else if (CurrentModule == "Criticas")
            {
                <CriticalAlerts />
            }
            else if (CurrentModule == "Clientes")
            {
                <CustomerDashboard />
            }
            else if (CurrentModule == "Admin")
            {
                <AdminDashboard />
            }
            else
            {
                <AlertDashboard UserEmail="@UserEmail" />
            }

        </section>
    </main>
</section>

@code {
    private const string CloudGroupId = "bf276a6b-a93f-4725-9f28-75ea0b055ad4";

    private bool HasAccess = false;
    private bool IsAdmin = false;

    private string CurrentModule = "";

    private bool ShowAlertMenu = false;
    private bool ShowAdministrationMenu = false;
    private bool ShowMaintenanceMenu = false;
    private bool ShowSqlMenu = false;

    private string UserName = "";
    private string UserEmail = "";
    private string UserInitial = "?";

    private List<string> GroupClaims = new();
    private List<Claim> AllClaims = new();

    private string CurrentTitle =>
        CurrentModule switch
        {
            "Alertas" => "Monitoreo de Alertas",
            "Dashboard" => "Dashboard",
            "Asignadas" => "Asignadas a mí",
            "AdminManagerView" => "Admin / Manager View",
            "CustomerAdmin" => "Administración / Clientes",
            "AppRegistrationsITQS" => "Administración / App Registrations ITQS",
            "GdapAdminLinks" => "Administración / Admin Links GDAP",

            "SqlDashboard" => "Mantenimiento / SQL / Dashboard",
            "SqlMaintenance" => "Mantenimiento / SQL / Mantenimiento",
            "SqlJobs" => "Mantenimiento / SQL / Monitor / Jobs SQL",
            "SqlBlocking" => "Mantenimiento / SQL / Monitor / Bloqueos",
            "SqlActiveSessions" => "Mantenimiento / SQL / Monitor / Sesiones",
            "SqlSlowQueries" => "Mantenimiento / SQL / Monitor / Consultas Lentas",

            "Todas" => "Todas las alertas",
            "Criticas" => "Alertas críticas",
            "Clientes" => "Info Clientes",
            "Admin" => "Admin / Manager View",

            _ => "Monitoreo de Alertas"
        };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        AllClaims = user.Claims.ToList();

        GroupClaims = user.Claims
            .Where(c => c.Type.Contains("group", StringComparison.OrdinalIgnoreCase))
            .Select(c => $"{c.Type}: {c.Value}")
            .ToList();

        UserName =
            user.FindFirst("name")?.Value
            ?? user.Identity?.Name
            ?? "Usuario";

        UserEmail =
            user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.FindFirst("email")?.Value
            ?? user.FindFirst("preferred_username")?.Value
            ?? user.Identity?.Name
            ?? "";

        HasAccess =
            user.HasClaim("groups", CloudGroupId) ||
            user.HasClaim("http://schemas.microsoft.com/ws/2008/06/identity/claims/groups", CloudGroupId);

        IsAdmin = true;

        if (!string.IsNullOrWhiteSpace(UserName))
        {
            UserInitial = UserName.Substring(0, 1).ToUpper();
        }
    }

    private void SelectAlertMonitoring()
    {
        CurrentModule = "Alertas";

        ShowAlertMenu = !ShowAlertMenu;
        ShowAdministrationMenu = false;
        ShowMaintenanceMenu = false;
        ShowSqlMenu = false;
    }

    private void SelectAdministration()
    {
        ShowAdministrationMenu = !ShowAdministrationMenu;

        ShowAlertMenu = false;
        ShowMaintenanceMenu = false;
        ShowSqlMenu = false;
    }

    private void SelectMaintenance()
    {
        ShowAdministrationMenu = false;

        ShowMaintenanceMenu = !ShowMaintenanceMenu;
        ShowAlertMenu = false;

        if (!ShowMaintenanceMenu)
        {
            ShowSqlMenu = false;
        }
    }

    private void SelectSqlMenu()
    {
        ShowSqlMenu = !ShowSqlMenu;

        ShowMaintenanceMenu = true;
        ShowAdministrationMenu = false;
        ShowAlertMenu = false;

        if (ShowSqlMenu)
        {
            CurrentModule = "SqlDashboard";
        }
    }

    private void SelectModule(string module)
    {
        CurrentModule = module;

        if (module == "CustomerAdmin" ||
            module == "AppRegistrationsITQS" ||
            module == "GdapAdminLinks")
        {
            ShowAdministrationMenu = true;

            ShowAlertMenu = false;
            ShowMaintenanceMenu = false;
            ShowSqlMenu = false;
        }
        else if (module.StartsWith("Sql", StringComparison.OrdinalIgnoreCase))
        {
            ShowMaintenanceMenu = true;
            ShowSqlMenu = true;

            ShowAlertMenu = false;
            ShowAdministrationMenu = false;
        }
        else
        {
            ShowAlertMenu = true;

            ShowAdministrationMenu = false;
            ShowMaintenanceMenu = false;
            ShowSqlMenu = false;
        }
    }
}
