@page "/support-cloud"
@rendermode @(new InteractiveServerRenderMode())

<PageTitle>Support Cloud - ITQS SOC</PageTitle>

<section class="cloud-layout">

    <aside class="cloud-sidebar">
        <div class="cloud-brand">
            <span>☁</span>
            <strong>Support Cloud</strong>
        </div>

        <nav class="cloud-menu">

            <div class="menu-group">
                <button type="button"
                        class="menu-title menu-button @(CurrentModule == "Alertas" ? "active" : "")"
                        @onclick="ToggleAlertMenu">
                    🔔 Monitoreo de Alertas
                    <span class="menu-caret">@(ShowAlertMenu ? "⌃" : "⌄")</span>
                </button>

                <div class="menu-links @(ShowAlertMenu ? "show" : "")">
                    <button type="button" class="menu-link @(CurrentView == "Dashboard" ? "active" : "")" @onclick='() => SelectView("Alertas", "Dashboard")'>Dashboard</button>
                    <button type="button" class="menu-link @(CurrentView == "Asignadas" ? "active" : "")" @onclick='() => SelectView("Alertas", "Asignadas")'>Asignadas a mí</button>
                    <button type="button" class="menu-link @(CurrentView == "SinAsignar" ? "active" : "")" @onclick='() => SelectView("Alertas", "SinAsignar")'>Sin asignar</button>
                    <button type="button" class="menu-link @(CurrentView == "Todas" ? "active" : "")" @onclick='() => SelectView("Alertas", "Todas")'>Todas las alertas</button>
                    <button type="button" class="menu-link @(CurrentView == "Criticas" ? "active" : "")" @onclick='() => SelectView("Alertas", "Criticas")'>Alertas críticas</button>
                </div>
            </div>

            <button type="button" class="menu-item @(CurrentModule == "Clientes" ? "active" : "")" @onclick='() => SelectView("Clientes", "Clientes")'>👥 Info Clientes</button>
            <button type="button" class="menu-item @(CurrentModule == "Inventory" ? "active" : "")" @onclick='() => SelectView("Inventory", "Inventory")'>📦 Inventory</button>
            <button type="button" class="menu-item @(CurrentModule == "Admin" ? "active" : "")" @onclick='() => SelectView("Admin", "Admin")'>⚙ Admin / Manager View</button>

        </nav>

        <a class="cloud-logout" href="/portal">← Volver al Portal</a>
    </aside>

    <main class="cloud-main">
        <header class="cloud-topbar">
            <div class="hamburger">☰</div>
            <strong>Support Cloud</strong>

            <div class="cloud-user">
                <div class="avatar">A</div>
                <div>
                    <strong>Administrador</strong>
                    <span>ITQS SOC</span>
                </div>
            </div>
        </header>

        <section class="cloud-content">

            @if (CurrentModule == "Alertas")
            {
                <h1>Monitoreo de Alertas</h1>
                <p>Monitoreo centralizado de alertas, asignaciones y operación.</p>

                <div class="cloud-divider"></div>

                @if (CurrentView == "Dashboard")
                {
                    <div class="kpi-row">

                        <article class="kpi-box">
                            <h3>Alertas Totales</h3>
                            <div class="kpi-icon blue">🔔</div>
                            <strong>146</strong>
                            <span>Activas</span>
                        </article>

                        <article class="kpi-box">
                            <h3>Backup Alerts</h3>
                            <div class="kpi-icon purple">💾</div>
                            <strong>42</strong>
                            <span>Activas</span>
                        </article>

                        <article class="kpi-box">
                            <h3>Management Alerts</h3>
                            <div class="kpi-icon orange">⚙</div>
                            <strong>71</strong>
                            <span>Activas</span>
                        </article>

                        <article class="kpi-box">
                            <h3>Asignadas a mí</h3>
                            <div class="kpi-icon green">👤</div>
                            <strong>28</strong>
                            <span>Pendientes</span>
                        </article>

                        <article class="kpi-box">
                            <h3>Sin asignar</h3>
                            <div class="kpi-icon red">⚠</div>
                            <strong>34</strong>
                            <span>Pendientes</span>
                        </article>

                        <article class="kpi-box">
                            <h3>Resueltas hoy</h3>
                            <div class="kpi-icon purple">✓</div>
                            <strong>16</strong>
                            <span>Cerradas</span>
                        </article>

                    </div>
                }
                else if (CurrentView == "Asignadas")
                {
                    <div class="placeholder-panel">
                        <h2>Asignadas a mí</h2>
                        <p>Aquí se mostrarán las alertas asignadas al usuario autenticado.</p>
                    </div>
                }
                else if (CurrentView == "SinAsignar")
                {
                    <div class="placeholder-panel">
                        <h2>Sin asignar</h2>
                        <p>Aquí se mostrarán las alertas activas pendientes de asignación.</p>
                    </div>
                }
                else if (CurrentView == "Todas")
                {
                    <div class="placeholder-panel">
                        <h2>Todas las alertas</h2>
                        <p>Aquí se mostrará el listado general de alertas con filtros operativos.</p>
                    </div>
                }
                else if (CurrentView == "Criticas")
                {
                    <div class="placeholder-panel">
                        <h2>Alertas críticas</h2>
                        <p>Aquí se mostrarán únicamente las alertas críticas o de mayor prioridad.</p>
                    </div>
                }
            }
            else if (CurrentModule == "Clientes")
            {
                <h1>Info Clientes</h1>
                <p>Información de clientes, tenants, suscripciones y contactos operativos.</p>
                <div class="cloud-divider"></div>
                <div class="placeholder-panel">
                    <h2>Módulo en preparación</h2>
                    <p>Este módulo se conectará a la información de clientes y suscripciones.</p>
                </div>
            }
            else if (CurrentModule == "Inventory")
            {
                <h1>Inventory</h1>
                <p>Inventario Azure multi-tenant de recursos, servidores y servicios.</p>
                <div class="cloud-divider"></div>
                <div class="placeholder-panel">
                    <h2>Módulo en preparación</h2>
                    <p>Este módulo se conectará al inventario de recursos Azure.</p>
                </div>
            }
            else if (CurrentModule == "Admin")
            {
                <h1>Admin / Manager View</h1>
                <p>Administración, configuración, usuarios, reglas y gestión operativa.</p>
                <div class="cloud-divider"></div>
                <div class="placeholder-panel">
                    <h2>Módulo en preparación</h2>
                    <p>Este módulo se usará para administración y configuración del SOC.</p>
                </div>
            }
            else
            {
                <h1>Support Cloud</h1>
                <p>Seleccione un módulo del menú lateral.</p>
                <div class="cloud-divider"></div>
            }

        </section>
    </main>

</section>

@code {
    private string CurrentModule = "";
    private string CurrentView = "";
    private bool ShowAlertMenu = false;

    private void ToggleAlertMenu()
    {
        CurrentModule = "Alertas";
        CurrentView = "Dashboard";
        ShowAlertMenu = !ShowAlertMenu;
    }

    private void SelectView(string module, string view)
    {
        CurrentModule = module;
        CurrentView = view;

        if (module != "Alertas")
        {
            ShowAlertMenu = false;
        }
        else
        {
            ShowAlertMenu = true;
        }
    }
}
