@page "/support-cloud"

<PageTitle>Support Cloud - ITQS SOC</PageTitle>

<section class="cloud-layout">

    <aside class="cloud-sidebar">
        <div class="cloud-brand">
            <span>☁</span>
            <strong>Support Cloud</strong>
        </div>

        <nav class="cloud-menu">
            <div class="menu-group active">
                <div class="menu-title">🔔 Monitoreo de Alertas</div>
                <a href="/cloud/dashboard">Dashboard</a>
                <a href="/cloud/asignadas">Asignadas a mí</a>
                <a href="/cloud/sin-asignar">Sin asignar</a>
                <a href="/cloud/todas-alertas">Todas las alertas</a>
                <a href="/cloud/alertas-criticas">Alertas críticas</a>
            </div>

            <a class="menu-item" href="/cloud/info-clientes">👥 Info Clientes</a>
            <a class="menu-item" href="/cloud/inventory">▦ Inventory</a>
            <a class="menu-item" href="/cloud/admin-manager">⚙ Admin / Manager</a>
        </nav>

        <a class="cloud-logout" href="/portal">← Volver al Portal</a>
    </aside>

    <main class="cloud-main">
        <header class="cloud-topbar">
            <div class="hamburger">☰</div>
            <strong>Support Cloud</strong>

            <div class="cloud-user">
                <div class="avatar">A</div>
                <div>
                    <strong>Administrador</strong>
                    <span>ITQS SOC</span>
                </div>
            </div>
        </header>

        <section class="cloud-content">
            <h1>Monitoreo de Alertas</h1>
            <p>Monitoreo centralizado de alertas, asignaciones y operación.</p>

            <div class="cloud-divider"></div>

            <div class="kpi-row">
                <article class="kpi-box">
                    <h3>Alertas Totales</h3>
                    <div class="kpi-icon blue">🔔</div>
                    <strong>146</strong>
                    <span>+12 hoy</span>
                </article>

                <article class="kpi-box">
                    <h3>Asignadas a mí</h3>
                    <div class="kpi-icon green">👤</div>
                    <strong>28</strong>
                    <span>+5 hoy</span>
                </article>

                <article class="kpi-box">
                    <h3>Sin asignar</h3>
                    <div class="kpi-icon orange">👤</div>
                    <strong>34</strong>
                    <span>+8 hoy</span>
                </article>

                <article class="kpi-box">
                    <h3>Críticas</h3>
                    <div class="kpi-icon red">⚠</div>
                    <strong>7</strong>
                    <span>+2 hoy</span>
                </article>

                <article class="kpi-box">
                    <h3>Resueltas hoy</h3>
                    <div class="kpi-icon purple">✓</div>
                    <strong>16</strong>
                    <span>+3 hoy</span>
                </article>
            </div>
        </section>
    </main>

</section>