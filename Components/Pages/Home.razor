@page "/"
@page "/home"
@rendermode @(new InteractiveServerRenderMode())
@inject NavigationManager Navigation

<PageTitle>Home - ITQS SOC</PageTitle>

<section class="home-hero">
    <div class="hero-logo">ITQS</div>

    <h1>Bienvenido</h1>

    <p>ITQS Support Operations Center</p>

    <span class="hero-subtitle">
        Selecciona el área en la que deseas trabajar.
    </span>
</section>

<section class="area-selector">
    <div class="area-grid">

        <article class="area-card cloud">
            <div class="area-icon">☁</div>
            <h2>Soporte Cloud</h2>
            <p>
                Gestión de alertas, inventario, clientes, recursos Azure,
                monitoreo y administración Cloud.
            </p>
            <button class="btn primary wide"
                    @onclick='() => Navigation.NavigateTo("/soporte/cloud")'>
                Ingresar →
            </button>
        </article>

        <article class="area-card m365">
            <div class="area-icon">▣</div>
            <h2>Soporte 365</h2>
            <p>
                Gestión operativa de Microsoft 365, Exchange Online,
                Teams, SharePoint, OneDrive y licenciamiento.
            </p>
            <button class="btn purple wide"
                    @onclick='() => Navigation.NavigateTo("/soporte365")'>
                Ingresar →
            </button>
        </article>

        <article class="area-card security">
            <div class="area-icon">🛡</div>
            <h2>Seguridad</h2>
            <p>
                Microsoft Sentinel, Defender, incidentes,
                cumplimiento y gestión de riesgos.
            </p>
            <button class="btn green wide"
                    @onclick='() => Navigation.NavigateTo("/seguridad")'>
                Ingresar →
            </button>
        </article>

    </div>
</section>