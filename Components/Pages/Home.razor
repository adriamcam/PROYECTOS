@page "/"
@rendermode @(new InteractiveServerRenderMode())
@inject NavigationManager Navigation

<PageTitle>Ingresar - ITQS SOC</PageTitle>

<section class="login-shell">
    <div class="login-panel">
        <div class="login-logo">ITQS</div>

        <h1>Bienvenido</h1>
        <p>ITQS Support Operations Center</p>

        <div class="login-form">
            <label>Correo</label>
            <input @bind="email" placeholder="usuario@itqscr.com" />

            <label>Nombre</label>
            <input @bind="name" placeholder="Nombre completo" />

            <button class="login-button" @onclick="Login">
                Ingresar
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="login-error">@error</div>
        }
    </div>
</section>

@code {
    private string email = "wcambronero@itqscr.com";
    private string name = "William Cambronero";
    private string? error;

    private void Login()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(name))
        {
            error = "Debe ingresar nombre y correo.";
            return;
        }

        Navigation.NavigateTo("/home");
    }
}