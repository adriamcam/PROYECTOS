@page "/soporte-cloud"
@inject NavigationManager Navigation

<PageTitle>Soporte Cloud - ITQS SOC</PageTitle>

<div class="page-title">
    <h1>Soporte Cloud</h1>
    <p>Centro operativo para el departamento Cloud.</p>
</div>

<section class="module-grid">
    <article class="module-card enabled" @onclick='() => Navigation.NavigateTo("/soporte-cloud/gestor-alertas")'>
        <div class="module-icon">◇</div>
        <h2>Gestor de Alertas</h2>
        <p>Dashboard, asignación, seguimiento, detalle y cierre de alertas.</p>
        <span>Entrar →</span>
    </article>
    <article class="module-card enabled" @onclick='() => Navigation.NavigateTo("/soporte-cloud/clientes")'>
        <div class="module-icon">👥</div>
        <h2>Clientes</h2>
        <p>Información operativa de clientes, tenants y suscripciones.</p>
        <span>Ver módulo →</span>
    </article>
    <article class="module-card enabled" @onclick='() => Navigation.NavigateTo("/soporte-cloud/inventory")'>
        <div class="module-icon">▦</div>
        <h2>Inventory</h2>
        <p>Inventario multi-tenant de recursos Azure.</p>
        <span>Ver módulo →</span>
    </article>
    <article class="module-card enabled" @onclick='() => Navigation.NavigateTo("/soporte-cloud/admin")'>
        <div class="module-icon">⚙</div>
        <h2>Administración</h2>
        <p>Configuración, usuarios, reglas y mantenimiento operativo.</p>
        <span>Ver módulo →</span>
    </article>
</section>
