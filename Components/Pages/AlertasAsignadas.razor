@page "/soporte-cloud/gestor-alertas/asignadas"
@rendermode @(new InteractiveServerRenderMode())
@inject IAlertService AlertService
@inject IConfiguration Configuration

<PageTitle>Alertas Asignadas - ITQS SOC</PageTitle>

<div class="page-title compact">
    <h1>Alertas Asignadas</h1>
    <p>Alertas tomadas por el usuario actual.</p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert-message danger">@errorMessage</div>
}
@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert-message success">@successMessage</div>
}

<section class="alert-workspace">
    <div class="workspace-header">
        <div class="tabs flat">
            <a class="tab" href="/soporte-cloud/gestor-alertas/dashboard">Dashboard</a>
            <button class="tab active">Asignadas</button>
            <a class="tab" href="/soporte-cloud/gestor-alertas/historial">Historial</a>
        </div>
        <div class="workspace-actions">
            <div class="toolbar-search"><span>⌕</span><input @bind="search" @bind:event="oninput" placeholder="Buscar alerta, cliente, recurso..." /></div>
            <button class="btn" @onclick="LoadAsync">Actualizar</button>
        </div>
    </div>

    <div class="table-card">
        <div class="table-header"><h2>Asignadas a @userName</h2><span>Máximo 50 registros por página</span></div>
        <div class="table-scroll">
            <table>
                <thead><tr><th>Alerta</th><th>Cliente</th><th>Severidad</th><th>KPI</th><th>Recurso</th><th>Eventos</th><th>Asignado</th><th>Acción</th></tr></thead>
                <tbody>
                    @if (assigned.Count == 0)
                    {
                        <tr><td colspan="8" class="empty">No hay alertas asignadas.</td></tr>
                    }
                    else
                    {
                        @foreach (var alert in assigned)
                        {
                            <tr>
                                <td class="truncate">@alert.AlertName</td>
                                <td>@alert.CustomerName</td>
                                <td><span class="severity @GetSeverityClass(alert.Severity)">@alert.Severity</span></td>
                                <td>@alert.KPIType</td>
                                <td class="truncate">@alert.ResourceName</td>
                                <td>@alert.Events</td>
                                <td><span class="status-pill assigned">@alert.AssignedTo</span></td>
                                <td class="actions slim">
                                    <button class="btn small" @onclick="() => ViewDetailAsync(alert.Id)">Ver</button>
                                    <button class="btn small info">In Progress</button>
                                    <button class="btn small danger" @onclick="() => CloseAsync(alert.Id)">Cerrar</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="pagination"><button class="btn small" disabled="@(pageNumber <= 1)" @onclick="PreviousPage">Anterior</button><span>Página @pageNumber</span><button class="btn small" @onclick="NextPage">Siguiente</button></div>
    </div>
</section>

@if (selectedDetail?.Alert is not null)
{
    <div class="drawer-backdrop" @onclick="CloseDetail"></div>
    <aside class="detail-drawer">
        <div class="drawer-header"><div><span class="eyebrow">Detalle alerta</span><h2>@selectedDetail.Alert.AlertName</h2></div><button class="icon-button" @onclick="CloseDetail">×</button></div>
        <dl class="detail-list">
            <dt>Cliente</dt><dd>@selectedDetail.Alert.CustomerName</dd>
            <dt>Suscripción</dt><dd>@selectedDetail.Alert.SubscriptionName</dd>
            <dt>Recurso</dt><dd>@selectedDetail.Alert.ResourceName</dd>
            <dt>Severidad</dt><dd>@selectedDetail.Alert.Severity</dd>
            <dt>KPI</dt><dd>@selectedDetail.Alert.KPIType</dd>
            <dt>AlertId</dt><dd>@selectedDetail.Alert.AlertId</dd>
        </dl>
        <h3>Historial</h3>
        <div class="history-list">
            @foreach (var item in selectedDetail.History)
            {
                <div class="history-item"><strong>@item.Action</strong><span>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm") · @item.UserEmail</span><p>@item.Comment</p></div>
            }
        </div>
    </aside>
}

@code {
    private IReadOnlyList<AlertListItemDto> assigned = [];
    private AlertDetailResultDto? selectedDetail;
    private string? search;
    private string? errorMessage;
    private string? successMessage;
    private int pageNumber = 1;
    private const int PageSize = 50;
    private string userName = "William Adrian Cambronero Acosta";
    private string userEmail = "wcambronero@itqscr.com";

    protected override async Task OnInitializedAsync()
    {
        userName = Configuration["AppSettings:SupportUserName"] ?? userName;
        userEmail = Configuration["AppSettings:SupportUserEmail"] ?? userEmail;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        errorMessage = null;
        successMessage = null;
        try { assigned = await AlertService.GetAssignedAlertsAsync(userEmail, pageNumber, PageSize, search); }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task CloseAsync(long id)
    {
        await AlertService.CloseAlertAsync(id, userName, userEmail, "Cliente Notificado-Monitoreo | Cierre desde ITQS SOC");
        successMessage = "Alerta enviada a cierre correctamente.";
        selectedDetail = null;
        await LoadAsync();
    }

    private async Task ViewDetailAsync(long id) => selectedDetail = await AlertService.GetAlertDetailAsync(id);
    private void CloseDetail() => selectedDetail = null;
    private async Task PreviousPage() { pageNumber = Math.Max(1, pageNumber - 1); await LoadAsync(); }
    private async Task NextPage() { pageNumber++; await LoadAsync(); }
    private static string GetSeverityClass(string? severity) => (severity ?? string.Empty).ToLowerInvariant() switch { "sev0" => "sev0", "sev1" => "sev1", "sev2" => "sev2", "sev3" => "sev3", _ => "sev4" };
}
