@using ITQS.SupportOperationsCenter.Components.Shared

<h1>Dashboard</h1>

<div class="cloud-divider"></div>

<div class="kpi-row">
    <KpiCard Title="Total asignadas"
             Icon="👤"
             CssClass="blue"
             Value="180"
             Label="Asignadas" />

    <KpiCard Title="Backup asignadas"
             Icon="💾"
             CssClass="purple"
             Value="45"
             Label="Backup" />

    <KpiCard Title="Management asignadas"
             Icon="⚙"
             CssClass="orange"
             Value="135"
             Label="Management" />

    <KpiCard Title="Pendientes"
             Icon="⚠"
             CssClass="red"
             Value="170"
             Label="Pendientes" />

    <KpiCard Title="Resueltas"
             Icon="✓"
             CssClass="green"
             Value="10"
             Label="Resueltas" />
</div>

<div class="cloud-divider"></div>

<div class="d-flex justify-content-between align-items-center mb-3">

    <h3 class="mb-0">Alerts</h3>

    <div>

        <button class="btn @(SelectedAlertType == "Management" ? "btn-primary" : "btn-outline-primary") btn-sm me-2"
                @onclick='() => ChangeAlertType("Management")'>
            Management Alerts
        </button>

        <button class="btn @(SelectedAlertType == "Backup" ? "btn-primary" : "btn-outline-primary") btn-sm"
                @onclick='() => ChangeAlertType("Backup")'>
            Backup Alerts
        </button>

    </div>

</div>

<h5 class="mb-3">@SelectedAlertType Alerts</h5>

<div class="table-responsive">

    <table class="table table-hover table-striped align-middle">

        <thead class="table-light">

            <tr>
                <th style="width:18%">Cliente</th>
                <th style="width:25%">Alerta</th>
                <th style="width:10%">Severidad</th>
                <th style="width:12%">Tipo</th>
                <th style="width:18%">Recurso</th>
                <th class="text-center" style="width:7%">Eventos</th>
                <th class="text-center" style="width:10%">Acción</th>
            </tr>

        </thead>

        <tbody>

            <tr>

                <td>Cliente Demo</td>
                <td>CPU mayor al 95%</td>

                <td>
                    <span class="badge bg-danger">
                        Critical
                    </span>
                </td>

                <td>@SelectedAlertType</td>

                <td>Servidor01</td>

                <td class="text-center">
                    <strong>10</strong>
                </td>

                <td class="text-center">

                    <button class="btn btn-primary btn-sm">
                        Asignarme
                    </button>

                </td>

            </tr>

        </tbody>

    </table>

</div>

@code {

    [Parameter]
    public string UserEmail { get; set; } = string.Empty;

    private string SelectedAlertType = "Management";

    private void ChangeAlertType(string type)
    {
        SelectedAlertType = type;
    }

}