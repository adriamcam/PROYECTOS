@using ITQS.SupportOperationsCenter.Components.Shared
@using ITQS.SupportOperationsCenter.Models.Dashboard
@using ITQS.SupportOperationsCenter.Services.Interfaces
@inject IAssignedAlertsDashboardService DashboardService

<h1>Dashboard</h1>

<div class="cloud-divider"></div>

<div class="kpi-row">
    <KpiCard Title="Alertas activas"
             Icon="🚨"
             CssClass="red"
           Value="@Dashboard.TotalAlerts"
             Label="Activas" />

    <KpiCard Title="Management"
             Icon="⚙"
             CssClass="orange"
            Value="@Dashboard.ManagementAlerts"
             Label="Activas" />

    <KpiCard Title="Backup"
             Icon="💾"
             CssClass="purple"
             Value="@Dashboard.BackupAlerts"
             Label="Activas" />

    <KpiCard Title="Sin asignar"
             Icon="📋"
             CssClass="blue"
             Value="@Dashboard.UnassignedAlerts"
             Label="Pendientes" />

    <KpiCard Title="Críticas"
             Icon="🔥"
             CssClass="red"
             Value="@Dashboard.CriticalAlerts"
             Label="Sev0 / Sev1" />

    <KpiCard Title="Nuevas hoy"
             Icon="📈"
             CssClass="green"
             Value="@Dashboard.NewToday"
             Label="Hoy" />
</div>

<div class="cloud-divider"></div>

<div class="dashboard-alerts-panel">

    <div class="dashboard-alerts-header">
        <h3>Alerts</h3>

        <div class="alert-type-actions">
            <button type="button"
                    class="alert-type-btn @(SelectedAlertType == "Management" ? "active" : "")"
                    @onclick='async () => await ChangeAlertType("Management")'>
                ⚙ Management Alerts
            </button>

            <button type="button"
                    class="alert-type-btn @(SelectedAlertType == "Backup" ? "active" : "")"
                    @onclick='async () => await ChangeAlertType("Backup")'>
                💾 Backup Alerts
            </button>
        </div>
    </div>

    <div class="cloud-divider"></div>

    <div class="alerts-toolbar">
        <input class="alerts-search"
               placeholder="Buscar cliente, alerta o recurso..."
               @bind="SearchText"
               @bind:event="oninput" />

        <button type="button" class="search-btn" @onclick="SearchAsync">
            Buscar
        </button>

        <select class="page-size-select" @bind="PageSize" @bind:after="PageSizeChangedAsync">
            <option value="25">25</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>
    </div>

    <h4 class="alerts-section-title">
        @(SelectedAlertType == "Management" ? "⚙ Management Alerts" : "💾 Backup Alerts")
    </h4>

    @if (IsLoading)
    {
        <p>Cargando alertas...</p>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }
    else
    {
        <div class="table-responsive w-100">
            <table class="table table-hover align-middle dashboard-alerts-table">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Alerta</th>
                        <th>Severidad</th>
                        <th>Tipo</th>
                        <th>Recurso</th>
                        <th class="text-center">Eventos</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Alerts.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center">
                                No hay alertas disponibles.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var alert in Alerts)
                        {
                            <tr>
                                <td>@alert.ClientName</td>
                                <td>@alert.AlertName</td>
                                <td>
                                    <span class="severity-badge @GetSeverityClass(alert.Severity)">
                                        @alert.Severity
                                    </span>
                                </td>
                                <td>@alert.AlertType</td>
                                <td>@alert.ResourceName</td>
                                <td class="text-center"><strong>@alert.Events</strong></td>
                                <td class="text-center">
                                    <button type="button"
                                            class="assign-btn"
                                            @onclick="async () => await AssignAlert(alert)">
                                        👤 Asignarme
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-bar">
            <div>
                Mostrando página <strong>@PageNumber</strong> de <strong>@TotalPages</strong>
                — Total: <strong>@TotalCount</strong>
            </div>

            <div class="pagination-actions">
                <button type="button"
                        class="page-btn"
                        disabled="@(PageNumber <= 1)"
                        @onclick="PreviousPageAsync">
                    ◀ Anterior
                </button>

                <button type="button"
                        class="page-btn"
                        disabled="@(PageNumber >= TotalPages)"
                        @onclick="NextPageAsync">
                    Siguiente ▶
                </button>
            </div>
        </div>
    }
</div>

<style>
    .dashboard-alerts-panel {
        background: #ffffff;
        border: 1px solid #dbe4f0;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
        width: 100%;
    }

    .dashboard-alerts-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .dashboard-alerts-header h3 {
        margin: 0;
        font-size: 24px;
        font-weight: 800;
        color: #061634;
    }

    .alert-type-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .alert-type-btn {
        border: 1px solid #bcd0ee;
        background: #ffffff;
        color: #061634;
        border-radius: 10px;
        padding: 12px 24px;
        font-weight: 800;
        font-size: 15px;
        min-width: 190px;
        transition: all .15s ease-in-out;
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.04);
    }

    .alert-type-btn:hover {
        transform: translateY(-1px);
        border-color: #1f66ff;
        color: #1f66ff;
    }

    .alert-type-btn.active {
        background: linear-gradient(135deg, #1262ff, #4c6fff);
        color: #ffffff;
        border-color: #1262ff;
        box-shadow: 0 10px 24px rgba(18, 98, 255, 0.28);
    }

    .alerts-toolbar {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 16px;
    }

    .alerts-search {
        min-width: 320px;
        flex: 1;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: 10px 14px;
        font-weight: 600;
    }

    .search-btn,
    .page-btn,
    .page-size-select {
        border: 1px solid #bcd0ee;
        background: #ffffff;
        color: #061634;
        border-radius: 10px;
        padding: 10px 14px;
        font-weight: 800;
    }

    .alerts-section-title {
        margin: 0 0 16px 0;
        color: #061634;
        font-weight: 800;
    }

    .dashboard-alerts-table {
        border: 1px solid #dbe4f0;
        border-radius: 12px;
        overflow: hidden;
        background: #ffffff;
        width: 100%;
    }

    .dashboard-alerts-table thead th {
        background: #f6f9fd;
        color: #061634;
        font-weight: 800;
        padding: 14px 16px;
        border-bottom: 1px solid #dbe4f0;
        white-space: nowrap;
    }

    .dashboard-alerts-table tbody td {
        padding: 14px 16px;
        border-bottom: 1px solid #eef2f7;
        vertical-align: middle;
    }

    .severity-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 800;
    }

    .severity-badge.critical {
        color: #dc2626;
        background: #fee2e2;
    }

    .severity-badge.warning {
        color: #d97706;
        background: #fef3c7;
    }

    .severity-badge.info {
        color: #2563eb;
        background: #dbeafe;
    }

    .severity-badge.normal {
        color: #475569;
        background: #e2e8f0;
    }

    .severity-badge::before {
        content: "●";
        font-size: 10px;
    }

    .assign-btn {
        border: 0;
        background: linear-gradient(135deg, #1262ff, #4c6fff);
        color: #ffffff;
        border-radius: 9px;
        padding: 9px 16px;
        font-weight: 800;
        font-size: 14px;
        box-shadow: 0 8px 18px rgba(18, 98, 255, 0.25);
        transition: all .15s ease-in-out;
    }

    .assign-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 12px 24px rgba(18, 98, 255, 0.32);
    }

    .pagination-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-top: 16px;
        font-weight: 700;
        color: #334155;
    }

    .pagination-actions {
        display: flex;
        gap: 10px;
    }

    .page-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>

@code {
    [Parameter]
    public string UserEmail { get; set; } = string.Empty;

    [Parameter]
    public string UserName { get; set; } = string.Empty;

    private AssignedAlertsDashboardModel Dashboard = new();

private string SelectedAlertType = "Management";
private List<DashboardAlertItemModel> Alerts = new();

    private bool IsLoading = false;
    private string ErrorMessage = string.Empty;

    private int PageNumber = 1;
    private int PageSize = 25;
    private string SearchText = string.Empty;
    private int TotalCount = 0;
    private int TotalPages = 0;
	

    protected override async Task OnInitializedAsync()
    {
        await LoadAlertsAsync();
    }

    private async Task ChangeAlertType(string type)
    {
        SelectedAlertType = type;
        PageNumber = 1;
        await LoadAlertsAsync();
    }

    private async Task SearchAsync()
    {
        PageNumber = 1;
        await LoadAlertsAsync();
    }

    private async Task PageSizeChangedAsync()
    {
        PageNumber = 1;
        await LoadAlertsAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (PageNumber > 1)
        {
            PageNumber--;
            await LoadAlertsAsync();
        }
    }

    private async Task NextPageAsync()
    {
        if (PageNumber < TotalPages)
        {
            PageNumber++;
            await LoadAlertsAsync();
        }
    }

   private async Task LoadAlertsAsync()
{
    IsLoading = true;
    ErrorMessage = string.Empty;

    try
    {
	var dashboardResult = await DashboardService.GetDashboardAsync(UserEmail);

if (dashboardResult.Success && dashboardResult.Data is not null)
{
    Dashboard = dashboardResult.Data;
}
        var result = SelectedAlertType == "Backup"
            ? await DashboardService.GetBackupAlertsAsync(PageNumber, PageSize, SearchText)
            : await DashboardService.GetManagementAlertsAsync(PageNumber, PageSize, SearchText);

            Alerts = result.Items;
            TotalCount = result.TotalCount;
            TotalPages = result.TotalPages;
            PageNumber = result.PageNumber;
            PageSize = result.PageSize;
        }
        catch
        {
            ErrorMessage = "No fue posible cargar las alertas.";
            Alerts = new();
            TotalCount = 0;
            TotalPages = 0;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task AssignAlert(DashboardAlertItemModel alert)
    {
        var assignedName = string.IsNullOrWhiteSpace(UserName)
            ? UserEmail
            : UserName;

        if (alert.SourceType == "Backup")
        {
            await DashboardService.AssignBackupAlertAsync(alert.Id, assignedName, UserEmail);
        }
        else
        {
            await DashboardService.AssignManagementAlertAsync(alert.Id, assignedName, UserEmail);
        }

        await LoadAlertsAsync();
    }

    private string GetSeverityClass(string severity)
    {
        return severity?.ToLowerInvariant() switch
        {
            "critical" => "critical",
            "error" => "critical",
            "high" => "critical",
            "warning" => "warning",
            "medium" => "warning",
            "informational" => "info",
            "info" => "info",
            "sev0" => "critical",
            "sev1" => "critical",
            "sev2" => "warning",
            "sev3" => "info",
            _ => "normal"
        };
    }
}