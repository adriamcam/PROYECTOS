@using ITQS.SupportOperationsCenter.Models.Dashboard
@using ITQS.SupportOperationsCenter.Services.Interfaces
@using ITQS.SupportOperationsCenter.Components.Shared
@inject IAlertService AlertService

<h1>Monitoreo de Alertas</h1>
<p>Monitoreo centralizado de alertas, asignaciones y operación.</p>

<div class="cloud-divider"></div>

@if (IsLoading)
{
    <p>Cargando KPI de alertas...</p>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="soc-alert-error">
        @ErrorMessage
    </div>
}
else
{
    <div class="kpi-row">
        <KpiCard Title="Alertas Totales" Icon="🔔" CssClass="blue" Value="@Dashboard.TotalAlerts" Label="Activas" />
        <KpiCard Title="Backup Alerts" Icon="💾" CssClass="purple" Value="@Dashboard.BackupAlerts" Label="Activas" />
        <KpiCard Title="Management Alerts" Icon="⚙" CssClass="orange" Value="@Dashboard.ManagementAlerts" Label="Activas" />
        <KpiCard Title="Asignadas a mí" Icon="👤" CssClass="green" Value="@Dashboard.AssignedToMe" Label="Pendientes" />
        <KpiCard Title="Admin / Manager View" Icon="⚠" CssClass="red" Value="@Dashboard.Unassigned" Label="Pendientes" />
        <KpiCard Title="Resueltas hoy" Icon="✓" CssClass="purple" Value="@Dashboard.ResolvedToday" Label="Cerradas" />
    </div>

    <div class="cloud-divider"></div>

    <div class="soc-insights-grid">
        <div class="soc-insight-card">
            <div class="soc-insight-header">
                <h3>Alertas por severidad</h3>
                <span>Distribución actual</span>
            </div>

            <div class="severity-list">
                @if (Dashboard.Severities.Any())
                {
                    @foreach (var item in Dashboard.Severities)
                    {
                        <div class="severity-row">
                            <span class="severity-dot @GetSeverityCss(item.Severity)"></span>
                            <span>@item.Severity</span>
                            <strong>@item.Total</strong>
                        </div>
                    }
                }
                else
                {
                    <div class="severity-row">
                        <span class="severity-dot low"></span>
                        <span>Sin datos aún</span>
                        <strong>0</strong>
                    </div>
                }
            </div>
        </div>

        <div class="soc-insight-card">
            <div class="soc-insight-header">
                <h3>Top clientes</h3>
                <span>Mayor volumen de alertas</span>
            </div>

            <div class="top-client-list">
                @if (Dashboard.TopClients.Any())
                {
                    @foreach (var item in Dashboard.TopClients)
                    {
                        <div class="top-client-row">
                            <span>@item.ClientName</span>
                            <strong>@item.Total</strong>
                        </div>
                    }
                }
                else
                {
                    <div class="top-client-row">
                        <span>Sin datos aún</span>
                        <strong>0</strong>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .soc-insights-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
        margin-top: 24px;
    }

    .soc-insight-card {
        background: #ffffff;
        border: 1px solid #dbe4f0;
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
        min-height: 240px;
    }

    .soc-insight-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
    }

    .soc-insight-header h3 {
        margin: 0;
        color: #061634;
        font-size: 20px;
        font-weight: 800;
    }

    .soc-insight-header span {
        color: #64748b;
        font-size: 13px;
        font-weight: 700;
    }

    .severity-list,
    .top-client-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .severity-row,
    .top-client-row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-weight: 700;
    }

    .top-client-row {
        grid-template-columns: 1fr auto;
    }

    .severity-dot {
        width: 12px;
        height: 12px;
        border-radius: 999px;
        display: inline-block;
    }

    .severity-dot.critical {
        background: #dc2626;
    }

    .severity-dot.high {
        background: #f97316;
    }

    .severity-dot.medium {
        background: #eab308;
    }

    .severity-dot.low {
        background: #22c55e;
    }

    @@media (max-width: 1100px) {
        .soc-insights-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Parameter]
    public string UserEmail { get; set; } = "wcambronero@itqscr.com";

    private AlertDashboardModel Dashboard { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var result = await AlertService.GetDashboardAsync(UserEmail);

        if (result.Success && result.Data is not null)
        {
            Dashboard = result.Data;
        }
        else
        {
            ErrorMessage = result.ErrorMessage ?? "No fue posible cargar la información.";
        }

        IsLoading = false;
    }

    private string GetSeverityCss(string severity)
    {
        return severity switch
        {
            "Critical / Sev0" => "critical",
            "High / Sev1" => "high",
            "Medium / Sev2" => "medium",
            _ => "low"
        };
    }
}