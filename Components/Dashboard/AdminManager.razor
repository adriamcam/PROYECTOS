@using System.Security.Claims
@using System.Text
@using Microsoft.AspNetCore.Components.Authorization
@using ITQS.SupportOperationsCenter.Models.Dashboard
@using ITQS.SupportOperationsCenter.Services.Interfaces

@inject IAdminManagerService AdminService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager


@if (!HasAdminAccess)
{
    <section class="admin-access-denied">

        <div class="admin-access-icon">
            🔒
        </div>

        <h1>Acceso denegado</h1>

        <p>
            No tienes permisos para ingresar a este módulo.
        </p>

    </section>

    return;
}

<button class="primary-btn config-button" type="button" @onclick="OpenUserConfigAsync">⚙ Configuración</button>

<div class="cloud-divider"></div>

@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="@MessageCss">@Message</div>
}

<div class="admin-kpis">
    <div class="kpi"><span>🚨</span><b>@Dashboard.TotalAssignedGroups</b><small>Total asignadas</small></div>
    <div class="kpi"><span>📊</span><b>@Dashboard.TotalAssignedEvents</b><small>Eventos asignados</small></div>
    <div class="kpi"><span>🟢</span><b>@Dashboard.ActiveGroups</b><small>Activas</small></div>
    <div class="kpi"><span>🟡</span><b>@Dashboard.InProgressGroups</b><small>In Progress</small></div>
    <div class="kpi"><span>✅</span><b>@Dashboard.ClosedToday</b><small>Cerradas hoy</small></div>
    <div class="kpi"><span>👥</span><b>@Dashboard.UsersWithAlerts</b><small>Usuarios con carga</small></div>
</div>

<div class="admin-filters">
    <input class="admin-input search" placeholder="Buscar cliente, alerta, recurso o usuario..." @bind="SearchText" @bind:event="oninput" />
    <select class="admin-input" @bind="SelectedClient"><option value="">Todos los clientes</option>@foreach (var client in Clients){<option value="@client">@client</option>}</select>
    <select class="admin-input" @bind="SelectedAssignedEmail"><option value="">Todos los usuarios</option>@foreach (var user in Users){<option value="@user.UserEmail">@user.DisplayName</option>}</select>
    <select class="admin-input" @bind="SelectedSourceType"><option value="All">Todos los tipos</option><option value="Management">Management</option><option value="Backup">Backup</option></select>
    <select class="admin-input" @bind="SelectedSeverity"><option value="All">Todas las severidades</option>@foreach (var sev in SeverityOptions){<option value="@sev">@sev</option>}</select>
    <select class="admin-input" @bind="SelectedStatus"><option value="All">Todos los estados</option><option value="Activa">Activa</option><option value="InProgress">In Progress</option></select>
    <button class="secondary-btn" type="button" @onclick="ClearFiltersAsync">Limpiar</button>
    <button class="primary-btn" type="button" @onclick="SearchAsync">Buscar</button>
</div>

<div class="admin-grid">
    <section class="admin-card">
        <div class="admin-card-header">
            <div><h3>Todas las alertas asignadas</h3><small>Última actualización: @LastRefreshAt.ToString("HH:mm:ss") · @Alerts.TotalCount grupos</small></div>
            <button class="secondary-btn" type="button" @onclick="LoadAllAsync">🔄 Actualizar</button>
        </div>

        <div class="reassign-row">
            <select class="admin-input" @bind="ReassignToEmail"><option value="">Seleccionar usuario para reasignar</option>@foreach (var user in Users){<option value="@user.UserEmail">@user.DisplayName (@user.UserEmail)</option>}</select>
            <input class="admin-input" placeholder="Comentario de reasignación..." @bind="ReassignComment" />
            <button class="primary-btn" type="button" disabled="@(!CanReassign)" @onclick="ReassignSelectedAsync">Reasignar (@SelectedCount)</button>
        </div>

        <div class="table-wrap">
            <table class="admin-table">
                <thead><tr><th><input type="checkbox" checked="@AllCurrentSelected" @onchange="ToggleAllCurrentPage" /></th><th>Cliente</th><th>Tipo</th><th>Severidad</th><th>Alerta</th><th>Recurso</th><th>Eventos</th><th>Usuario asignado</th><th>Estado</th><th>Último evento</th></tr></thead>
                <tbody>
                    @if (IsLoading){<tr><td colspan="10" class="empty">Cargando...</td></tr>}
                    else if (Alerts.Items.Count == 0){<tr><td colspan="10" class="empty">No se encontraron alertas asignadas.</td></tr>}
                    else
                    {
                        @foreach (var alert in Alerts.Items)
                        {
                            <tr>
                                <td><input type="checkbox" @bind="alert.Selected" /></td>
                                <td>@alert.ClientName</td>
                                <td><span class="type-badge @alert.SourceType.ToLowerInvariant()">@alert.SourceType</span></td>
                                <td><span class="severity @GetSeverityClass(alert.Severity)">@alert.Severity</span></td>
                                <td>@alert.AlertName</td>
                                <td>@alert.ResourceName</td>
                                <td><strong>@alert.Events</strong></td>
                                <td><strong>@alert.AssignedTo</strong><small>@alert.AssignedEmail</small></td>
                                <td><span class="status @GetStatusClass(alert.AlertStatus)">@GetStatusText(alert.AlertStatus)</span></td>
                                <td>@FormatDate(alert.LastEventAt)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination">
            <span>Página <b>@PageNumber</b> de <b>@Math.Max(Alerts.TotalPages, 1)</b> · Total <b>@Alerts.TotalCount</b></span>
            <div class="pagination-actions">
                <button class="secondary-btn" disabled="@(PageNumber <= 1)" @onclick="FirstPageAsync">1</button>
                <button class="secondary-btn" disabled="@(PageNumber <= 1)" @onclick="PreviousPageAsync">◀</button>
                <select class="admin-input page-size" @bind="PageSize" @bind:after="PageSizeChangedAsync"><option value="25">25 / página</option><option value="50">50 / página</option><option value="100">100 / página</option></select>
                <button class="secondary-btn" disabled="@(PageNumber >= Alerts.TotalPages)" @onclick="NextPageAsync">▶</button>
                <button class="secondary-btn" disabled="@(PageNumber >= Alerts.TotalPages)" @onclick="LastPageAsync">@Math.Max(Alerts.TotalPages, 1)</button>
            </div>
        </div>
    </section>

    <aside class="side">
        <section class="admin-card">
            <h3>Cerrar por severidad</h3><p>Solo cierra alertas sin usuario asignado y no In Progress.</p>
            @foreach (var sev in SeveritySummary)
            {
                <div class="severity-close"><div><b>@sev.SourceType · @sev.Severity</b><small>@sev.CloseableGroups grupos · @sev.CloseableEvents eventos</small></div><button class="danger-btn" @onclick="async () => await CloseSeverityAsync(sev)">Cerrar</button></div>
            }
        </section>

        <section class="admin-card">
            <h3>Carga por ingeniero</h3>
            @foreach (var user in Workload)
            {
                var pct = MaxUserEvents == 0 ? 0 : Math.Min(100, (int)Math.Round(user.TotalEvents * 100.0 / MaxUserEvents));
                <div class="workload"><div><b>@user.DisplayName</b><span>@user.TotalEvents eventos</span></div><div class="bar"><i style="width:@pct%"></i></div><small>Activas: @user.ActiveGroups · In Progress: @user.InProgressGroups · Cerradas hoy: @user.ClosedToday</small></div>
            }
        </section>
    </aside>
</div>

<section class="admin-card history">
    <div class="admin-card-header"><div><h3>Historial de alertas cerradas</h3><small>@ClosedHistory.TotalCount cierres encontrados</small></div><button class="primary-btn" type="button" @onclick="ExportHistoryExcelAsync">⬇ Descargar Excel</button></div>
    <div class="history-filters">
        <input class="admin-input" placeholder="Buscar historial..." @bind="HistorySearchText" @bind:event="oninput" />
        <select class="admin-input" @bind="HistoryKpiType"><option value="All">Todos los tipos</option><option value="Management">Management</option><option value="Backup">Backup</option></select>
        <select class="admin-input" @bind="HistoryUserEmail"><option value="">Todos los usuarios</option>@foreach (var user in Users){<option value="@user.UserEmail">@user.DisplayName</option>}</select>
        <button class="secondary-btn" type="button" @onclick="ClearHistoryFiltersAsync">Limpiar</button>
        <button class="primary-btn" type="button" @onclick="SearchHistoryAsync">Buscar</button>
    </div>
    <div class="table-wrap">
        <table class="admin-table">
            <thead><tr><th>Fecha</th><th>Usuario</th><th>Tipo</th><th>Cliente</th><th>Alerta</th><th>Recurso</th><th>Comentario</th></tr></thead>
            <tbody>
                @if (ClosedHistory.Items.Count == 0){<tr><td colspan="7" class="empty">No hay historial de cierres.</td></tr>}
                else
                {
                    @foreach (var item in ClosedHistory.Items)
                    {
                        <tr><td>@FormatDate(item.ClosedAt)</td><td><strong>@item.ClosedBy</strong><small>@item.UserEmail</small></td><td>@item.KPIType</td><td>@item.ClientName</td><td>@item.AlertName</td><td>@item.ResourceName</td><td>@item.Comment</td></tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="pagination"><span>Página <b>@HistoryPageNumber</b> de <b>@Math.Max(ClosedHistory.TotalPages, 1)</b> · Total <b>@ClosedHistory.TotalCount</b></span><div class="pagination-actions"><button class="secondary-btn" disabled="@(HistoryPageNumber <= 1)" @onclick="FirstHistoryPageAsync">1</button><button class="secondary-btn" disabled="@(HistoryPageNumber <= 1)" @onclick="PreviousHistoryPageAsync">◀</button><select class="admin-input page-size" @bind="HistoryPageSize" @bind:after="HistoryPageSizeChangedAsync"><option value="25">25 / página</option><option value="50">50 / página</option><option value="100">100 / página</option></select><button class="secondary-btn" disabled="@(HistoryPageNumber >= ClosedHistory.TotalPages)" @onclick="NextHistoryPageAsync">▶</button><button class="secondary-btn" disabled="@(HistoryPageNumber >= ClosedHistory.TotalPages)" @onclick="LastHistoryPageAsync">@Math.Max(ClosedHistory.TotalPages, 1)</button></div></div>
</section>

@if (ShowUserConfigModal)
{
    <div class="config-modal-backdrop">
        <div class="config-modal">
            <div class="config-modal-header"><div><h3>Configuración de usuarios</h3><small>Administración de acceso al módulo Admin / Manager View desde dbo.ITQS_AppUsers.</small></div><button class="secondary-btn" type="button" @onclick="CloseUserConfig">Cerrar</button></div>
            <div class="table-wrap">
                <table class="admin-table config-table">
                    <thead><tr><th>Usuario</th><th>Correo</th><th>BaseRole</th><th>EffectiveRole</th><th>Temp Admin</th><th>Activo</th><th>Acceso Admin</th><th>Notas</th><th>Acción</th></tr></thead>
                    <tbody>
                        @foreach (var appUser in UserMaintenance)
                        {
                            <tr>
                                <td><input class="admin-input" @bind="appUser.DisplayName" /></td>
                                <td>@appUser.UserEmail</td>
                                <td><select class="admin-input" @bind="appUser.BaseRole"><option value="Admin">Admin</option><option value="User">User</option></select></td>
                                <td><select class="admin-input" @bind="appUser.EffectiveRole"><option value="Admin">Admin</option><option value="User">User</option></select></td>
                                <td><input type="checkbox" @bind="appUser.IsTempAdmin" /></td>
                                <td><input type="checkbox" @bind="appUser.IsActive" /></td>
                                <td><span class="status @(appUser.CanAccessAdminManager ? "active" : "closed")">@(appUser.CanAccessAdminManager ? "Permitido" : "Bloqueado")</span></td>
                                <td><input class="admin-input" @bind="appUser.Notes" /></td>
                                <td><button class="primary-btn" type="button" @onclick="async () => await SaveUserConfigAsync(appUser)">Guardar</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="config-help">Para permitir acceso al módulo, el usuario debe estar activo y tener BaseRole o EffectiveRole igual a Admin.</p>
        </div>
    </div>
}

