</style>

@code {
    private bool HasAdminAccess;
    private bool IsLoading;
    private bool ShowUserConfigModal;
    private string Message = string.Empty;
    private string MessageCss = "admin-message ok";
    private string UserEmail = string.Empty;
    private string UserName = string.Empty;

    private AdminManagerDashboardModel Dashboard = new();
    private AdminManagerAlertPagedResultModel Alerts = new();
    private AdminManagerClosedHistoryPagedResultModel ClosedHistory = new();

    private List<string> Clients = new();
    private List<AdminManagerAppUserModel> Users = new();
    private List<AdminManagerEngineerWorkloadModel> Workload = new();
    private List<AdminManagerSeveritySummaryModel> SeveritySummary = new();
    private List<AdminManagerUserMaintenanceModel> UserMaintenance = new();

    private int PageNumber = 1;
    private int PageSize = 50;
    private string SearchText = string.Empty;
    private string SelectedClient = string.Empty;
    private string SelectedAssignedEmail = string.Empty;
    private string SelectedSourceType = "All";
    private string SelectedSeverity = "All";
    private string SelectedStatus = "All";

    private int HistoryPageNumber = 1;
    private int HistoryPageSize = 50;
    private string HistorySearchText = string.Empty;
    private string HistoryKpiType = "All";
    private string HistoryUserEmail = string.Empty;

    private string ReassignToEmail = string.Empty;
    private string ReassignComment = string.Empty;
    private DateTime LastRefreshAt = DateTime.Now;

    private IEnumerable<string> SeverityOptions => SeveritySummary.Select(x => x.Severity).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().OrderBy(x => x).ToList();
    private int SelectedCount => Alerts.Items.Count(x => x.Selected);
    private bool CanReassign => SelectedCount > 0 && !string.IsNullOrWhiteSpace(ReassignToEmail);
    private bool AllCurrentSelected => Alerts.Items.Count > 0 && Alerts.Items.All(x => x.Selected);
    private int MaxUserEvents => Workload.Count == 0 ? 0 : Workload.Max(x => x.TotalEvents);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        UserEmail = user.FindFirst(ClaimTypes.Email)?.Value ?? user.FindFirst("preferred_username")?.Value ?? user.Identity?.Name ?? string.Empty;
        UserName = user.FindFirst("name")?.Value ?? user.Identity?.Name ?? UserEmail;

        HasAdminAccess = await AdminService.CanAccessAdminManagerAsync(UserEmail);

        if (!HasAdminAccess)
        {
            return;
        }

        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        IsLoading = true;
        try
        {
            Dashboard = await AdminService.GetDashboardAsync();
            Clients = await AdminService.GetClientsAsync();
            Users = await AdminService.GetUsersAsync();
            Workload = await AdminService.GetEngineerWorkloadAsync();
            SeveritySummary = await AdminService.GetSeveritySummaryAsync();
            await LoadAlertsAsync();
            await LoadHistoryAsync();
            LastRefreshAt = DateTime.Now;
        }
        catch (Exception ex)
        {
            SetError($"No fue posible cargar Admin / Manager View. {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadAlertsAsync() => Alerts = await AdminService.GetAlertsAsync(PageNumber, PageSize, SearchText, SelectedClient, SelectedAssignedEmail, SelectedSourceType, SelectedSeverity, SelectedStatus);
    private async Task LoadHistoryAsync() => ClosedHistory = await AdminService.GetClosedHistoryPagedAsync(HistoryPageNumber, HistoryPageSize, HistorySearchText, HistoryKpiType, HistoryUserEmail);

    private async Task SearchAsync(){ PageNumber = 1; await LoadAlertsAsync(); }
    private async Task ClearFiltersAsync(){ SearchText = string.Empty; SelectedClient = string.Empty; SelectedAssignedEmail = string.Empty; SelectedSourceType = "All"; SelectedSeverity = "All"; SelectedStatus = "All"; PageNumber = 1; await LoadAlertsAsync(); }
    private async Task PageSizeChangedAsync(){ PageNumber = 1; await LoadAlertsAsync(); }
    private async Task FirstPageAsync(){ PageNumber = 1; await LoadAlertsAsync(); }
    private async Task PreviousPageAsync(){ if (PageNumber > 1){ PageNumber--; await LoadAlertsAsync(); } }
    private async Task NextPageAsync(){ if (PageNumber < Alerts.TotalPages){ PageNumber++; await LoadAlertsAsync(); } }
    private async Task LastPageAsync(){ PageNumber = Math.Max(Alerts.TotalPages, 1); await LoadAlertsAsync(); }

    private async Task SearchHistoryAsync(){ HistoryPageNumber = 1; await LoadHistoryAsync(); }
    private async Task ClearHistoryFiltersAsync(){ HistorySearchText = string.Empty; HistoryKpiType = "All"; HistoryUserEmail = string.Empty; HistoryPageNumber = 1; await LoadHistoryAsync(); }
    private async Task HistoryPageSizeChangedAsync(){ HistoryPageNumber = 1; await LoadHistoryAsync(); }
    private async Task FirstHistoryPageAsync(){ HistoryPageNumber = 1; await LoadHistoryAsync(); }
    private async Task PreviousHistoryPageAsync(){ if (HistoryPageNumber > 1){ HistoryPageNumber--; await LoadHistoryAsync(); } }
    private async Task NextHistoryPageAsync(){ if (HistoryPageNumber < ClosedHistory.TotalPages){ HistoryPageNumber++; await LoadHistoryAsync(); } }
    private async Task LastHistoryPageAsync(){ HistoryPageNumber = Math.Max(ClosedHistory.TotalPages, 1); await LoadHistoryAsync(); }

    private void ToggleAllCurrentPage(ChangeEventArgs args)
    {
        var selected = args.Value is bool b && b;
        foreach (var alert in Alerts.Items) alert.Selected = selected;
    }

    private async Task ReassignSelectedAsync()
    {
        if (!CanReassign) return;

        var selectedUser = Users.FirstOrDefault(x => x.UserEmail.Equals(ReassignToEmail, StringComparison.OrdinalIgnoreCase));
        if (selectedUser is null){ SetError("Debe seleccionar un usuario válido."); return; }

        var selectedAlerts = Alerts.Items.Where(x => x.Selected).ToList();

        await AdminService.ReassignAlertsAsync(new AdminManagerReassignRequestModel
        {
            Alerts = selectedAlerts,
            NewAssignedTo = selectedUser.DisplayName,
            NewAssignedEmail = selectedUser.UserEmail,
            RequestedBy = UserName,
            RequestedByEmail = UserEmail,
            Comment = ReassignComment
        });

        OpenReassignmentEmail(selectedUser, selectedAlerts);
        SetOk($"Se reasignaron {selectedAlerts.Count} grupos a {selectedUser.DisplayName}.");
        ReassignToEmail = string.Empty;
        ReassignComment = string.Empty;
        await LoadAllAsync();
    }

    private async Task CloseSeverityAsync(AdminManagerSeveritySummaryModel severity)
    {
        await AdminService.CloseSeverityAsync(new AdminManagerCloseSeverityRequestModel
        {
            SourceType = severity.SourceType,
            Severity = severity.Severity,
            RequestedBy = UserName,
            RequestedByEmail = UserEmail,
            Comment = $"Cierre masivo de alertas {severity.SourceType} con severidad {severity.Severity}. Solo alertas sin asignar y no In Progress."
        });

        SetOk($"Se envió cierre masivo para {severity.SourceType} / {severity.Severity}.");
        await LoadAllAsync();
    }

    private async Task ExportHistoryExcelAsync()
    {
        var rows = await AdminService.GetClosedHistoryForExportAsync(HistorySearchText, HistoryKpiType, HistoryUserEmail);

        var csv = new StringBuilder();
        csv.AppendLine("Fecha,Usuario,Correo,Tipo,Cliente,Alerta,Recurso,Severidad,Comentario");

        foreach (var item in rows)
        {
            csv.AppendLine(string.Join(",",
                Csv(item.ClosedAt?.ToString("dd/MM/yyyy HH:mm") ?? ""),
                Csv(item.ClosedBy),
                Csv(item.UserEmail),
                Csv(item.KPIType),
                Csv(item.ClientName),
                Csv(item.AlertName),
                Csv(item.ResourceName),
                Csv(item.Severity),
                Csv(item.Comment)));
        }

        var bytes = Encoding.UTF8.GetPreamble().Concat(Encoding.UTF8.GetBytes(csv.ToString())).ToArray();
        var base64 = Convert.ToBase64String(bytes);
        NavigationManager.NavigateTo($"data:text/csv;base64,{base64}", forceLoad: true);
    }

    private static string Csv(string value)
    {
        value = value?.Replace("\"", "\"\"") ?? string.Empty;
        return $"\"{value}\"";
    }

    private async Task OpenUserConfigAsync()
    {
        UserMaintenance = await AdminService.GetUserMaintenanceAsync();
        ShowUserConfigModal = true;
    }

    private void CloseUserConfig() => ShowUserConfigModal = false;

    private async Task SaveUserConfigAsync(AdminManagerUserMaintenanceModel appUser)
    {
        await AdminService.SaveUserMaintenanceAsync(new AdminManagerUserSaveRequestModel
        {
            Id = appUser.Id,
            UserEmail = appUser.UserEmail,
            DisplayName = appUser.DisplayName,
            BaseRole = appUser.BaseRole,
            EffectiveRole = appUser.EffectiveRole,
            IsTempAdmin = appUser.IsTempAdmin,
            TempAdminStartAt = appUser.TempAdminStartAt,
            TempAdminEndAt = appUser.TempAdminEndAt,
            IsActive = appUser.IsActive,
            Notes = appUser.Notes,
            UpdatedBy = UserEmail
        });

        UserMaintenance = await AdminService.GetUserMaintenanceAsync();
        Users = await AdminService.GetUsersAsync();
        SetOk($"Usuario {appUser.DisplayName} actualizado correctamente.");
    }

    private void OpenReassignmentEmail(AdminManagerAppUserModel user, List<AdminManagerAlertItemModel> selectedAlerts)
    {
        if (selectedAlerts.Count == 0) return;

        var totalEvents = selectedAlerts.Sum(x => x.Events);
        var subject = $"Reasignación de alertas SOC | {selectedAlerts.Count} grupos | {totalEvents} eventos";
        var body = $"Hola {user.DisplayName},\\r\\n\\r\\nSe te han reasignado alertas desde Admin / Manager View.\\r\\n\\r\\nGrupos reasignados: {selectedAlerts.Count}\\r\\nEventos incluidos: {totalEvents}\\r\\nReasignado por: {UserName} ({UserEmail})\\r\\nFecha: {DateTime.Now:dd/MM/yyyy HH:mm}\\r\\n\\r\\nPor favor validar el panel Asignadas a mí para dar seguimiento.\\r\\n\\r\\nSaludos,\\r\\nSoporte ITQS";
        NavigationManager.NavigateTo($"mailto:{Uri.EscapeDataString(user.UserEmail)}?subject={Uri.EscapeDataString(subject)}&body={Uri.EscapeDataString(body)}", forceLoad: true);
    }

    private void SetOk(string message){ Message = message; MessageCss = "admin-message ok"; }
    private void SetError(string message){ Message = message; MessageCss = "admin-message error"; }

    private string GetSeverityClass(string severity) => severity?.ToLowerInvariant() switch
    {
        "critical" or "error" or "high" or "sev0" or "sev1" => "critical",
        "warning" or "medium" or "sev2" => "warning",
        "informational" or "info" or "sev3" => "info",
        _ => "normal"
    };

    private string GetStatusClass(string status) => status?.ToLowerInvariant() switch
    {
        "closed" => "closed",
        "inprogress" or "in progress" => "in-progress",
        _ => "active"
    };

    private string GetStatusText(string status) => status?.ToLowerInvariant() switch
    {
        "closed" => "Closed",
        "inprogress" or "in progress" => "In Progress",
        "activa" or "active" => "Activa",
        _ => string.IsNullOrWhiteSpace(status) ? "Activa" : status
    };

    private string FormatDate(DateTime? value) => value.HasValue ? value.Value.ToString("dd/MM/yyyy HH:mm") : "-";
}
