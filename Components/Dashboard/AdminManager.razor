6px 10px;border-radius:999px;font-size:12px;font-weight:900}.management{color:#2563eb;background:#dbeafe}.backup{color:#7c3aed;background:#ede9fe}.critical{color:#dc2626;background:#fee2e2}.warning{color:#d97706;background:#fef3c7}.info{color:#2563eb;background:#dbeafe}.normal{color:#475569;background:#e2e8f0}.active{color:#15803d;background:#dcfce7}.in-progress{color:#d97706;background:#fef3c7}.closed{color:#991b1b;background:#fee2e2}.pagination{display:flex;justify-content:space-between;align-items:center;margin-top:14px;gap:12px}.pagination-actions{display:flex;gap:8px;align-items:center}.page-size{width:140px;display:inline-block}.severity-close{display:flex;justify-content:space-between;gap:10px;padding:12px 0;border-top:1px solid #eef2f7}.severity-close small{display:block}.workload{padding:12px 0;border-top:1px solid #eef2f7}.workload div:first-child{display:flex;justify-content:space-between}.bar{height:9px;background:#e2e8f0;border-radius:999px;overflow:hidden;margin:8px 0}.bar i{display:block;height:100%;background:#2563eb}.history{margin-top:18px}.empty{text-align:center;color:#64748b;padding:18px}.admin-message{border-radius:12px;padding:12px 16px;font-weight:900;margin-bottom:16px}.admin-message.ok{color:#166534;background:#dcfce7;border:1px solid #bbf7d0}.admin-message.error{color:#991b1b;background:#fee2e2;border:1px solid #fecaca}.config-modal-backdrop{position:fixed;inset:0;background:rgba(2,6,23,.55);z-index:9999;display:flex;align-items:center;justify-content:center;padding:24px}.config-modal{width:min(1400px,96vw);max-height:90vh;overflow:auto;background:#fff;border-radius:18px;border:1px solid #dbe4f0;padding:20px;box-shadow:0 25px 80px rgba(2,6,23,.35)}.config-modal-header{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;margin-bottom:16px}.config-table{min-width:1200px}.config-help{color:#64748b;font-weight:700;margin-top:12px}@@media(max-width:1400px){.admin-kpis{grid-template-columns:repeat(3,1fr)}.admin-filters,.hi