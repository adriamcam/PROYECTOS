@using ITQS.SupportOperationsCenter.Components.Shared
@using System.Security.Claims
@using System.Text
@using Microsoft.AspNetCore.Components.Authorization
@using ITQS.SupportOperationsCenter.Components.Dialogs
@using ITQS.SupportOperationsCenter.Models.Dashboard
@using ITQS.SupportOperationsCenter.Services.Interfaces

@inject IAssignedAlertsDashboardService DashboardService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

@implements IDisposable

<div class="module-title-row">
    <div class="module-title">
    <h1>Asignadas a mí</h1>
    <OperationalInfoButton
    Title="Asignadas a mí"
    Description="Mostrar únicamente las alertas asignadas al usuario autenticado para seguimiento, actualización de comentarios, gestión operativa y cierre de incidentes."
    Tables="dbo.AlertsManagement, dbo.AlertasBackup, dbo.AlertUpdatesHistory, dbo.AzureAlertCloseQueue"
    Views="dbo.vw_MyAlerts, dbo.vw_MyAlertsSummary"
    Procedures="dbo.usp_GetAlertsByUser, dbo.usp_UpdateAlertComment, dbo.usp_CloseAlert"
    Integrations="Microsoft Graph, Azure SQL Database, Azure Monitor, Power Automate, Microsoft Outlook"
    Flow="Asignación de Alerta > Lista Personal > Actualización > Cierre > Historial"
    Kpis="Mis Alertas Activas, Vencen menor a 1 hora, Vencen menor a 24 horas, Vencidas, Cerradas Hoy, Comentarios Pendientes, Tiempo Promedio de Resolución, Última Ejecución"
    Version="Asignadas a mí v1.0" />
</div>

<p>Alertas asignadas al usuario conectado para seguimiento, comentarios y cierre.</p>
</div>

<div class="module-actions">
    <OperationalInfoButton
        Title="Asignadas a mí"
        Description="Gestión de alertas asignadas al ingeniero."
        Tables="dbo.AlertsManagement,dbo.AlertasBackup,dbo.AlertUpdatesHistory,dbo.AzureAlertCloseQueue"
        Views="dbo.vw_MyAlerts,dbo.vw_MyAlertsSummary"
        Procedures="dbo.usp_GetAlertsByUser,dbo.usp_UpdateAlertComment,dbo.usp_CloseAlert"
        Integrations="Microsoft Graph,Azure SQL Database,Azure Monitor,Power Automate"
        Flow="Asignación>Trabajo>Comentarios>Cierre>Historial"
        Kpis="Mis Alertas,Pendientes,Vencidas,Cerradas Hoy"
        Version="Asignadas a mí v1.0" />
</div>

</div>

<div class="cloud-divider"></div>

<div class="assigned-kpi-row">
    <div class="assigned-kpi-card red">
        <span>🚨</span>
        <div>
            <strong>@TotalCount</strong>
            <small>Total asignadas</small>
        </div>
    </div>

    <div class="assigned-kpi-card orange">
        <span>🔥</span>
        <div>
            <strong>@CriticalCount</strong>
            <small>Críticas</small>
        </div>
    </div>

    <div class="assigned-kpi-card blue">
        <span>⚙</span>
        <div>
            <strong>@ManagementCount</strong>
            <small>Management</small>
        </div>
    </div>

    <div class="assigned-kpi-card purple">
        <span>💾</span>
        <div>
            <strong>@BackupCount</strong>
            <small>Backup</small>
        </div>
    </div>
</div>

</div>

<div class="module-actions">
    <OperationalInfoButton
        Title="Asignadas a mí"
        Description="Gestión de alertas asignadas al ingeniero."
        Tables="dbo.AlertsManagement,dbo.AlertasBackup,dbo.AlertUpdatesHistory,dbo.AzureAlertCloseQueue"
        Views="dbo.vw_MyAlerts,dbo.vw_MyAlertsSummary"
        Procedures="dbo.usp_GetAlertsByUser,dbo.usp_UpdateAlertComment,dbo.usp_CloseAlert"
        Integrations="Microsoft Graph,Azure SQL Database,Azure Monitor,Power Automate"
        Flow="Asignación>Trabajo>Comentarios>Cierre>Historial"
        Kpis="Mis Alertas,Pendientes,Vencidas,Cerradas Hoy"
        Version="Asignadas a mí v1.0" />
</div>

</div>

<div class="cloud-divider"></div>

<div class="assigned-panel">
    <div class="assigned-header">
        <div>
            <h3>Mis incidentes</h3>
            <small>Última actualización: @LastRefreshAt.ToString("HH:mm:ss")</small>
        </div>

        <button type="button" class="refresh-btn" @onclick="LoadAssignedAlertsAsync">
            🔄 Actualizar
        </button>
    </div>

    <div class="assigned-tabs">
        <button type="button"
                class="assigned-tab @(SelectedSourceType == "Management" ? "active" : "")"
                @onclick='() => ChangeSourceType("Management")'>
            ⚙ Management Alerts
        </button>

        <button type="button"
                class="assigned-tab @(SelectedSourceType == "Backup" ? "active" : "")"
                @onclick='() => ChangeSourceType("Backup")'>
            💾 Backup Alerts
        </button>
    </div>

    <div class="assigned-toolbar">
        <input class="assigned-search"
               placeholder="Buscar cliente, alerta o recurso..."
               @bind="SearchText"
               @bind:event="oninput" />

        <select class="assigned-select"
                @bind="SelectedClient"
                @bind:after="ClientChangedAsync">
            <option value="">Todos los clientes</option>

            @foreach (var client in Clients)
            {
                <option value="@client">@client</option>
            }
        </select>

        <button type="button" class="search-btn" @onclick="SearchAsync">
            Buscar
        </button>

        <select class="assigned-select small"
                @bind="PageSize"
                @bind:after="PageSizeChangedAsync">
            <option value="25">25</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>
    </div>

    @if (IsLoading)
    {
        <p>Cargando alertas asignadas...</p>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="assigned-error">@ErrorMessage</div>
    }
    else
    {
        <div class="table-responsive w-100">
            <table class="table table-hover align-middle assigned-table">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Alerta</th>
                        <th>Severidad</th>
                        <th>Tipo</th>
                        <th>Recurso</th>
                        <th class="text-center">Eventos</th>
                        <th>Último evento</th>
                        <th>Estado</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!FilteredAlerts.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center">
                                No tienes alertas asignadas actualmente.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var alert in FilteredAlerts)
                        {
                            <tr>
                                <td>@alert.ClientName</td>
                                <td>@alert.AlertName</td>
                                <td>
                                    <span class="severity-badge @GetSeverityClass(alert.Severity)">
                                        @alert.Severity
                                    </span>
                                </td>
                                <td>@alert.AlertType</td>
                                <td>@alert.ResourceName</td>
                                <td class="text-center"><strong>@alert.Events</strong></td>
                                <td>@FormatDate(alert.LastEventAt)</td>
                                <td>
                                    <span class="status-badge @GetStatusClass(alert.AlertStatus)">
                                        @GetStatusText(alert.AlertStatus)
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="action-buttons">
                                        <button type="button"
                                                class="detail-btn"
                                                @onclick="async () => await OpenDetailAsync(alert)">
                                            🔎 Ver detalle
                                        </button>

                                        <button type="button"
                                                class="email-btn"
                                                @onclick="() => OpenEmail(alert)">
                                            ✉ Email
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-bar">
            <div>
                Página <strong>@PageNumber</strong> de <strong>@TotalPages</strong>
                — Total: <strong>@TotalCount</strong>
            </div>

            <div class="pagination-actions">
                <button type="button"
                        class="page-btn"
                        disabled="@(PageNumber <= 1)"
                        @onclick="PreviousPageAsync">
                    ◀ Anterior
                </button>

                <button type="button"
                        class="page-btn"
                        disabled="@(PageNumber >= TotalPages)"
                        @onclick="NextPageAsync">
                    Siguiente ▶
                </button>
            </div>
        </div>
    }
</div>

<AlertDetailDialog IsOpen="@IsDetailOpen"
                   Detail="@SelectedDetail"
                   OnClose="CloseDetailAsync"
                   OnSaveComment="SaveDetailCommentAsync"
                   OnCloseAlert="CloseDetailAlertAsync" />

