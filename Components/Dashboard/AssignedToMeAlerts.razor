@code {
    private List<DashboardAlertItemModel> Alerts = new();
    private List<string> Clients = new();

    private bool IsLoading = false;
    private string ErrorMessage = string.Empty;
    private string UserEmail = string.Empty;
    private string UserName = string.Empty;

    private int PageNumber = 1;
    private int PageSize = 25;
    private string SearchText = string.Empty;
    private string SelectedClient = string.Empty;
    private string SelectedSourceType = "Management";
    private int TotalCount = 0;
    private int TotalPages = 0;

    private DateTime LastRefreshAt = DateTime.Now;
    private PeriodicTimer? RefreshTimer;
    private CancellationTokenSource? RefreshCts;

    private bool IsDetailOpen = false;
    private AlertDetailModel? SelectedDetail;
    private DashboardAlertItemModel? SelectedAlert;

    private List<DashboardAlertItemModel> FilteredAlerts =>
        Alerts
            .Where(x => x.SourceType == SelectedSourceType)
            .ToList();

    private int CriticalCount =>
        Alerts.Count(x => IsCritical(x.Severity));

    private int ManagementCount =>
        Alerts.Count(x => x.SourceType == "Management");

    private int BackupCount =>
        Alerts.Count(x => x.SourceType == "Backup");

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        UserEmail =
            user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.FindFirst("preferred_username")?.Value
            ?? user.Identity?.Name
            ?? string.Empty;

        UserName =
            user.FindFirst("name")?.Value
            ?? user.Identity?.Name
            ?? UserEmail;

        await LoadAssignedAlertsAsync();

        RefreshCts = new CancellationTokenSource();
        RefreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(30));

        _ = AutoRefreshAsync(RefreshCts.Token);
    }

    private async Task LoadAssignedAlertsAsync()
    {
        if (string.IsNullOrWhiteSpace(UserEmail))
        {
            ErrorMessage = "No fue posible obtener el usuario autenticado.";
            return;
        }

        IsLoading = true;
        ErrorMessage = string.Empty;

        try
        {
            Clients = await DashboardService.GetAssignedClientsAsync(UserEmail);

            var result = await DashboardService.GetAssignedAlertsAsync(
                UserEmail,
                PageNumber,
                PageSize,
                SearchText,
                SelectedClient);

            Alerts = result.Items;
            TotalCount = result.TotalCount;
            TotalPages = result.TotalPages;
            PageNumber = result.PageNumber;
            PageSize = result.PageSize;
            LastRefreshAt = DateTime.Now;
        }
        catch
        {
            ErrorMessage = "No fue posible cargar las alertas asignadas.";
            Alerts = new();
            Clients = new();
            TotalCount = 0;
            TotalPages = 0;
            PageNumber = 1;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ChangeSourceType(string sourceType)
    {
        SelectedSourceType = sourceType;
        ErrorMessage = string.Empty;
    }

    private async Task SearchAsync()
    {
        PageNumber = 1;
        await LoadAssignedAlertsAsync();
    }

    private async Task ClientChangedAsync()
    {
        PageNumber = 1;
        await LoadAssignedAlertsAsync();
    }

    private async Task PageSizeChangedAsync()
    {
        PageNumber = 1;
        await LoadAssignedAlertsAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (PageNumber > 1)
        {
            PageNumber--;
            await LoadAssignedAlertsAsync();
        }
    }

    private async Task NextPageAsync()
    {
        if (PageNumber < TotalPages)
        {
            PageNumber++;
            await LoadAssignedAlertsAsync();
        }
    }

    private async Task OpenDetailAsync(DashboardAlertItemModel alert)
    {
        ErrorMessage = string.Empty;

        SelectedAlert = alert;
        SelectedDetail = await DashboardService.GetAlertDetailAsync(alert);

        if (SelectedDetail is null)
        {
            ErrorMessage = $"No se encontró detalle para la alerta: {alert.AlertName} - {alert.ResourceName}";
            return;
        }

        IsDetailOpen = true;
    }

    private Task CloseDetailAsync()
    {
        IsDetailOpen = false;
        SelectedDetail = null;
        SelectedAlert = null;

        return Task.CompletedTask;
    }

    private async Task SaveDetailCommentAsync(string payload)
    {
        if (SelectedDetail is null)
        {
            return;
        }

        var status = "InProgress";
        var comment = payload;

        if (!string.IsNullOrWhiteSpace(payload) && payload.Contains('|'))
        {
            var parts = payload.Split('|', 2);
            status = parts[0];
            comment = parts.Length > 1 ? parts[1] : string.Empty;
        }

        var request = new AlertCommentRequestModel
        {
            SourceType = SelectedDetail.SourceType,
            AlertId = SelectedDetail.AlertId,
            ClientName = SelectedDetail.ClientName,
            AlertName = SelectedDetail.AlertName,
            Severity = SelectedDetail.Severity,
            ResourceName = SelectedDetail.ResourceName,
            Status = status,
            Comment = comment,
            UpdatedBy = UserName,
            UserEmail = UserEmail,
            TenantId = SelectedDetail.TenantId,
            SubscriptionId = SelectedDetail.SubscriptionId
        };

        await DashboardService.SaveAlertCommentAsync(request);

        if (SelectedAlert is not null)
        {
            SelectedDetail = await DashboardService.GetAlertDetailAsync(SelectedAlert);
        }

        await LoadAssignedAlertsAsync();
        StateHasChanged();
    }

    private async Task CloseDetailAlertAsync(string payload)
    {
        if (SelectedDetail is null)
        {
            return;
        }

        var comment = payload;

        if (!string.IsNullOrWhiteSpace(payload) && payload.Contains('|'))
        {
            var parts = payload.Split('|', 2);
            comment = parts.Length > 1 ? parts[1] : string.Empty;
        }

        var request = new AlertCommentRequestModel
        {
            SourceType = SelectedDetail.SourceType,
            AlertId = SelectedDetail.AlertId,
            ClientName = SelectedDetail.ClientName,
            AlertName = SelectedDetail.AlertName,
            Severity = SelectedDetail.Severity,
            ResourceName = SelectedDetail.ResourceName,
            Status = "Closed",
            Comment = comment,
            UpdatedBy = UserName,
            UserEmail = UserEmail,
            TenantId = SelectedDetail.TenantId,
            SubscriptionId = SelectedDetail.SubscriptionId
        };

        await DashboardService.CloseAlertAsync(request);

        IsDetailOpen = false;
        SelectedDetail = null;
        SelectedAlert = null;

        await LoadAssignedAlertsAsync();
        StateHasChanged();
    }

    private void OpenEmail(DashboardAlertItemModel alert)
    {
        var alertType = alert.SourceType.Equals("Backup", StringComparison.OrdinalIgnoreCase)
            ? "Backup"
            : "Management";

        var resourceOrAlert = !string.IsNullOrWhiteSpace(alert.ResourceName)
            ? alert.ResourceName
            : alert.AlertName;

        var subject = $"Monitoreo Preventivo | {resourceOrAlert} | {alert.ClientName}";

        var bodyBuilder = new StringBuilder();

        bodyBuilder.AppendLine("Estimado cliente,");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("Durante nuestras labores de monitoreo y validación preventiva, hemos identificado alertas activas en su entorno de Azure relacionadas con servicios de infraestructura y/o respaldos.");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("El objetivo de esta notificación es mantener visibilidad temprana sobre eventos que podrían requerir revisión o seguimiento técnico para prevenir impactos operativos.");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("==========================================================");
        bodyBuilder.AppendLine("RESUMEN DE ALERTAS IDENTIFICADAS");
        bodyBuilder.AppendLine("==========================================================");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine($"Tipo de alerta: {alertType}");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine($"Alerta: {alert.AlertName}");
        bodyBuilder.AppendLine($"Recurso: {alert.ResourceName}");
        bodyBuilder.AppendLine($"Severidad: {alert.Severity}");
        bodyBuilder.AppendLine($"Eventos: {alert.Events}");
        bodyBuilder.AppendLine($"Último evento: {FormatDate(alert.LastEventAt)}");
        bodyBuilder.AppendLine($"Estado: {GetStatusText(alert.AlertStatus)}");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("==========================================================");
        bodyBuilder.AppendLine("POSIBLES IMPACTOS");
        bodyBuilder.AppendLine("==========================================================");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("• Fallos o inconsistencias en procesos de respaldo.");
        bodyBuilder.AppendLine("• Eventos relacionados con disponibilidad o configuración de recursos.");
        bodyBuilder.AppendLine("• Alertas de plataforma reportadas por Azure Monitor.");
        bodyBuilder.AppendLine("• Necesidad de validación preventiva sobre recursos específicos.");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("==========================================================");
        bodyBuilder.AppendLine("RECOMENDACIONES");
        bodyBuilder.AppendLine("==========================================================");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("• Revisar los recursos indicados en las alertas reportadas.");
        bodyBuilder.AppendLine("• Validar el estado actual de los servicios involucrados.");
        bodyBuilder.AppendLine("• Dar seguimiento preventivo para evitar impactos futuros.");
        bodyBuilder.AppendLine("• Coordinar revisión técnica en caso de observar comportamiento inusual.");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("Nuestro equipo puede apoyarle en la validación técnica, análisis de impacto y seguimiento de las alertas identificadas.");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("En caso de requerir asistencia, puede generar un caso mediante el siguiente portal de soporte:");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("https://evistacloud.itqscr.com/");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("==========================================================");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("Quedamos atentos para cualquier consulta adicional o coordinación técnica.");
        bodyBuilder.AppendLine();
        bodyBuilder.AppendLine("Saludos,");
        bodyBuilder.AppendLine("Soporte ITQS");

        var mailto = $"mailto:?subject={Uri.EscapeDataString(subject)}&body={Uri.EscapeDataString(bodyBuilder.ToString())}";
        NavigationManager.NavigateTo(mailto, forceLoad: true);
    }

    private string GetSeverityClass(string severity)
    {
        return severity?.ToLowerInvariant() switch
        {
            "critical" => "critical",
            "error" => "critical",
            "high" => "critical",
            "warning" => "warning",
            "medium" => "warning",
            "informational" => "info",
            "info" => "info",
            "sev0" => "critical",
            "sev1" => "critical",
            "sev2" => "warning",
            "sev3" => "info",
            _ => "normal"
        };
    }

    private string GetStatusText(string status)
    {
        return status?.ToLowerInvariant() switch
        {
            "closed" => "Closed",
            "inprogress" => "In Progress",
            "in progress" => "In Progress",
            "activa" => "Activa",
            "active" => "Activa",
            "new" => "Activa",
            _ => string.IsNullOrWhiteSpace(status) ? "Activa" : status
        };
    }

    private string GetStatusClass(string status)
    {
        return status?.ToLowerInvariant() switch
        {
            "closed" => "closed",
            "inprogress" => "in-progress",
            "in progress" => "in-progress",
            _ => "active"
        };
    }

    private bool IsCritical(string severity)
    {
        var value = severity?.ToLowerInvariant();

        return value is "critical" or "error" or "high" or "sev0" or "sev1";
    }

    private string FormatDate(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToString("dd/MM/yyyy HH:mm")
            : "-";
    }

    private async Task AutoRefreshAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (RefreshTimer is not null &&
                   await RefreshTimer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    if (!IsDetailOpen)
                    {
                        await LoadAssignedAlertsAsync();
                        StateHasChanged();
                    }
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    public void Dispose()
    {
        RefreshCts?.Cancel();
        RefreshTimer?.Dispose();
        RefreshCts?.Dispose();
    }
}










