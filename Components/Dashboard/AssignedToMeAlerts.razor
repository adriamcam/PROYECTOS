@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using ITQS.SupportOperationsCenter.Components.Dialogs
@using ITQS.SupportOperationsCenter.Models.Dashboard
@using ITQS.SupportOperationsCenter.Services.Interfaces

@inject IAssignedAlertsDashboardService DashboardService
@inject AuthenticationStateProvider AuthenticationStateProvider

@implements IDisposable

<h1>Asignadas a mí</h1>
<p>Alertas asignadas al usuario conectado para seguimiento, comentarios y cierre.</p>

<div class="cloud-divider"></div>

<div class="assigned-kpi-row">
    <div class="assigned-kpi-card red">
        <span>🚨</span>
        <div>
            <strong>@TotalCount</strong>
            <small>Total asignadas</small>
        </div>
    </div>

    <div class="assigned-kpi-card orange">
        <span>🔥</span>
        <div>
            <strong>@CriticalCount</strong>
            <small>Críticas</small>
        </div>
    </div>

    <div class="assigned-kpi-card blue">
        <span>⚙</span>
        <div>
            <strong>@ManagementCount</strong>
            <small>Management</small>
        </div>
    </div>

    <div class="assigned-kpi-card purple">
        <span>💾</span>
        <div>
            <strong>@BackupCount</strong>
            <small>Backup</small>
        </div>
    </div>
</div>

<div class="cloud-divider"></div>

<div class="assigned-panel">
    <div class="assigned-header">
        <div>
            <h3>Mis incidentes</h3>
            <small>Última actualización: @LastRefreshAt.ToString("HH:mm:ss")</small>
        </div>

        <button type="button" class="refresh-btn" @onclick="LoadAssignedAlertsAsync">
            🔄 Actualizar
        </button>
    </div>

    <div class="assigned-toolbar">
        <input class="assigned-search"
               placeholder="Buscar cliente, alerta o recurso..."
               @bind="SearchText"
               @bind:event="oninput" />

        <select class="assigned-select"
                @bind="SelectedClient"
                @bind:after="ClientChangedAsync">
            <option value="">Todos los clientes</option>

            @foreach (var client in Clients)
            {
                <option value="@client">@client</option>
            }
        </select>

        <button type="button" class="search-btn" @onclick="SearchAsync">
            Buscar
        </button>

        <select class="assigned-select small"
                @bind="PageSize"
                @bind:after="PageSizeChangedAsync">
            <option value="25">25</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>
    </div>

    @if (IsLoading)
    {
        <p>Cargando alertas asignadas...</p>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="assigned-error">@ErrorMessage</div>
    }
    else
    {
        <div class="table-responsive w-100">
            <table class="table table-hover align-middle assigned-table">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Alerta</th>
                        <th>Severidad</th>
                        <th>Tipo</th>
                        <th>Recurso</th>
                        <th class="text-center">Eventos</th>
                        <th>Último evento</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Alerts.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center">
                                No tienes alertas asignadas actualmente.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var alert in Alerts)
                        {
                            <tr>
                                <td>@alert.ClientName</td>
                                <td>@alert.AlertName</td>
                                <td>
                                    <span class="severity-badge @GetSeverityClass(alert.Severity)">
                                        @alert.Severity
                                    </span>
                                </td>
                                <td>@alert.AlertType</td>
                                <td>@alert.ResourceName</td>
                                <td class="text-center"><strong>@alert.Events</strong></td>
                                <td>@FormatDate(alert.LastEventAt)</td>
                                <td class="text-center">
                                    <button type="button"
                                            class="detail-btn"
                                            @onclick="async () => await OpenDetailAsync(alert)">
                                        🔎 Ver detalle
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-bar">
            <div>
                Página <strong>@PageNumber</strong> de <strong>@TotalPages</strong>
                — Total: <strong>@TotalCount</strong>
            </div>

            <div class="pagination-actions">
                <button type="button"
                        class="page-btn"
                        disabled="@(PageNumber <= 1)"
                        @onclick="PreviousPageAsync">
                    ◀ Anterior
                </button>

                <button type="button"
                        class="page-btn"
                        disabled="@(PageNumber >= TotalPages)"
                        @onclick="NextPageAsync">
                    Siguiente ▶
                </button>
            </div>
        </div>
    }
</div>

<AlertDetailDialog IsOpen="@IsDetailOpen"
                   Detail="@SelectedDetail"
                   OnClose="CloseDetailAsync"
                   OnSaveComment="SaveDetailCommentAsync"
                   OnCloseAlert="CloseDetailAlertAsync" />

<style>
