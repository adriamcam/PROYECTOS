.advisor-page {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
}

.advisor-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
}

.advisor-header h2 {
    margin: 4px 0 6px;
    color: #17233c;
    font-size: 24px;
    font-weight: 700;
}

.advisor-header p {
    max-width: 760px;
    margin: 0;
    color: #667085;
    font-size: 14px;
    line-height: 1.55;
}

.advisor-eyebrow {
    color: #2563eb;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.advisor-refresh-button,
.advisor-retry-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 38px;
    padding: 8px 15px;
    border: 1px solid #cbd5e1;
    border-radius: 7px;
    background: #ffffff;
    color: #334155;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition:
        border-color 0.15s ease,
        background-color 0.15s ease;
}

.advisor-refresh-button:hover,
.advisor-retry-button:hover {
    border-color: #2563eb;
    background: #eff6ff;
}

.advisor-refresh-button:disabled {
    cursor: wait;
    opacity: 0.65;
}

.advisor-summary-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
}

.advisor-summary-card {
    display: flex;
    flex-direction: column;
    min-height: 122px;
    padding: 18px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    background: #ffffff;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
}

.advisor-summary-card span {
    color: #64748b;
    font-size: 12px;
    font-weight: 600;
}

.advisor-summary-card strong {
    margin-top: 10px;
    color: #17233c;
    font-size: 25px;
    font-weight: 700;
}

.advisor-summary-card small {
    margin-top: auto;
    padding-top: 9px;
    color: #94a3b8;
    font-size: 11px;
}

.advisor-table-card {
    overflow: hidden;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    background: #ffffff;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
}

.advisor-table-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 17px 20px;
    border-bottom: 1px solid #e2e8f0;
}

.advisor-table-header h3 {
    margin: 3px 0 0;
    color: #17233c;
    font-size: 16px;
    font-weight: 700;
}

.advisor-result-count {
    padding: 5px 10px;
    border-radius: 999px;
    background: #eff6ff;
    color: #2563eb;
    font-size: 11px;
    font-weight: 700;
}

.advisor-table-container {
    width: 100%;
    overflow-x: auto;
}

.advisor-table {
    width: 100%;
    min-width: 980px;
    border-collapse: collapse;
}

.advisor-table th {
    padding: 11px 16px;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
    color: #64748b;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.025em;
    text-align: left;
    text-transform: uppercase;
}

.advisor-table td {
    padding: 13px 16px;
    border-bottom: 1px solid #eef2f7;
    color: #475569;
    font-size: 12px;
    vertical-align: middle;
}

.advisor-table tbody tr:last-child td {
    border-bottom: 0;
}

.advisor-table tbody tr:hover {
    background: #f8fbff;
}

.advisor-recommendation-title {
    max-width: 360px;
    color: #1e293b;
    font-weight: 600;
    line-height: 1.4;
}

.advisor-category {
    display: inline-flex;
    padding: 4px 8px;
    border-radius: 5px;
    background: #f1f5f9;
    color: #475569;
    font-size: 11px;
    font-weight: 600;
}

.advisor-impact {
    display: inline-flex;
    min-width: 66px;
    justify-content: center;
    padding: 4px 8px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
}

.advisor-impact-high {
    background: #fee2e2;
    color: #b91c1c;
}

.advisor-impact-medium {
    background: #fef3c7;
    color: #92400e;
}

.advisor-impact-low {
    background: #dcfce7;
    color: #166534;
}

.advisor-resource {
    display: inline-block;
    max-width: 220px;
    overflow: hidden;
    color: #475569;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.advisor-money-column {
    text-align: right !important;
    white-space: nowrap;
}

.advisor-money-column strong {
    color: #047857;
}

.advisor-state {
    display: flex;
    min-height: 260px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
    border: 1px dashed #cbd5e1;
    border-radius: 10px;
    background: #f8fafc;
    text-align: center;
}

.advisor-state-icon {
    margin-bottom: 10px;
    font-size: 32px;
}

.advisor-state h3 {
    margin: 0 0 7px;
    color: #1e293b;
    font-size: 17px;
}

.advisor-state p {
    max-width: 560px;
    margin: 0;
    color: #64748b;
    font-size: 13px;
    line-height: 1.5;
}

.advisor-state-error {
    border-color: #fecaca;
    background: #fff7f7;
}

.advisor-state-error .advisor-retry-button {
    margin-top: 16px;
}

.advisor-loader {
    width: 30px;
    height: 30px;
    margin-bottom: 14px;
    border: 3px solid #dbeafe;
    border-top-color: #2563eb;
    border-radius: 50%;
    animation: advisor-spin 0.8s linear infinite;
}

@keyframes advisor-spin {
    to {
        transform: rotate(360deg);
    }
}

@media (max-width: 900px) {
    .advisor-summary-grid {
        grid-template-columns: 1fr;
    }

    .advisor-header {
        flex-direction: column;
    }
}
