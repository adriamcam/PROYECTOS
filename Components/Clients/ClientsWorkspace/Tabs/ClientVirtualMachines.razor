<style>
    .vm-export-button {
        display: inline-flex;
        min-height: 34px;
        align-items: center;
        justify-content: center;
        gap: 7px;
        padding: 7px 14px;
        border: 1px solid #2563eb;
        border-radius: 8px;
        background: #2563eb;
        color: #ffffff;
        font-family: inherit;
        font-size: 12px;
        font-weight: 700;
        line-height: 1;
        white-space: nowrap;
        cursor: pointer;
        box-shadow: 0 2px 5px rgba(37, 99, 235, .20);
        transition:
            background-color .15s ease,
            border-color .15s ease,
            box-shadow .15s ease,
            transform .15s ease;
    }

    .vm-export-button::before {
        content: "⇩";
        font-size: 16px;
        font-weight: 700;
        line-height: 1;
    }

    .vm-export-button:hover:not(:disabled) {
        border-color: #1d4ed8;
        background: #1d4ed8;
        box-shadow: 0 5px 12px rgba(37, 99, 235, .25);
        transform: translateY(-1px);
    }

    .vm-export-button:focus-visible {
        outline: 3px solid rgba(37, 99, 235, .20);
        outline-offset: 2px;
    }

    .vm-export-button:disabled {
        border-color: #cbd5e1;
        background: #e2e8f0;
        color: #64748b;
        cursor: not-allowed;
        box-shadow: none;
        transform: none;
    }
</style>
<section class="virtual-machines-workspace">

    <header class="vm-heading">

        <div class="vm-title-group">

            <div class="vm-title-icon">
                🖥️
            </div>

            <div>
                <span class="vm-eyebrow">
                    COMPUTE
                </span>

                <h2>Virtual Machines</h2>

                <p>
                    Inventario consolidado de cómputo, sistema operativo,
                    red, discos y extensiones.
                </p>
            </div>

        </div>

        <div class="vm-heading-summary">
            <span>Fuente</span>
            <strong>vw_VMInfrastructure</strong>
        </div>

    </header>

    <section class="vm-kpi-grid">

        <article class="vm-kpi-card">
            <div class="vm-kpi-header">
                <span>Total VM</span>
                <span class="vm-kpi-icon">🖥️</span>
            </div>

            <strong>@TotalVMs</strong>
            <small>Máquinas inventariadas</small>
        </article>

        <article class="vm-kpi-card">
            <div class="vm-kpi-header">
                <span>Running</span>
                <span class="vm-kpi-indicator success"></span>
            </div>

            <strong>@Running</strong>
            <small>En ejecución</small>
        </article>

        <article class="vm-kpi-card">
            <div class="vm-kpi-header">
                <span>Stopped</span>
                <span class="vm-kpi-indicator neutral"></span>
            </div>

            <strong>@Stopped</strong>
            <small>Detenidas o desasignadas</small>
        </article>

        <article class="vm-kpi-card">
            <div class="vm-kpi-header">
                <span>Windows</span>
                <span class="vm-kpi-icon">▦</span>
            </div>

            <strong>@Windows</strong>
            <small>Máquinas Windows</small>
        </article>

        <article class="vm-kpi-card">
            <div class="vm-kpi-header">
                <span>Linux</span>
                <span class="vm-kpi-icon">🐧</span>
            </div>

            <strong>@Linux</strong>
            <small>Máquinas Linux</small>
        </article>

        <article class="vm-kpi-card">
            <div class="vm-kpi-header">
                <span>vCPU</span>
                <span class="vm-kpi-icon">⚙️</span>
            </div>

            <strong>@TotalVCPUs</strong>
            <small>Capacidad total</small>
        </article>

        <article class="vm-kpi-card">
            <div class="vm-kpi-header">
                <span>Memoria</span>
                <span class="vm-kpi-icon">▤</span>
            </div>

            <strong>@TotalMemoryGB.ToString("N0") GB</strong>
            <small>RAM total aprovisionada</small>
        </article>

    </section>

    <section class="vm-inventory-card">

        <header class="vm-inventory-header">

            <div>
                <h3>Inventario de máquinas virtuales</h3>

                <p>
                    Información centralizada de cada máquina virtual
                    perteneciente al cliente y suscripción seleccionados.
                </p>
            </div>

            <div style="display:flex; align-items:center; gap:10px;">

                <button type="button"
                        class="vm-export-button"
                        disabled="@(IsLoading || IsExportingExcel || VirtualMachines.Count == 0)"
                        @onclick="ExportToExcelAsync">
                    @(IsExportingExcel
                        ? "Generando Excel..."
                        : "Exportar Excel")
                </button>

                <div class="vm-result-count">
                    <strong>@VirtualMachines.Count</strong>
                    <span>resultados</span>
                </div>

            </div>

        </header>

        <div class="vm-table-container">

            <table class="vm-table">

                <thead>
                    <tr>
                        <th>Máquina virtual</th>
                        <th>Estado</th>
                        <th>Resource Group</th>
                        <th>Región</th>
                        <th>Size</th>
                        <th>vCPU</th>
                        <th>RAM</th>
                        <th>Sistema operativo</th>
                        <th>IP privada</th>
                        <th>NIC</th>
                        <th>Discos</th>
                        <th>Almacenamiento</th>
                        <th>Tipo disco</th>
                        <th>Nombre disco</th>
                        <th>Tamaño disco</th>
                        <th>Tier</th>
                    </tr>
                </thead>

                <tbody>

                    @if (IsLoading)
                    {
                        <tr>
                            <td colspan="16">
                                <div class="vm-empty-state">
                                    <div class="vm-empty-icon">🖥️</div>
                                    <strong>Cargando inventario</strong>
                                    <p>Consultando las máquinas virtuales de @CustomerName.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
                    {
                        <tr>
                            <td colspan="16">
                                <div class="vm-empty-state">
                                    <div class="vm-empty-icon">⚠️</div>
                                    <strong>Error al cargar el inventario</strong>
                                    <p>@ErrorMessage</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (VirtualMachines.Count == 0)
                    {
                        <tr>
                            <td colspan="16">
                                <div class="vm-empty-state">
                                    <div class="vm-empty-icon">🖥️</div>
                                    <strong>Sin máquinas virtuales</strong>
                                    <p>
                                        No se encontraron registros para el cliente
                                        @CustomerName y la suscripción seleccionada.
                                    </p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var vm in VirtualMachines)
                        {
                            <tr>
                                <td>
                                    <strong>@vm.VMName</strong>
                                </td>

                                <td>
                                    <span class="@StateCssClass(vm.DisplayPowerState)">
                                        @vm.DisplayPowerState
                                    </span>
                                </td>

                                <td>@vm.DisplayResourceGroup</td>
                                <td>@vm.DisplayLocation</td>
                                <td>@vm.DisplayVMSize</td>
                                <td>@vm.DisplayVCPUs</td>
                                <td>@vm.DisplayMemoryGB.ToString("N2") GB</td>
                                <td>@vm.DisplayOSType</td>
                                <td>@vm.DisplayPrivateIP</td>
                                <td>@vm.DisplayNicName</td>
                                <td>@vm.DisplayDiskCount</td>
                                <td>@vm.DisplayDiskSizeGB.ToString("N0") GB</td>

                                <td>
                                    @foreach (var disk in vm.Disks)
                                    {
                                        <div>@disk.DisplayRole</div>
                                    }
                                </td>

                                <td>
                                    @foreach (var disk in vm.Disks)
                                    {
                                        <div>@disk.DiskName</div>
                                    }
                                </td>

                                <td>
                                    @foreach (var disk in vm.Disks)
                                    {
                                        <div>@((disk.DiskSizeGB ?? 0).ToString("N0")) GB</div>
                                    }
                                </td>

                                <td>
                                    @foreach (var disk in vm.Disks)
                                    {
                                        <div>@disk.DisplayTier</div>
                                    }
                                </td>
                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </section>

</section>



