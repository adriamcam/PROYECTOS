@using System.Globalization
@using Microsoft.AspNetCore.Components
@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Models

<section class="overview-dashboard">

    <header class="overview-heading">
        <div>
            <span class="overview-eyebrow">RESUMEN OPERATIVO</span>
            <h2>@SubscriptionDisplayName</h2>
            <p>
                Vista consolidada de infraestructura, protección,
                optimización y salud operativa.
            </p>
        </div>

        <div class="@($"overview-status {GetStatusClass()}")">
            <span class="overview-status-dot"></span>
            <div>
                <small>Estado general</small>
                <strong>@DisplayOverallStatus</strong>
            </div>
        </div>
    </header>

    <div class="overview-section-grid">
        <article class="overview-panel overview-health-panel">
            <div class="overview-panel-header">
                <div>
                    <span class="overview-panel-eyebrow">ÚLTIMOS 7 DÍAS</span>
                    <h3>Estado de infraestructura</h3>
                </div>

                <span class="@($"overview-health-badge {GetStatusClass()}")">
                    @DisplayOverallStatus
                </span>
            </div>

            <div class="overview-metric-list">

                <div class="overview-metric">
                    <div class="overview-metric-header">
                        <div>
                            <span>Total de VM</span>
                            <small>Máquinas virtuales activas</small>
                        </div>

                        <strong>
                            @Overview.TotalVirtualMachines.ToString("N0")
                        </strong>
                    </div>
                </div>

                <div class="overview-metric">
                    <div class="overview-metric-header">
                        <div>
                            <span>VM con CPU crítica</span>
                            <small>Mayor valor diario del período</small>
                        </div>

                        <strong>
                            @Overview.CpuCriticalVirtualMachines.ToString("N0")
                        </strong>
                    </div>
                </div>

                <div class="overview-metric">
                    <div class="overview-metric-header">
                        <div>
                            <span>VM con memoria crítica</span>
                            <small>Mayor valor diario del período</small>
                        </div>

                        <strong>
                            @Overview.MemoryCriticalVirtualMachines.ToString("N0")
                        </strong>
                    </div>
                </div>

                <div class="overview-metric">
                    <div class="overview-metric-header">
                        <div>
                            <span>VM con discos críticos</span>
                            <small>Mayor valor diario del período</small>
                        </div>

                        <strong>
                            @Overview.DiskCriticalVirtualMachines.ToString("N0")
                        </strong>
                    </div>
                </div>

            </div>
        </article>

        <article class="overview-panel">
            <div class="overview-panel-header">
                <div>
                    <span class="overview-panel-eyebrow">PROTECCIÓN</span>
                    <h3>Cobertura de backup</h3>
                </div>

                <span class="@($"overview-value-badge {GetBackupClass()}")">
                    @FormatPercent(Overview.BackupCoveragePercentage)
                </span>
            </div>

            <div class="overview-backup-summary">
                <div class="overview-donut"
                     style="@GetDonutStyle(Overview.BackupCoveragePercentage)">
                    <div>
                        <strong>@FormatPercent(Overview.BackupCoveragePercentage)</strong>
                        <span>cobertura</span>
                    </div>
                </div>

                <div class="overview-backup-stats">
                    <div>
                        <span class="overview-legend-dot legend-total"></span>
                        <p>
                            <small>Total evaluadas</small>
                            <strong>@Overview.TotalBackupVirtualMachines.ToString("N0")</strong>
                        </p>
                    </div>

                    <div>
                        <span class="overview-legend-dot legend-protected"></span>
                        <p>
                            <small>Con backup</small>
                            <strong>@Overview.VirtualMachinesWithBackup.ToString("N0")</strong>
                        </p>
                    </div>

                    <div>
                        <span class="overview-legend-dot legend-unprotected"></span>
                        <p>
                            <small>Sin backup</small>
                            <strong>@Overview.VirtualMachinesWithoutBackup.ToString("N0")</strong>
                        </p>
                    </div>
                </div>
            </div>

            @if (Overview.VirtualMachinesWithoutBackup > 0)
            {
                <div class="overview-callout overview-callout-warning">
                    <span>!</span>
                    <p>
                        Existen
                        <strong>@Overview.VirtualMachinesWithoutBackup.ToString("N0")</strong>
                        máquinas virtuales sin protección de backup.
                    </p>
                </div>
            }
            else
            {
                <div class="overview-callout overview-callout-success">
                    <span>✓</span>
                    <p>Todas las máquinas virtuales evaluadas están protegidas.</p>
                </div>
            }
        </article>

        <article class="overview-panel">
            <div class="overview-panel-header">
                <div>
                    <span class="overview-panel-eyebrow">GOBERNANZA</span>
                    <h3>Recursos</h3>
                </div>
            </div>

            <div class="overview-risk-grid">
                <div class="@($"overview-risk-card {GetCountRiskClass(Overview.OrphanResources)}")">
                    <div class="overview-risk-icon">⌁</div>
                    <div>
                        <span>Recursos huérfanos</span>
                        <strong>@Overview.OrphanResources.ToString("N0")</strong>
                        <small>Requieren revisión</small>
                    </div>
                </div>

                <div class="@($"overview-risk-card {GetCountRiskClass(Overview.ResourcesWithoutTags)}")">
                    <div class="overview-risk-icon">#</div>
                    <div>
                        <span>Recursos sin tags</span>
                        <strong>@Overview.ResourcesWithoutTags.ToString("N0")</strong>
                        <small>Gobernanza incompleta</small>
                    </div>
                </div>
            </div>

            <div class="overview-governance-note">
                <strong>Prioridad sugerida</strong>
                <p>@GovernanceRecommendation</p>
            </div>
        </article>

        <article class="overview-panel overview-advisor-panel">
            <div class="overview-panel-header">
                <div>
                    <span class="overview-panel-eyebrow">OPTIMIZACIÓN</span>
                    <h3>Azure Advisor</h3>
                </div>

                <span class="overview-advisor-count">
                    @Overview.TotalAdvisorRecommendations.ToString("N0")
                </span>
            </div>

            <div class="overview-savings">
                <span>Ahorro anual estimado</span>
                <strong>@FormatMoney(Overview.AnnualAdvisorSavings)</strong>
                <small>
                    Estimación basada en recomendaciones actualmente valoradas.
                </small>
            </div>

            <div class="overview-advisor-line">
                <div>
                    <span>Recomendaciones detectadas</span>
                    <strong>@Overview.TotalAdvisorRecommendations.ToString("N0")</strong>
                </div>

                <div>
                    <span>Promedio potencial por recomendación</span>
                    <strong>@AverageSavingsPerRecommendation</strong>
                </div>
            </div>
        </article>

    </div>

</section>

@code {
    [Parameter, EditorRequired]
    public ClientWorkspaceContext Context { get; set; } = new();

    [Parameter, EditorRequired]
    public ClientWorkspaceOverview Overview { get; set; } = new();

    private string CustomerDisplayName =>
        !string.IsNullOrWhiteSpace(Context.CustomerNamePortal)
            ? Context.CustomerNamePortal
            : !string.IsNullOrWhiteSpace(Context.CustomerName)
                ? Context.CustomerName
                : "Cliente seleccionado";

    private string SubscriptionDisplayName =>
        Context.HasSubscription
            ? DisplayValue(Context.SubscriptionName)
            : "Todas las suscripciones";

    private string DisplayOverallStatus =>
        string.IsNullOrWhiteSpace(Overview.OverallStatus)
            ? "Sin datos"
            : Overview.OverallStatus;

    private string LastUpdateText =>
        Overview.LastOperationalUpdate.HasValue
            ? Overview.LastOperationalUpdate.Value.ToString(
                "dd/MM/yyyy HH:mm",
                CultureInfo.InvariantCulture)
            : "Sin información";

    private string GovernanceRecommendation
    {
        get
        {
            if (Overview.OrphanResources > 0 &&
                Overview.ResourcesWithoutTags > 0)
            {
                return "Revisar primero los recursos huérfanos y luego completar el etiquetado obligatorio.";
            }

            if (Overview.OrphanResources > 0)
            {
                return "Validar propiedad, dependencia y necesidad de los recursos huérfanos detectados.";
            }

            if (Overview.ResourcesWithoutTags > 0)
            {
                return "Completar las etiquetas de propietario, ambiente, centro de costo y criticidad.";
            }

            return "No se identifican pendientes relevantes de higiene de recursos.";
        }
    }

    private string AverageSavingsPerRecommendation
    {
        get
        {
            if (Overview.TotalAdvisorRecommendations <= 0)
            {
                return "$0.00";
            }

            var average =
                Overview.AnnualAdvisorSavings /
                Overview.TotalAdvisorRecommendations;

            return FormatMoney(average);
        }
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? "-"
            : value;

    private static string FormatPercent(decimal value) =>
        $"{NormalizePercentage(value).ToString("N2", CultureInfo.InvariantCulture)}%";

    private static string FormatMoney(decimal value) =>
        value.ToString(
            "C2",
            CultureInfo.GetCultureInfo("en-US"));

    private static decimal NormalizePercentage(decimal value) =>
        Math.Clamp(value, 0m, 100m);

    private static string GetProgressStyle(decimal value)
    {
        var normalized = NormalizePercentage(value);

        return string.Create(
            CultureInfo.InvariantCulture,
            $"width: {normalized:0.##}%;");
    }

    private static string GetDonutStyle(decimal value)
    {
        var normalized = NormalizePercentage(value);

        return string.Create(
            CultureInfo.InvariantCulture,
            $"--backup-coverage: {normalized:0.##}%;");
    }

    private string GetStatusClass()
    {
        var status = DisplayOverallStatus.Trim().ToLowerInvariant();

        if (status.Contains("healthy") ||
            status.Contains("saludable") ||
            status.Contains("correcto"))
        {
            return "status-success";
        }

        if (status.Contains("critical") ||
            status.Contains("crítico") ||
            status.Contains("critico") ||
            status.Contains("error"))
        {
            return "status-danger";
        }

        if (status.Contains("warning") ||
            status.Contains("advertencia") ||
            status.Contains("degradado"))
        {
            return "status-warning";
        }

        return "status-neutral";
    }

    private string GetCpuClass() =>
        Overview.AverageCpuPercent >= 85m
            ? "progress-danger"
            : Overview.AverageCpuPercent >= 70m
                ? "progress-warning"
                : "progress-success";

    private string GetMemoryClass() =>
        Overview.AverageMemoryPercent >= 90m
            ? "progress-danger"
            : Overview.AverageMemoryPercent >= 75m
                ? "progress-warning"
                : "progress-success";

    private string GetAvailabilityClass() =>
        Overview.AverageAvailabilityPercent >= 99m
            ? "progress-success"
            : Overview.AverageAvailabilityPercent >= 95m
                ? "progress-warning"
                : "progress-danger";

    private string GetBackupClass() =>
        Overview.BackupCoveragePercentage >= 95m
            ? "value-success"
            : Overview.BackupCoveragePercentage >= 80m
                ? "value-warning"
                : "value-danger";

    private static string GetCountRiskClass(int value) =>
        value <= 0
            ? "risk-success"
            : "risk-warning";
}






