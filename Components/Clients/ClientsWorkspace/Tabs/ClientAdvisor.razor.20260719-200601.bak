@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Models
@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Services
@inject IClientWorkspaceService WorkspaceService

<section class="advisor-page">

    <header class="advisor-header">
        <div>
            <span class="advisor-eyebrow">
                Optimización, confiabilidad y seguridad
            </span>

            <h2>Azure Advisor</h2>

            <p>
                Scores, recomendaciones, ahorro potencial y Secure Score
                para la selección actual.
            </p>
        </div>

        <button type="button"
                class="advisor-refresh-button"
                disabled="@(IsLoading || Context?.HasCustomer != true)"
                @onclick="LoadDataAsync">
            ↻ Actualizar
        </button>
    </header>

    @if (Context?.HasCustomer != true)
    {
        <div class="advisor-state">
            <h3>Seleccione un cliente</h3>
            <p>
                Seleccione un cliente para consultar Azure Advisor.
            </p>
        </div>
    }
    else if (IsLoading)
    {
        <div class="advisor-state">
            <div class="advisor-loader"></div>
            <h3>Cargando Azure Advisor</h3>
            <p>Consultando scores y recomendaciones.</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="advisor-state advisor-error">
            <h3>Error al consultar Azure Advisor</h3>
            <p>@ErrorMessage</p>
        </div>
    }
    else
    {
        <section class="advisor-panel">

            <div class="advisor-panel-heading">
                <div>
                    <span class="advisor-eyebrow">Evaluación</span>
                    <h3>Scores de Azure</h3>
                </div>

                <span class="@GetScoreBadgeClass(AdvisorGeneralScore)">
                    Advisor general:
                    @FormatPercent(AdvisorGeneralScore)
                </span>
            </div>

            <div class="advisor-score-grid">

                @foreach (var score in AdvisorScores)
                {
                    <article class="advisor-score-card">
                        <div class="advisor-score-header">
                            <span>@TranslateScore(score.ScoreName)</span>
                            <strong>@FormatPercent(score.Score)</strong>
                        </div>

                        <div class="advisor-score-track">
                            <div class="advisor-score-fill"
                                 style="@GetWidthStyle(score.Score)">
                            </div>
                        </div>

                        <div class="advisor-score-footer">
                            <span>
                                Recursos:
                                <strong>@score.ImpactedResourceCount</strong>
                            </span>

                            <span>
                                Mejora:
                                <strong>
                                    @FormatPercent(
                                        score.PotentialScoreIncrease)
                                </strong>
                            </span>
                        </div>
                    </article>
                }

                <article class="advisor-score-card security-score">
                    <div class="advisor-score-header">
                        <span>Defender Secure Score</span>

                        <strong>
                            @FormatPercent(SecurityScore?.Score ?? 0)
                        </strong>
                    </div>

                    <div class="advisor-score-track">
                        <div class="advisor-score-fill"
                             style="@GetWidthStyle(
                                 SecurityScore?.Score ?? 0)">
                        </div>
                    </div>

                    <div class="advisor-score-footer">
                        <span>
                            Suscripciones:
                            <strong>
                                @(SecurityScore?.SubscriptionCount ?? 0)
                            </strong>
                        </span>

                        <span>
                            Actualización:
                            <strong>
                                @FormatDate(SecurityScore?.UpdatedAt)
                            </strong>
                        </span>
                    </div>
                </article>

            </div>
        </section>

        <div class="advisor-summary-grid">

            <article class="advisor-summary-card">
                <span>Total recomendaciones</span>
                <strong>@Recommendations.Count</strong>
                <small>Todas las recomendaciones disponibles</small>
            </article>

            <article class="advisor-summary-card">
                <span>Ahorro anual potencial</span>
                <strong>@FormatMoney(TotalSavings)</strong>
                <small>Suma total, no solamente Top 10</small>
            </article>

            <article class="advisor-summary-card">
                <span>Recursos afectados</span>
                <strong>@AffectedResources</strong>
                <small>Recursos únicos con recomendaciones</small>
            </article>

            <article class="advisor-summary-card">
                <span>Con ahorro estimado</span>
                <strong>@RecommendationsWithSavings</strong>
                <small>Recomendaciones valorizadas</small>
            </article>

        </div>

        <section class="advisor-panel">

            <div class="advisor-panel-heading">
                <div>
                    <span class="advisor-eyebrow">
                        Inventario completo
                    </span>

                    <h3>Todas las recomendaciones</h3>
                </div>

                <span class="advisor-result-count">
                    @FilteredRecommendations.Count resultados
                </span>
            </div>

            <div class="advisor-filters">

                <input type="search"
                       class="advisor-input"
                       placeholder="Buscar recomendación, recurso o grupo..."
                       @bind="SearchText"
                       @bind:event="oninput" />

                <select class="advisor-select"
                        @bind="SelectedCategory">
                    <option value="">Todas las categorías</option>

                    @foreach (var category in Categories)
                    {
                        <option value="@category">
                            @TranslateCategory(category)
                        </option>
                    }
                </select>

                <select class="advisor-select"
                        @bind="SelectedImpact">
                    <option value="">Todos los impactos</option>

                    @foreach (var impact in Impacts)
                    {
                        <option value="@impact">@impact</option>
                    }
                </select>

                <label class="advisor-checkbox">
                    <input type="checkbox"
                           @bind="OnlyWithSavings" />

                    Solo con ahorro
                </label>

            </div>

            <div class="advisor-table-wrapper">
                <table class="advisor-table">
                    <thead>
                        <tr>
                            <th>Recomendación</th>
                            <th>Categoría</th>
                            <th>Impacto</th>
                            <th>Recurso</th>
                            <th>Grupo de recursos</th>
                            <th>Complejidad</th>
                            <th>Ventana</th>
                            <th class="money-column">Ahorro anual</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in PagedRecommendations)
                        {
                            <tr>
                                <td>
                                    <strong class="recommendation-title">
                                        @item.RecommendationSpanish
                                    </strong>

                                    @if (
                                        !string.IsNullOrWhiteSpace(
                                            item.DescriptionSpanish)
                                    )
                                    {
                                        <div class="recommendation-description">
                                            @item.DescriptionSpanish
                                        </div>
                                    }

                                    <small class="subscription-name">
                                        @item.SubscriptionName
                                    </small>
                                </td>

                                <td>
                                    <span class="category-badge">
                                        @TranslateCategory(
                                            item.AzureCategory)
                                    </span>
                                </td>

                                <td>
                                    <span class="@GetImpactClass(
                                        item.Impact)">
                                        @item.Impact
                                    </span>
                                </td>

                                <td title="@item.AffectedResource">
                                    @Display(item.ResourceName)
                                </td>

                                <td>
                                    @Display(item.ResourceGroup)
                                </td>

                                <td>
                                    @Display(item.Complexity)
                                </td>

                                <td>
                                    @(item.RequiresMaintenanceWindow
                                        ? "Sí"
                                        : "No")
                                </td>

                                <td class="money-column">
                                    @FormatMoney(
                                        item.AnnualSavingsAmount)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <footer class="advisor-pagination">
                <span>
                    Página @EffectivePage de @TotalPages
                </span>

                <div>
                    <button type="button"
                            disabled="@(EffectivePage <= 1)"
                            @onclick="PreviousPage">
                        Anterior
                    </button>

                    <button type="button"
                            disabled="@(EffectivePage >= TotalPages)"
                            @onclick="NextPage">
                        Siguiente
                    </button>
                </div>
            </footer>

        </section>
    }

</section>

@code {
    [Parameter]
    public ClientWorkspaceContext? Context { get; set; }

    private IReadOnlyList<ClientAdvisorRecommendation> Recommendations =
        Array.Empty<ClientAdvisorRecommendation>();

    private IReadOnlyList<ClientAdvisorScore> AdvisorScores =
        Array.Empty<ClientAdvisorScore>();

    private ClientSecurityScore? SecurityScore;

    private bool IsLoading;

    private string? ErrorMessage;

    private Guid? LoadedTenantId;

    private Guid? LoadedSubscriptionId;

    private string SearchText = string.Empty;

    private string SelectedCategory = string.Empty;

    private string SelectedImpact = string.Empty;

    private bool OnlyWithSavings;

    private int CurrentPage = 1;

    private const int PageSize = 25;

    private decimal TotalSavings =>
        Recommendations.Sum(x => x.AnnualSavingsAmount);

    private int RecommendationsWithSavings =>
        Recommendations.Count(x => x.AnnualSavingsAmount > 0);

    private int AffectedResources =>
        Recommendations
            .Where(x => !string.IsNullOrWhiteSpace(x.AffectedResource))
            .Select(x => x.AffectedResource)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();

    private decimal AdvisorGeneralScore =>
        AdvisorScores.Count == 0
            ? 0
            : AdvisorScores.Average(x => x.Score);

    private IReadOnlyList<string> Categories =>
        Recommendations
            .Select(x => x.AzureCategory)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToArray();

    private IReadOnlyList<string> Impacts =>
        Recommendations
            .Select(x => x.Impact)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToArray();

    private IReadOnlyList<ClientAdvisorRecommendation>
        FilteredRecommendations
    {
        get
        {
            IEnumerable<ClientAdvisorRecommendation> query =
                Recommendations;

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                var search = SearchText.Trim();

                query = query.Where(
                    x =>
                        Contains(x.RecommendationSpanish, search) ||
                        Contains(x.DescriptionSpanish, search) ||
                        Contains(x.ResourceName, search) ||
                        Contains(x.ResourceGroup, search) ||
                        Contains(x.SubscriptionName, search));
            }

            if (!string.IsNullOrWhiteSpace(SelectedCategory))
            {
                query = query.Where(
                    x => string.Equals(
                        x.AzureCategory,
                        SelectedCategory,
                        StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(SelectedImpact))
            {
                query = query.Where(
                    x => string.Equals(
                        x.Impact,
                        SelectedImpact,
                        StringComparison.OrdinalIgnoreCase));
            }

            if (OnlyWithSavings)
            {
                query = query.Where(
                    x => x.AnnualSavingsAmount > 0);
            }

            return query.ToArray();
        }
    }

    private int TotalPages =>
        Math.Max(
            1,
            (int)Math.Ceiling(
                FilteredRecommendations.Count /
                (double)PageSize));

    private int EffectivePage =>
        Math.Clamp(CurrentPage, 1, TotalPages);

    private IReadOnlyList<ClientAdvisorRecommendation>
        PagedRecommendations =>
            FilteredRecommendations
                .Skip((EffectivePage - 1) * PageSize)
                .Take(PageSize)
                .ToArray();

    protected override async Task OnParametersSetAsync()
    {
        if (Context?.TenantId is not Guid tenantId)
        {
            ClearData();
            return;
        }

        if (
            LoadedTenantId == tenantId &&
            LoadedSubscriptionId == Context.SubscriptionId
        )
        {
            return;
        }

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        if (Context?.TenantId is not Guid tenantId)
        {
            ClearData();
            return;
        }

        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var recommendationsTask =
                WorkspaceService.GetAdvisorRecommendationsAsync(
                    tenantId,
                    Context.SubscriptionId);

            var advisorScoresTask =
                WorkspaceService.GetAdvisorScoresAsync(
                    tenantId,
                    Context.SubscriptionId);

            var securityScoreTask =
                WorkspaceService.GetSecurityScoreAsync(
                    tenantId,
                    Context.SubscriptionId);

            await Task.WhenAll(
                recommendationsTask,
                advisorScoresTask,
                securityScoreTask);

            Recommendations = await recommendationsTask;
            AdvisorScores = await advisorScoresTask;
            SecurityScore = await securityScoreTask;

            LoadedTenantId = tenantId;
            LoadedSubscriptionId = Context.SubscriptionId;

            CurrentPage = 1;
        }
        catch (Exception ex)
        {
            Recommendations =
                Array.Empty<ClientAdvisorRecommendation>();

            AdvisorScores =
                Array.Empty<ClientAdvisorScore>();

            SecurityScore = null;

            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ClearData()
    {
        Recommendations =
            Array.Empty<ClientAdvisorRecommendation>();

        AdvisorScores =
            Array.Empty<ClientAdvisorScore>();

        SecurityScore = null;

        LoadedTenantId = null;
        LoadedSubscriptionId = null;

        ErrorMessage = null;
        CurrentPage = 1;
    }

    private void PreviousPage()
    {
        CurrentPage = Math.Max(1, EffectivePage - 1);
    }

    private void NextPage()
    {
        CurrentPage = Math.Min(TotalPages, EffectivePage + 1);
    }

    private static bool Contains(string? value, string search)
    {
        return value?.Contains(
            search,
            StringComparison.OrdinalIgnoreCase) == true;
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "-"
            : value;
    }

    private static string FormatMoney(decimal value)
    {
        return value.ToString(
            "C2",
            System.Globalization.CultureInfo
                .GetCultureInfo("en-US"));
    }

    private static string FormatPercent(decimal value)
    {
        return $"{value:N2}%";
    }

    private static string FormatDate(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime().ToString("dd/MM/yyyy")
            : "Sin datos";
    }

    private static string TranslateScore(string scoreName)
    {
        return scoreName switch
        {
            "Cost" => "Costos",
            "HighAvailability" => "Confiabilidad",
            "OperationalExcellence" => "Excelencia operativa",
            "Performance" => "Rendimiento",
            "Security" => "Seguridad",
            _ => scoreName
        };
    }

    private static string TranslateCategory(string category)
    {
        return TranslateScore(category);
    }

    private static string GetWidthStyle(decimal score)
    {
        var width = Math.Clamp(score, 0, 100);

        return
            $"width:{width.ToString(
                "0.##",
                System.Globalization.CultureInfo.InvariantCulture)}%;";
    }

    private static string GetScoreBadgeClass(decimal score)
    {
        if (score >= 80)
        {
            return "score-badge score-good";
        }

        if (score >= 60)
        {
            return "score-badge score-warning";
        }

        return "score-badge score-critical";
    }

    private static string GetImpactClass(string? impact)
    {
        return impact?.Trim().ToUpperInvariant() switch
        {
            "HIGH" => "impact-badge impact-high",
            "MEDIUM" => "impact-badge impact-medium",
            "LOW" => "impact-badge impact-low",
            _ => "impact-badge impact-default"
        };
    }
}
