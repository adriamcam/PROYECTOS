@using ClosedXML.Excel
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Models
@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Services
@inject IAdvisorCatalogService AdvisorCatalogService
@inject IJSRuntime JS

<div class="advisor-catalog">
    <div class="catalog-header">
        <div>
            <span class="eyebrow">OPTIMIZACIÓN, CONFIABILIDAD Y SEGURIDAD</span>
            <h2>Configuración Advisor</h2>
            <p>Edición del catálogo de recomendaciones, traducciones, complejidad y tiempo estimado.</p>
        </div>

        <div class="toolbar">
            <button type="button" class="toolbar-button" @onclick="OpenNew">
                <span>＋</span> Nueva
            </button>

            <label class="toolbar-button file-button">
                <span>📥</span> Importar Excel
                <InputFile class="file-input" OnChange="ReadExcelAsync" accept=".xlsx" />
            </label>

            <button type="button" class="toolbar-button" @onclick="DownloadTemplateAsync">
                <span>📄</span> Descargar plantilla
            </button>

            <button type="button" class="toolbar-button" @onclick="ExportCatalogAsync">
                <span>📤</span> Exportar catálogo
            </button>

            @if (SelectedIds.Count > 0)
            {
                <button type="button" class="toolbar-button danger" @onclick="OpenDeleteModal">
                    <span>🗑</span> Eliminar seleccionadas (@SelectedIds.Count)
                </button>
            }

            <button type="button" class="toolbar-button primary" @onclick="LoadAsync" disabled="@IsLoading">
                <span>↻</span> @(IsLoading ? "Cargando..." : "Actualizar")
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(PageMessage))
    {
        <div class="@PageMessageClass">
            <span>@PageMessage</span>
            <button type="button" class="message-close" @onclick="ClearMessage">✕</button>
        </div>
    }

    <div class="catalog-kpis">
        <div><span>Total</span><strong>@Items.Count</strong></div>
        <div><span>Activos</span><strong>@Items.Count(x => x.IsActive)</strong></div>
        <div><span>Sin complejidad</span><strong>@Items.Count(x => string.IsNullOrWhiteSpace(x.Complexity))</strong></div>
        <div><span>Sin tiempo</span><strong>@Items.Count(x => x.ImplementationMinutes <= 0)</strong></div>
    </div>

    <div class="catalog-filters">
        <input type="search"
               value="@SearchText"
               @oninput="OnSearchInput"
               placeholder="Buscar por ID, recomendación, traducción, descripción, complejidad, costo o notas..." />

        <select @bind="ComplexityFilter" @bind:after="ResetPage">
            <option value="">Todas las complejidades</option>
            <option value="Baja">Baja</option>
            <option value="Media">Media</option>
            <option value="Alta">Alta</option>
        </select>

        <select @bind="StatusFilter" @bind:after="ResetPage">
            <option value="">Todos los estados</option>
            <option value="active">Activos</option>
            <option value="inactive">Inactivos</option>
        </select>

        <select @bind="PageSize">
            <option value="10">10 por página</option>
            <option value="20">20 por página</option>
            <option value="50">50 por página</option>
            <option value="100">100 por página</option>
        </select>
    </div>

    @if (IsLoading)
    {
        <div class="catalog-state">Cargando catálogo...</div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th class="selection-column">
                            <input type="checkbox"
                                   checked="@AreAllVisibleSelected"
                                   @onchange="ToggleAllVisible" 
                                   title="Seleccionar todos los registros visibles" />
                        </th>
                        <th><button type="button" class="sort-header" @onclick='() => SortBy("id")'>ID @GetSortIcon("id")</button></th>
                        <th><button type="button" class="sort-header" @onclick='() => SortBy("recommendation")'>Recomendación original @GetSortIcon("recommendation")</button></th>
                        <th><button type="button" class="sort-header" @onclick='() => SortBy("translation")'>Traducción / descripción @GetSortIcon("translation")</button></th>
                        <th><button type="button" class="sort-header" @onclick='() => SortBy("complexity")'>Complejidad @GetSortIcon("complexity")</button></th>
                        <th><button type="button" class="sort-header" @onclick='() => SortBy("hours")'>Horas @GetSortIcon("hours")</button></th>
                        <th><button type="button" class="sort-header" @onclick='() => SortBy("minutes")'>Minutos @GetSortIcon("minutes")</button></th>
                        <th><button type="button" class="sort-header" @onclick='() => SortBy("cost")'>Costo @GetSortIcon("cost")</button></th>
                        <th><button type="button" class="sort-header" @onclick='() => SortBy("window")'>Ventana @GetSortIcon("window")</button></th>
                        <th><button type="button" class="sort-header" @onclick='() => SortBy("active")'>Activo @GetSortIcon("active")</button></th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (PagedItems.Count == 0)
                    {
                        <tr><td colspan="11" class="empty-row">No se encontraron recomendaciones.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in PagedItems)
                        {
                            <tr class="@(SelectedIds.Contains(item.Id) ? "selected-row" : string.Empty)">
                                <td class="selection-column">
                                    <input type="checkbox"
                                           checked="@SelectedIds.Contains(item.Id)"
                                           @onchange="args => ToggleItem(item.Id, args)" />
                                </td>
                                <td>@item.Id</td>
                                <td class="original-cell">
                                    <strong>@item.Recommendation</strong>
                                    <small>@item.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                                </td>
                                <td>
                                    @if (item.IsEditing)
                                    {
                                        <textarea rows="3" @bind="item.RecommendationSpanish"></textarea>
                                        <textarea rows="3" placeholder="Descripción" @bind="item.DescriptionSpanish"></textarea>
                                        <textarea rows="2" placeholder="Notas" @bind="item.Notes"></textarea>
                                    }
                                    else
                                    {
                                        <strong>@item.RecommendationSpanish</strong>
                                        <p>@item.DescriptionSpanish</p>
                                        <small>@item.Notes</small>
                                    }
                                </td>
                                <td>
                                    @if (item.IsEditing)
                                    {
                                        <select @bind="item.Complexity">
                                            <option value="">Sin definir</option>
                                            <option value="Baja">Baja</option>
                                            <option value="Media">Media</option>
                                            <option value="Alta">Alta</option>
                                        </select>
                                    }
                                    else
                                    {
                                        @TextOrDash(item.Complexity)
                                    }
                                </td>
                                <td>@(item.ImplementationHours?.ToString("N2") ?? "0.00")</td>
                                <td>
                                    @if (item.IsEditing)
                                    {
                                        <input type="number" min="0" @bind="item.ImplementationMinutes" />
                                    }
                                    else
                                    {
                                        @item.ImplementationMinutes
                                    }
                                </td>
                                <td>
                                    @if (item.IsEditing)
                                    {
                                        <select @bind="item.CostClassification">
                                            <option value="Por validar">Por validar</option>
                                            <option value="Con costo">Con costo</option>
                                            <option value="Sin costo">Sin costo</option>
                                            <option value="Mixto">Mixto</option>
                                        </select>
                                    }
                                    else
                                    {
                                        @item.CostClassification
                                    }
                                </td>
                                <td><input type="checkbox" @bind="item.RequiresMaintenanceWindow" disabled="@(!item.IsEditing)" /></td>
                                <td><input type="checkbox" @bind="item.IsActive" disabled="@(!item.IsEditing)" /></td>
                                <td class="actions">
                                    @if (item.IsEditing)
                                    {
                                        <button type="button" class="save-button" @onclick="() => SaveAsync(item)" disabled="@item.IsSaving">
                                            @(item.IsSaving ? "Guardando..." : "Guardar")
                                        </button>
                                        <button type="button" @onclick="() => Cancel(item)" disabled="@item.IsSaving">Cancelar</button>
                                    }
                                    else
                                    {
                                        <button type="button" @onclick="() => Edit(item)">Editar</button>
                                    }
                                    <small>@item.StatusMessage</small>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination">
            <span>Mostrando @FirstRecord-@LastRecord de @Filtered.Count</span>
            <div>
                <button type="button" @onclick="Previous" disabled="@(CurrentPage <= 1)">Anterior</button>
                <strong>Página @CurrentPage de @TotalPages</strong>
                <button type="button" @onclick="Next" disabled="@(CurrentPage >= TotalPages)">Siguiente</button>
            </div>
        </div>
    }
</div>

@if (ShowNewModal)
{
    <div class="modal-backdrop" @onclick="CloseNew">
        <div class="modal-panel medium" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div><span class="eyebrow">CATÁLOGO ADVISOR</span><h3>Nueva recomendación</h3></div>
                <button type="button" class="icon-button" @onclick="CloseNew">✕</button>
            </div>

            <div class="modal-body form-grid">
                <label class="full">Recomendación original *<textarea rows="3" @bind="NewItem.Recommendation"></textarea></label>
                <label class="full">Traducción *<textarea rows="3" @bind="NewItem.RecommendationSpanish"></textarea></label>
                <label class="full">Descripción<textarea rows="3" @bind="NewItem.DescriptionSpanish"></textarea></label>
                <label>Categoría<input @bind="NewItem.Category" /></label>
                <label>Complejidad
                    <select @bind="NewItem.Complexity"><option value="">Sin definir</option><option>Baja</option><option>Media</option><option>Alta</option></select>
                </label>
                <label>Minutos<input type="number" min="0" @bind="NewItem.ImplementationMinutes" /></label>
                <label>Costo
                    <select @bind="NewItem.CostClassification"><option>Por validar</option><option>Con costo</option><option>Sin costo</option><option>Mixto</option></select>
                </label>
                <label class="check-label"><input type="checkbox" @bind="NewItem.RequiresMaintenanceWindow" /> Requiere ventana</label>
                <label class="check-label"><input type="checkbox" @bind="NewItem.IsActive" /> Activa</label>
                <label class="full">Notas<textarea rows="2" @bind="NewItem.Notes"></textarea></label>
            </div>

            <div class="modal-footer">
                <button type="button" @onclick="CloseNew" disabled="@IsCreating">Cancelar</button>
                <button type="button" class="primary-button" @onclick="CreateAsync" disabled="@IsCreating">
                    @(IsCreating ? "Guardando..." : "Guardar recomendación")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowImportModal)
{
    <div class="modal-backdrop" @onclick="CloseImport">
        <div class="modal-panel wide" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <span class="eyebrow">IMPORTACIÓN CONTROLADA</span>
                    <h3>Importar catálogo desde Excel</h3>
                    <p>@SelectedExcelFileName</p>
                </div>
                <button type="button" class="icon-button" @onclick="CloseImport">✕</button>
            </div>

            <div class="modal-body">
                @if (IsReadingExcel)
                {
                    <div class="catalog-state">Leyendo y validando el archivo...</div>
                }
                else if (ImportPreview is not null)
                {
                    <div class="import-kpis">
                        <div class="new"><span>Nuevos</span><strong>@ImportPreview.NewCount</strong></div>
                        <div class="update"><span>Actualizar</span><strong>@ImportPreview.UpdateCount</strong></div>
                        <div><span>Sin cambios</span><strong>@ImportPreview.UnchangedCount</strong></div>
                        <div class="error"><span>Errores</span><strong>@ImportPreview.ErrorCount</strong></div>
                    </div>

                    <div class="import-table-wrapper">
                        <table class="import-table">
                            <thead><tr><th>Estado</th><th>Fila</th><th>Recomendación</th><th>Traducción</th><th>Complejidad</th><th>Minutos</th><th>Resultado</th></tr></thead>
                            <tbody>
                                @foreach (var row in ImportPreview.Rows)
                                {
                                    <tr>
                                        <td><span class="status-pill @GetImportStatusClass(row)">@row.Action</span></td>
                                        <td>@row.ExcelRowNumber</td>
                                        <td>@row.Recommendation</td>
                                        <td>@row.RecommendationSpanish</td>
                                        <td>@TextOrDash(row.Complexity)</td>
                                        <td>@row.ImplementationMinutes</td>
                                        <td>@(row.IsValid ? GetImportResultText(row.Action) : row.ValidationMessage)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="modal-footer spaced">
                <div class="modal-secondary-actions">
                    <label class="secondary-button file-button">Cambiar archivo<InputFile class="file-input" OnChange="ReadExcelAsync" accept=".xlsx" /></label>
                    <button type="button" @onclick="DownloadTemplateAsync">Descargar plantilla</button>
                </div>
                <div>
                    <button type="button" @onclick="CloseImport" disabled="@IsImporting">Cancelar</button>
                    <button type="button" class="primary-button" @onclick="ConfirmImportAsync" disabled="@(!CanConfirmImport)">
                        @(IsImporting ? "Importando..." : $"Confirmar importación ({ImportPreview?.ValidChangeCount ?? 0})")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowDeleteModal)
{
    <div class="modal-backdrop" @onclick="CloseDeleteModal">
        <div class="modal-panel small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div><span class="eyebrow danger-text">ACCIÓN DESTRUCTIVA</span><h3>Eliminar recomendaciones</h3></div>
                <button type="button" class="icon-button" @onclick="CloseDeleteModal">✕</button>
            </div>
            <div class="modal-body">
                <p>Se eliminarán permanentemente <strong>@SelectedIds.Count</strong> recomendaciones.</p>
                <div class="delete-preview">
                    @foreach (var item in SelectedItems.Take(10))
                    {
                        <div><strong>#@item.Id</strong><span>@item.Recommendation</span></div>
                    }
                    @if (SelectedIds.Count > 10)
                    {
                        <small>Y @(SelectedIds.Count - 10) registros adicionales...</small>
                    }
                </div>
                <p class="warning-text">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button type="button" @onclick="CloseDeleteModal" disabled="@IsDeleting">Cancelar</button>
                <button type="button" class="danger-button" @onclick="DeleteSelectedAsync" disabled="@IsDeleting">
                    @(IsDeleting ? "Eliminando..." : $"Eliminar {SelectedIds.Count} registros")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<AdvisorCatalogItem> Items { get; set; } = new();
    private Dictionary<int, AdvisorCatalogItem> Backups { get; } = new();
    private HashSet<int> SelectedIds { get; } = new();

    private string SearchText { get; set; } = string.Empty;
    private string ComplexityFilter { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = string.Empty;
    private string PageMessage { get; set; } = string.Empty;
    private bool PageMessageIsError { get; set; }
    private bool IsLoading { get; set; }

    private int CurrentPage { get; set; } = 1;
    private int _pageSize = 20;
    private string SortColumn { get; set; } = "active";
    private bool SortAscending { get; set; }

    private bool ShowNewModal { get; set; }
    private bool IsCreating { get; set; }
    private AdvisorCatalogItem NewItem { get; set; } = NewCatalogItem();

    private bool ShowImportModal { get; set; }
    private bool IsReadingExcel { get; set; }
    private bool IsImporting { get; set; }
    private string SelectedExcelFileName { get; set; } = string.Empty;
    private AdvisorCatalogImportPreview? ImportPreview { get; set; }

    private bool ShowDeleteModal { get; set; }
    private bool IsDeleting { get; set; }

    private int PageSize
    {
        get => _pageSize;
        set { _pageSize = value; CurrentPage = 1; }
    }

    private string PageMessageClass => PageMessageIsError ? "message error" : "message success";

    private List<AdvisorCatalogItem> Filtered
    {
        get
        {
            IEnumerable<AdvisorCatalogItem> query = Items;

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                var search = SearchText.Trim();
                query = query.Where(x =>
                    x.Id.ToString().Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    Has(x.Recommendation, search) ||
                    Has(x.RecommendationSpanish, search) ||
                    Has(x.DescriptionSpanish, search) ||
                    Has(x.Category, search) ||
                    Has(x.Complexity, search) ||
                    Has(x.CostClassification, search) ||
                    Has(x.Notes, search) ||
                    x.ImplementationMinutes.ToString().Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    (x.ImplementationHours?.ToString("0.##")?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.IsActive && Has("activo", search)) ||
                    (!x.IsActive && Has("inactivo", search)));
            }

            if (!string.IsNullOrWhiteSpace(ComplexityFilter))
                query = query.Where(x => string.Equals(x.Complexity, ComplexityFilter, StringComparison.OrdinalIgnoreCase));

            query = StatusFilter switch
            {
                "active" => query.Where(x => x.IsActive),
                "inactive" => query.Where(x => !x.IsActive),
                _ => query
            };

            query = SortColumn switch
            {
                "id" => SortAscending ? query.OrderBy(x => x.Id) : query.OrderByDescending(x => x.Id),
                "recommendation" => SortAscending ? query.OrderBy(x => x.Recommendation) : query.OrderByDescending(x => x.Recommendation),
                "translation" => SortAscending ? query.OrderBy(x => x.RecommendationSpanish) : query.OrderByDescending(x => x.RecommendationSpanish),
                "complexity" => SortAscending ? query.OrderBy(x => ComplexityOrder(x.Complexity)) : query.OrderByDescending(x => ComplexityOrder(x.Complexity)),
                "hours" => SortAscending ? query.OrderBy(x => x.ImplementationHours ?? 0) : query.OrderByDescending(x => x.ImplementationHours ?? 0),
                "minutes" => SortAscending ? query.OrderBy(x => x.ImplementationMinutes) : query.OrderByDescending(x => x.ImplementationMinutes),
                "cost" => SortAscending ? query.OrderBy(x => x.CostClassification) : query.OrderByDescending(x => x.CostClassification),
                "window" => SortAscending ? query.OrderBy(x => x.RequiresMaintenanceWindow) : query.OrderByDescending(x => x.RequiresMaintenanceWindow),
                "active" => SortAscending ? query.OrderBy(x => x.IsActive) : query.OrderByDescending(x => x.IsActive),
                _ => query.OrderByDescending(x => x.IsActive).ThenBy(x => x.RecommendationSpanish)
            };

            return query.ToList();
        }
    }

    private List<AdvisorCatalogItem> PagedItems
    {
        get
        {
            ValidatePage();
            return Filtered.Skip((CurrentPage - 1) * PageSize).Take(PageSize).ToList();
        }
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count / (double)PageSize));
    private int FirstRecord => Filtered.Count == 0 ? 0 : ((CurrentPage - 1) * PageSize) + 1;
    private int LastRecord => Math.Min(CurrentPage * PageSize, Filtered.Count);
    private bool AreAllVisibleSelected => PagedItems.Count > 0 && PagedItems.All(x => SelectedIds.Contains(x.Id));
    private IEnumerable<AdvisorCatalogItem> SelectedItems => Items.Where(x => SelectedIds.Contains(x.Id));
    private bool CanConfirmImport => !IsReadingExcel && !IsImporting && ImportPreview is { ValidChangeCount: > 0 };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        IsLoading = true;
        try
        {
            Items = (await AdvisorCatalogService.GetAllAsync()).ToList();
            Backups.Clear();
            SelectedIds.Clear();
            CurrentPage = 1;
        }
        catch (Exception ex) { SetMessage($"No fue posible cargar el catálogo: {ex.Message}", true); }
        finally { IsLoading = false; }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchText = e.Value?.ToString() ?? string.Empty;
        CurrentPage = 1;
    }

    private void ResetPage() => CurrentPage = 1;

    private void Edit(AdvisorCatalogItem item)
    {
        Backups[item.Id] = item.Clone();
        item.IsEditing = true;
        item.StatusMessage = string.Empty;
    }

    private void Cancel(AdvisorCatalogItem item)
    {
        if (Backups.TryGetValue(item.Id, out var backup))
        {
            CopyValues(backup, item);
            item.RowVersion = backup.RowVersion.ToArray();
            item.UpdatedAt = backup.UpdatedAt;
        }
        item.IsEditing = false;
        item.IsSaving = false;
        item.StatusMessage = string.Empty;
        Backups.Remove(item.Id);
    }

    private async Task SaveAsync(AdvisorCatalogItem item)
    {
        if (string.IsNullOrWhiteSpace(item.RecommendationSpanish))
        {
            item.StatusMessage = "La traducción es obligatoria.";
            return;
        }

        item.IsSaving = true;
        try
        {
            var result = await AdvisorCatalogService.UpdateAsync(item);
            item.StatusMessage = result.Message;
            if (!result.Success) return;
            item.RowVersion = result.RowVersion;
            item.UpdatedAt = result.UpdatedAt;
            item.IsEditing = false;
            Backups.Remove(item.Id);
            SetMessage($"Registro {item.Id} actualizado.", false);
        }
        catch (Exception ex) { item.StatusMessage = ex.Message; }
        finally { item.IsSaving = false; }
    }

    private void OpenNew()
    {
        NewItem = NewCatalogItem();
        ShowNewModal = true;
    }

    private void CloseNew()
    {
        if (!IsCreating) ShowNewModal = false;
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(NewItem.Recommendation) || string.IsNullOrWhiteSpace(NewItem.RecommendationSpanish))
        {
            SetMessage("Recomendación original y traducción son obligatorias.", true);
            return;
        }

        IsCreating = true;
        try
        {
            var result = await AdvisorCatalogService.CreateAsync(NewItem);
            SetMessage(result.Message, !result.Success);
            if (result.Success)
            {
                ShowNewModal = false;
                await LoadAsync();
            }
        }
        catch (Exception ex) { SetMessage($"No fue posible crear la recomendación: {ex.Message}", true); }
        finally { IsCreating = false; }
    }

    private async Task ReadExcelAsync(InputFileChangeEventArgs e)
    {
        ShowImportModal = true;
        IsReadingExcel = true;
        ImportPreview = null;
        SelectedExcelFileName = e.File.Name;

        try
        {
            await using var uploadStream = e.File.OpenReadStream(20 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await uploadStream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            using var workbook = new XLWorkbook(memoryStream);
            var ws = workbook.Worksheets.FirstOrDefault()
                ?? throw new InvalidOperationException("El libro no contiene hojas.");

            var headerCells = ws.Row(1).CellsUsed().ToList();
            var headers = headerCells.ToDictionary(
                c => c.GetString().Trim(),
                c => c.Address.ColumnNumber,
                StringComparer.OrdinalIgnoreCase);

            string[] required = ["Recommendation", "RecommendationSpanish"];
            var missing = required.Where(x => !headers.ContainsKey(x)).ToArray();
            if (missing.Length > 0)
                throw new InvalidOperationException($"Faltan columnas obligatorias: {string.Join(", ", missing)}");

            var rows = new List<AdvisorCatalogImportRow>();
            foreach (var row in ws.RowsUsed().Skip(1))
            {
                if (row.IsEmpty()) continue;

                string S(string name) => headers.TryGetValue(name, out var col)
                    ? row.Cell(col).GetFormattedString().Trim()
                    : string.Empty;

                bool B(string name, bool defaultValue = false)
                {
                    var value = S(name);
                    if (string.IsNullOrWhiteSpace(value)) return defaultValue;
                    return value.Equals("true", StringComparison.OrdinalIgnoreCase)
                        || value.Equals("sí", StringComparison.OrdinalIgnoreCase)
                        || value.Equals("si", StringComparison.OrdinalIgnoreCase)
                        || value.Equals("yes", StringComparison.OrdinalIgnoreCase)
                        || value == "1";
                }

                int I(string name)
                {
                    if (!headers.TryGetValue(name, out var col)) return 0;
                    var cell = row.Cell(col);
                    return cell.TryGetValue<int>(out var number)
                        ? number
                        : int.TryParse(cell.GetFormattedString(), out number) ? number : 0;
                }

                rows.Add(new AdvisorCatalogImportRow
                {
                    ExcelRowNumber = row.RowNumber(),
                    Recommendation = S("Recommendation"),
                    RecommendationSpanish = S("RecommendationSpanish"),
                    DescriptionSpanish = EmptyToNull(S("DescriptionSpanish")),
                    Complexity = EmptyToNull(S("Complexity")),
                    ImplementationMinutes = I("ImplementationMinutes"),
                    CostClassification = string.IsNullOrWhiteSpace(S("CostClassification")) ? "Por validar" : S("CostClassification"),
                    RequiresMaintenanceWindow = B("RequiresMaintenanceWindow"),
                    Category = EmptyToNull(S("Category")),
                    IsActive = B("IsActive", true),
                    Notes = EmptyToNull(S("Notes"))
                });
            }

            ImportPreview = await AdvisorCatalogService.PreviewImportAsync(rows);
        }
        catch (Exception ex)
        {
            SetMessage($"No fue posible leer el Excel: {ex.Message}", true);
            ShowImportModal = false;
        }
        finally { IsReadingExcel = false; }
    }

    private async Task ConfirmImportAsync()
    {
        if (ImportPreview is null || ImportPreview.ValidChangeCount == 0) return;

        IsImporting = true;
        try
        {
            var result = await AdvisorCatalogService.ImportAsync(ImportPreview.Rows);
            SetMessage($"{result.Message} Nuevos: {result.Inserted}, actualizados: {result.Updated}, sin cambios: {result.Unchanged}, errores: {result.Errors}.", !result.Success);
            if (result.Success)
            {
                CloseImport(force: true);
                await LoadAsync();
            }
        }
        catch (Exception ex) { SetMessage($"La importación falló: {ex.Message}", true); }
        finally { IsImporting = false; }
    }

    private void CloseImport(bool force = false)
    {
        if (IsImporting && !force) return;
        ShowImportModal = false;
        ImportPreview = null;
        SelectedExcelFileName = string.Empty;
    }

    private void ToggleItem(int id, ChangeEventArgs args)
    {
        var selected = args.Value is bool value && value;
        if (selected) SelectedIds.Add(id); else SelectedIds.Remove(id);
    }

    private void ToggleAllVisible(ChangeEventArgs args)
    {
        var selected = args.Value is bool value && value;
        foreach (var item in PagedItems)
        {
            if (selected) SelectedIds.Add(item.Id); else SelectedIds.Remove(item.Id);
        }
    }

    private void OpenDeleteModal()
    {
        if (SelectedIds.Count > 0) ShowDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        if (!IsDeleting) ShowDeleteModal = false;
    }

    private async Task DeleteSelectedAsync()
    {
        if (SelectedIds.Count == 0) return;
        IsDeleting = true;
        try
        {
            var result = await AdvisorCatalogService.DeleteManyAsync(SelectedIds.ToArray());
            SetMessage(result.Message, !result.Success);
            if (result.Success)
            {
                ShowDeleteModal = false;
                await LoadAsync();
            }
        }
        catch (Exception ex) { SetMessage($"No fue posible eliminar: {ex.Message}", true); }
        finally { IsDeleting = false; }
    }

    private async Task DownloadTemplateAsync()
    {
        using var workbook = new XLWorkbook();
        var ws = workbook.AddWorksheet("Catalogo");
        string[] headers = ["Recommendation", "RecommendationSpanish", "DescriptionSpanish", "Complexity", "ImplementationMinutes", "CostClassification", "RequiresMaintenanceWindow", "Category", "IsActive", "Notes"];
        for (var i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
        ws.Cell(2, 1).Value = "Recommendation example";
        ws.Cell(2, 2).Value = "Recomendación de ejemplo";
        ws.Cell(2, 4).Value = "Baja";
        ws.Cell(2, 5).Value = 30;
        ws.Cell(2, 6).Value = "Mixto";
        ws.Cell(2, 7).Value = false;
        ws.Cell(2, 9).Value = true;
        ws.Row(1).Style.Font.Bold = true;
        ws.SheetView.FreezeRows(1);
        ws.Columns().AdjustToContents();
        await DownloadWorkbookAsync(workbook, "Plantilla-AdvisorCatalog.xlsx");
    }

    private async Task ExportCatalogAsync()
    {
        using var workbook = new XLWorkbook();
        var ws = workbook.AddWorksheet("Catalogo");
        string[] headers = ["Id", "Recommendation", "RecommendationSpanish", "DescriptionSpanish", "Complexity", "ImplementationHours", "ImplementationMinutes", "CostClassification", "RequiresMaintenanceWindow", "Category", "IsActive", "Notes", "UpdatedAt"];
        for (var i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];

        var row = 2;
        foreach (var item in Filtered)
        {
            ws.Cell(row, 1).Value = item.Id;
            ws.Cell(row, 2).Value = item.Recommendation;
            ws.Cell(row, 3).Value = item.RecommendationSpanish;
            ws.Cell(row, 4).Value = item.DescriptionSpanish;
            ws.Cell(row, 5).Value = item.Complexity;
            ws.Cell(row, 6).Value = item.ImplementationHours;
            ws.Cell(row, 7).Value = item.ImplementationMinutes;
            ws.Cell(row, 8).Value = item.CostClassification;
            ws.Cell(row, 9).Value = item.RequiresMaintenanceWindow;
            ws.Cell(row, 10).Value = item.Category;
            ws.Cell(row, 11).Value = item.IsActive;
            ws.Cell(row, 12).Value = item.Notes;
            ws.Cell(row, 13).Value = item.UpdatedAt;
            row++;
        }

        ws.Row(1).Style.Font.Bold = true;
        ws.SheetView.FreezeRows(1);
        ws.Columns().AdjustToContents();
        await DownloadWorkbookAsync(workbook, $"AdvisorCatalog-{DateTime.Now:yyyyMMdd-HHmm}.xlsx");
    }

    private async Task DownloadWorkbookAsync(XLWorkbook workbook, string fileName)
    {
        using var memoryStream = new MemoryStream();
        workbook.SaveAs(memoryStream);
        using var streamReference = new DotNetStreamReference(new MemoryStream(memoryStream.ToArray()));
        await JS.InvokeVoidAsync("advisorCatalogDownload", fileName, streamReference);
    }

    private void SortBy(string column)
    {
        if (string.Equals(SortColumn, column, StringComparison.OrdinalIgnoreCase)) SortAscending = !SortAscending;
        else { SortColumn = column; SortAscending = true; }
        CurrentPage = 1;
    }

    private string GetSortIcon(string column) =>
        !string.Equals(SortColumn, column, StringComparison.OrdinalIgnoreCase) ? "↕" : SortAscending ? "▲" : "▼";

    private static int ComplexityOrder(string? complexity) => complexity?.Trim().ToUpperInvariant() switch
    {
        "BAJA" => 1,
        "MEDIA" => 2,
        "ALTA" => 3,
        _ => 4
    };

    private void Previous() { if (CurrentPage > 1) CurrentPage--; }
    private void Next() { if (CurrentPage < TotalPages) CurrentPage++; }
    private void ValidatePage() => CurrentPage = Math.Clamp(CurrentPage, 1, TotalPages);
    private void SetMessage(string value, bool error) { PageMessage = value; PageMessageIsError = error; }
    private void ClearMessage() => PageMessage = string.Empty;

    private static bool Has(string? value, string search) =>
        !string.IsNullOrWhiteSpace(value) && value.Contains(search, StringComparison.OrdinalIgnoreCase);

    private static string TextOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
    private static string? EmptyToNull(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    private static string GetImportStatusClass(AdvisorCatalogImportRow row) => row.IsValid ? row.Action.ToLowerInvariant().Replace(" ", "-") : "error";
    private static string GetImportResultText(string action) => action switch { "Nuevo" => "Se insertará", "Actualizar" => "Se actualizará", _ => "No se modificará" };

