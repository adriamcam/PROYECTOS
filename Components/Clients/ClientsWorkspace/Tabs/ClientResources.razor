@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Models.Infrastructure
@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Services.Infrastructure

@inject AzureInventoryCatalogService InventoryCatalogService

<section class="resources-workspace">

    @if (string.IsNullOrWhiteSpace(_selectedModuleKey))
    {
        <header class="resources-header">
            <span class="resources-eyebrow">INVENTARIO DE AZURE</span>

            <h2>Recursos</h2>

            <p>
                Seleccione un servicio para consultar su inventario.
                Solo se mostrarán servicios disponibles para el cliente
                y la suscripción seleccionados.
            </p>
        </header>

        @if (_isLoading)
        {
            <div class="resources-message">
                Cargando servicios disponibles...
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="resources-message error">
                @_errorMessage
            </div>
        }
        else
        {
            @foreach (var category in
                _modules.GroupBy(module => module.Category))
            {
                <section class="resource-category">
                    <h3>@category.Key</h3>

                    <div class="resources-grid">
                        @foreach (var module in category)
                        {
                            <button type="button"
                                    class="azure-resource-card"
                                    @onclick="() => OpenModule(module.Key)">

                                <span class="azure-resource-icon">
                                    @module.Icon
                                </span>

                                <span class="azure-resource-content">
                                    <span class="azure-resource-title">
                                        @module.DisplayName
                                    </span>

                                    <span class="azure-resource-description">
                                        @module.Description
                                    </span>

                                    <span class="azure-resource-count">
                                        @module.ResourceCount recursos
                                    </span>
                                </span>

                                <span class="azure-resource-arrow">
                                    →
                                </span>

                            </button>
                        }
                    </div>
                </section>
            }
        }
    }
    else
    {
        <section class="resource-detail">

            <button type="button"
                    class="resource-back-button"
                    @onclick="BackToResources">
                <span>←</span>
                <span>Volver a recursos</span>
            </button>

            @if (_selectedModuleKey == "virtual-machines")
            {
                <ClientVirtualMachines
                    CustomerName="@CustomerName"
                    SubscriptionId="@SubscriptionId" />
            }
            else
            {
                <ClientGenericInventory
                    ModuleKey="@_selectedModuleKey"
                    CustomerName="@CustomerName"
                    SubscriptionId="@SubscriptionId" />
            }

        </section>
    }

</section>

<style>
    .resources-workspace {
        display: flex;
        width: 100%;
        flex-direction: column;
        gap: 22px;
    }

    .resources-header {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .resources-eyebrow {
        margin-bottom: 8px;
        color: #2563eb;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .09em;
    }

    .resources-header h2 {
        margin: 0 0 8px;
        color: #101828;
        font-size: 24px;
    }

    .resources-header p {
        max-width: 760px;
        margin: 0;
        color: #667085;
        font-size: 13px;
        line-height: 1.55;
    }

    .resource-category {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .resource-category h3 {
        margin: 0;
        color: #344054;
        font-size: 14px;
    }

    .resources-grid {
        display: grid;
        width: 100%;
        grid-template-columns: repeat(auto-fill, minmax(285px, 340px));
        gap: 16px;
    }

    .azure-resource-card {
        display: grid;
        grid-template-columns: 54px minmax(0, 1fr) 24px;
        align-items: center;
        gap: 14px;
        width: 100%;
        min-height: 112px;
        padding: 18px;
        border: 1px solid #dfe5ee;
        border-radius: 12px;
        background: #ffffff;
        color: inherit;
        font-family: inherit;
        text-align: left;
        cursor: pointer;
        box-shadow: 0 1px 3px rgba(16, 24, 40, .04);
        transition: .15s ease;
    }

    .azure-resource-card:hover {
        transform: translateY(-2px);
        border-color: #84a9f5;
        box-shadow: 0 9px 25px rgba(16, 24, 40, .09);
    }

    .azure-resource-icon {
        display: flex;
        width: 54px;
        height: 54px;
        align-items: center;
        justify-content: center;
        border-radius: 13px;
        background: #eef4ff;
        font-size: 27px;
    }

    .azure-resource-content {
        display: flex;
        min-width: 0;
        flex-direction: column;
        gap: 5px;
    }

    .azure-resource-title {
        color: #101828;
        font-size: 15px;
        font-weight: 700;
    }

    .azure-resource-description {
        color: #667085;
        font-size: 11px;
        line-height: 1.4;
    }

    .azure-resource-count {
        color: #2563eb;
        font-size: 10px;
        font-weight: 700;
    }

    .azure-resource-arrow {
        color: #2563eb;
        font-size: 22px;
        font-weight: 700;
    }

    .resource-detail {
        display: flex;
        width: 100%;
        flex-direction: column;
        gap: 16px;
    }

    .resource-back-button {
        display: inline-flex;
        width: fit-content;
        min-height: 36px;
        align-items: center;
        gap: 7px;
        padding: 7px 12px;
        border: 1px solid #d7deea;
        border-radius: 8px;
        background: #ffffff;
        color: #344054;
        font-family: inherit;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
    }

    .resources-message {
        padding: 30px;
        border: 1px dashed #cfd8e6;
        border-radius: 12px;
        text-align: center;
    }

    .resources-message.error {
        color: #b42318;
    }
</style>

@code {
    [Parameter]
    public string CustomerName { get; set; } = string.Empty;

    [Parameter]
    public string SubscriptionId { get; set; } = string.Empty;

    private List<AzureInventoryModule> _modules = [];

    private string _selectedModuleKey = string.Empty;

    private bool _isLoading;

    private string _errorMessage = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        _selectedModuleKey = string.Empty;

        await LoadModulesAsync();
    }

    private async Task LoadModulesAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = string.Empty;

            _modules =
                (await InventoryCatalogService.GetAvailableModulesAsync(
                    SubscriptionId))
                .ToList();
        }
        catch (Exception ex)
        {
            _errorMessage =
                $"No fue posible cargar los servicios: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenModule(string moduleKey)
    {
        _selectedModuleKey = moduleKey;
    }

    private void BackToResources()
    {
        _selectedModuleKey = string.Empty;
    }
}
