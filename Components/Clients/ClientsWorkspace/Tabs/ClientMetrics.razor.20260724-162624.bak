@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Components.Metrics
@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Models.Metrics
@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Services.Metrics

@inject AzureMetricsCatalogService MetricsCatalogService

<section class="metrics-workspace">

    @if (string.IsNullOrWhiteSpace(CustomerName) ||
         string.IsNullOrWhiteSpace(SubscriptionId))
    {
        <div class="metrics-empty-state">
            <div class="metrics-empty-icon">📊</div>

            <h2>Métricas</h2>

            <p>
                Seleccione un cliente y una suscripción para consultar
                las métricas de los recursos Azure.
            </p>
        </div>
    }
    else if (_isLoading)
    {
        <div class="metrics-empty-state">
            <div class="metrics-empty-icon">⏳</div>

            <h2>Cargando métricas</h2>

            <p>
                Consultando los tipos de recursos disponibles para
                la suscripción seleccionada.
            </p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="metrics-empty-state">
            <div class="metrics-empty-icon">⚠️</div>

            <h2>No fue posible cargar las métricas</h2>

            <p>@_errorMessage</p>

            <button type="button"
                    class="metrics-back-button"
                    @onclick="LoadModulesAsync">
                Reintentar
            </button>
        </div>
    }
    else if (string.IsNullOrWhiteSpace(_selectedModuleKey))
    {
        <header class="metrics-header">
            <div>
                <span class="metrics-eyebrow">
                    MONITOREO Y RENDIMIENTO
                </span>

                <h2>Métricas Azure</h2>

                <p>
                    Los módulos se generan automáticamente según los
                    recursos que tienen métricas disponibles para la
                    suscripción seleccionada.
                </p>
            </div>

            <div class="metrics-context">
                <span class="metrics-context-label">
                    Suscripción
                </span>

                <strong>
                    @SubscriptionName
                </strong>
            </div>
        </header>

        @if (_modules.Count == 0)
        {
            <div class="metrics-empty-state">
                <div class="metrics-empty-icon">📭</div>

                <h2>Sin métricas disponibles</h2>

                <p>
                    No existen módulos de métricas con información
                    para esta suscripción.
                </p>
            </div>
        }
        else
        {
            <div class="metrics-grid">

                @foreach (var module in _modules)
                {
                    <button type="button"
                            class="metrics-card metrics-card-enabled"
                            disabled="@(!module.IsEnabled)"
                            @onclick="() => SelectModule(module.ModuleKey)">

                        <div class="metrics-card-top">

                            <div class="metrics-card-icon">
                                @module.Icon
                            </div>

                            <span class="metrics-card-status metrics-status-active">
                                @module.ResourceCount
                                @(module.ResourceCount == 1
                                    ? "recurso"
                                    : "recursos")
                            </span>

                        </div>

                        <div class="metrics-card-content">

                            <h3>@module.DisplayName</h3>

                            <p>@module.Description</p>

                        </div>

                        <div class="metrics-card-footer">

                            <span>
                                Métricas disponibles
                            </span>

                            <span class="metrics-card-arrow">
                                →
                            </span>

                        </div>

                    </button>
                }

            </div>
        }
    }
    else
    {
        <div class="metrics-module-container">

            <button type="button"
                    class="metrics-back-button"
                    @onclick="ReturnToCatalog">
                <span aria-hidden="true">←</span>
                Volver a métricas
            </button>

            @switch (_selectedModuleKey)
            {
                case "virtual-machines":

                    <ClientVirtualMachineMetrics
                        CustomerName="@CustomerName"
                        SubscriptionId="@SubscriptionId"
                        SubscriptionName="@SubscriptionName" />

                    break;

                case "storage-accounts":

                    <div class="metrics-empty-state">
                        <div class="metrics-empty-icon">💾</div>

                        <h2>Storage Accounts</h2>

                        <p>
                            El catálogo detectó los Storage Accounts
                            disponibles para esta suscripción. La pantalla
                            detallada se conectará con las métricas de
                            capacidad, transacciones, tráfico, disponibilidad
                            y latencia.
                        </p>
                    </div>

                    break;

                default:

                    <div class="metrics-empty-state">
                        <div class="metrics-empty-icon">📊</div>

                        <h2>Módulo no disponible</h2>

                        <p>
                            No existe todavía una pantalla especializada
                            para este tipo de recurso.
                        </p>
                    </div>

                    break;
            }

        </div>
    }

</section>

@code {
    [Parameter]
    public string? CustomerName { get; set; }

    [Parameter]
    public string? SubscriptionId { get; set; }

    [Parameter]
    public string? SubscriptionName { get; set; }

    private readonly List<AzureMetricsModule> _modules = [];

    private string? _selectedModuleKey;

    private string? _loadedSubscriptionId;

    private string? _errorMessage;

    private bool _isLoading;

    protected override async Task OnParametersSetAsync()
    {
        var normalizedSubscriptionId =
            SubscriptionId?.Trim();

        if (string.IsNullOrWhiteSpace(normalizedSubscriptionId))
        {
            _modules.Clear();
            _selectedModuleKey = null;
            _loadedSubscriptionId = null;
            return;
        }

        if (string.Equals(
                _loadedSubscriptionId,
                normalizedSubscriptionId,
                StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _loadedSubscriptionId =
            normalizedSubscriptionId;

        _selectedModuleKey = null;

        await LoadModulesAsync();
    }

    private async Task LoadModulesAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _modules.Clear();

        try
        {
            var modules =
                await MetricsCatalogService
                    .GetAvailableModulesAsync(
                        SubscriptionId ?? string.Empty);

            _modules.AddRange(modules);
        }
        catch (Exception exception)
        {
            _errorMessage =
                $"Error consultando el catálogo: {exception.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SelectModule(string moduleKey)
    {
        if (string.IsNullOrWhiteSpace(moduleKey))
        {
            return;
        }

        _selectedModuleKey = moduleKey;
    }

    private void ReturnToCatalog()
    {
        _selectedModuleKey = null;
    }
}
