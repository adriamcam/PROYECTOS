.advisor-page {
    display: flex;
    flex-direction: column;
    gap: 18px;
}

.advisor-header,
.advisor-panel-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
}

.advisor-header h2,
.advisor-panel-heading h3 {
    margin: 4px 0 5px;
    color: #17233c;
}

.advisor-header h2 {
    font-size: 24px;
}

.advisor-panel-heading h3 {
    font-size: 17px;
}

.advisor-header p {
    margin: 0;
    color: #64748b;
    font-size: 12px;
}

.advisor-eyebrow {
    color: #2563eb;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
}

.advisor-refresh-button,
.advisor-pagination button {
    min-height: 36px;
    padding: 8px 14px;
    border: 1px solid #cbd5e1;
    border-radius: 7px;
    background: #fff;
    color: #334155;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
}

.advisor-refresh-button:disabled,
.advisor-pagination button:disabled {
    cursor: not-allowed;
    opacity: .5;
}

.advisor-panel {
    padding: 17px;
    border: 1px solid #dbe3ee;
    border-radius: 10px;
    background: #fff;
}

.advisor-score-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 15px;
}

.advisor-score-card {
    padding: 15px;
    border: 1px solid #e2e8f0;
    border-radius: 9px;
    background: #f8fafc;
}

.security-score {
    background: #f5f3ff;
}

.advisor-score-header,
.advisor-score-footer {
    display: flex;
    justify-content: space-between;
    gap: 12px;
}

.advisor-score-header {
    color: #334155;
    font-size: 12px;
    font-weight: 600;
}

.advisor-score-header strong {
    color: #17233c;
    font-size: 18px;
}

.advisor-score-track {
    height: 7px;
    margin: 12px 0;
    overflow: hidden;
    border-radius: 999px;
    background: #e2e8f0;
}

.advisor-score-fill {
    height: 100%;
    border-radius: 999px;
    background: #2563eb;
}

.advisor-score-footer {
    color: #64748b;
    font-size: 10px;
}

.score-badge,
.advisor-result-count {
    padding: 5px 10px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
}

.score-good {
    background: #dcfce7;
    color: #166534;
}

.score-warning {
    background: #fef3c7;
    color: #92400e;
}

.score-critical {
    background: #fee2e2;
    color: #b91c1c;
}

.advisor-result-count {
    background: #eff6ff;
    color: #2563eb;
}

.advisor-summary-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
}

.advisor-summary-card {
    display: flex;
    min-height: 105px;
    flex-direction: column;
    padding: 15px;
    border: 1px solid #dbe3ee;
    border-radius: 9px;
    background: #fff;
}

.advisor-summary-card span {
    color: #64748b;
    font-size: 10px;
    font-weight: 600;
}

.advisor-summary-card strong {
    margin-top: 8px;
    color: #17233c;
    font-size: 22px;
}

.advisor-summary-card small {
    margin-top: auto;
    color: #94a3b8;
    font-size: 9px;
}

.advisor-filters {
    display: grid;
    grid-template-columns:
        minmax(300px, 2fr)
        minmax(170px, 1fr)
        minmax(150px, 1fr)
        auto;
    gap: 10px;
    margin: 15px 0;
}

.advisor-input,
.advisor-select {
    min-height: 37px;
    padding: 8px 10px;
    border: 1px solid #cbd5e1;
    border-radius: 7px;
    background: #fff;
    color: #334155;
    font-size: 11px;
}

.advisor-checkbox {
    display: flex;
    align-items: center;
    gap: 7px;
    color: #475569;
    font-size: 11px;
    white-space: nowrap;
}

.advisor-table-wrapper {
    overflow-x: auto;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
}

.advisor-table {
    width: 100%;
    min-width: 1250px;
    border-collapse: collapse;
}

.advisor-table th {
    padding: 10px 12px;
    background: #f8fafc;
    color: #64748b;
    font-size: 9px;
    text-align: left;
    text-transform: uppercase;
}

.advisor-table td {
    padding: 11px 12px;
    border-top: 1px solid #edf1f6;
    color: #475569;
    font-size: 10px;
    vertical-align: top;
}

.recommendation-title {
    display: block;
    max-width: 390px;
    color: #1e293b;
    line-height: 1.4;
}

.recommendation-description {
    max-width: 390px;
    margin-top: 4px;
    color: #64748b;
    line-height: 1.4;
}

.subscription-name {
    display: block;
    margin-top: 5px;
    color: #2563eb;
}

.category-badge {
    display: inline-flex;
    padding: 4px 7px;
    border-radius: 5px;
    background: #f1f5f9;
    font-weight: 600;
}

.impact-badge {
    display: inline-flex;
    min-width: 60px;
    justify-content: center;
    padding: 4px 8px;
    border-radius: 999px;
    font-size: 9px;
    font-weight: 700;
}

.impact-high {
    background: #fee2e2;
    color: #b91c1c;
}

.impact-medium {
    background: #fef3c7;
    color: #92400e;
}

.impact-low {
    background: #dcfce7;
    color: #166534;
}

.impact-default {
    background: #f1f5f9;
    color: #475569;
}

.money-column {
    color: #047857 !important;
    font-weight: 700;
    text-align: right !important;
    white-space: nowrap;
}

.advisor-pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 13px;
    color: #64748b;
    font-size: 10px;
}

.advisor-pagination div {
    display: flex;
    gap: 8px;
}

.advisor-state {
    display: flex;
    min-height: 230px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 30px;
    border: 1px dashed #cbd5e1;
    border-radius: 10px;
    background: #f8fafc;
    text-align: center;
}

.advisor-error {
    border-color: #fecaca;
    background: #fff7f7;
}

.advisor-loader {
    width: 30px;
    height: 30px;
    margin-bottom: 14px;
    border: 3px solid #dbeafe;
    border-top-color: #2563eb;
    border-radius: 50%;
    animation: advisor-spin .8s linear infinite;
}

@keyframes advisor-spin {
    to {
        transform: rotate(360deg);
    }
}

@media (max-width: 1100px) {
    .advisor-score-grid,
    .advisor-summary-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .advisor-filters {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@media (max-width: 700px) {
    .advisor-header,
    .advisor-panel-heading {
        flex-direction: column;
    }

    .advisor-score-grid,
    .advisor-summary-grid,
    .advisor-filters {
        grid-template-columns: 1fr;
    }
}

/* ==========================================================
   ORDENAMIENTO DE COLUMNAS
   ========================================================== */

.advisor-table th {
    padding: 0;
}

.advisor-sort-button {
    display: flex;
    width: 100%;
    min-height: 38px;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 10px 12px;
    border: 0;
    background: transparent;
    color: #64748b;
    font-family: inherit;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .025em;
    text-align: left;
    text-transform: uppercase;
    cursor: pointer;
}

.advisor-sort-button:hover {
    background: #eef4ff;
    color: #2563eb;
}

.advisor-sort-button.active {
    background: #eff6ff;
    color: #1d4ed8;
}

.sort-icon {
    min-width: 12px;
    color: #94a3b8;
    font-size: 10px;
    line-height: 1;
    text-align: center;
}

.advisor-sort-button.active .sort-icon {
    color: #2563eb;
}

.money-column .advisor-sort-button {
    justify-content: flex-end;
    text-align: right;
}

.money-column .advisor-sort-button span:first-child {
    margin-left: auto;
}
