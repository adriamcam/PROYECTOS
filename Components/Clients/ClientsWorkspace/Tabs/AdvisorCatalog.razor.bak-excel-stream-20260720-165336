@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Models
@using ITQS.SupportOperationsCenter.Components.Clients.ClientsWorkspace.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using ClosedXML.Excel
@inject IAdvisorCatalogService AdvisorCatalogService
@inject IJSRuntime JS

<div class="advisor-catalog">
    <div class="catalog-header">
        <div>
            <h2>Configuración Advisor</h2>
            <p>
                Edición del catálogo de recomendaciones,
                traducciones, complejidad y tiempo estimado.
            </p>
        </div>

        <div class="catalog-toolbar">
            <button type="button"
                    class="toolbar-button"
                    @onclick="OpenNew">
                <span class="toolbar-icon">＋</span>
                Nueva
            </button>

            <label class="toolbar-button file-button">
                <span class="toolbar-icon">📥</span>
                Importar Excel

                <InputFile class="file-input"
                           OnChange="ReadExcelAsync"
                           accept=".xlsx" />
            </label>

            <button type="button"
                    class="toolbar-button"
                    @onclick="DownloadTemplateAsync">
                <span class="toolbar-icon">📄</span>
                Descargar plantilla
            </button>

            <button type="button"
                    class="toolbar-button"
                    @onclick="ExportCatalogAsync">
                <span class="toolbar-icon">📤</span>
                Exportar catálogo
            </button>

            <button type="button"
                    class="toolbar-button primary-button"
                    @onclick="LoadAsync"
                    disabled="@IsLoading">
                <span class="toolbar-icon">↻</span>
                @(IsLoading ? "Cargando..." : "Actualizar")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(SelectedExcelFileName))
        {
            <div class="selected-file">
                <span class="selected-file-icon">📊</span>

                <div>
                    <strong>Archivo seleccionado</strong>
                    <span>@SelectedExcelFileName</span>
                </div>

                <button type="button"
                        title="Quitar archivo"
                        @onclick="ClearImport">
                    ✕
                </button>
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(PageMessage))
    {
        <div class="@PageMessageClass">@PageMessage</div>
    }

    @if (ShowNewForm)
    {
        <div class="catalog-panel">
            <div class="panel-header"><h3>Nueva recomendación</h3><button type="button" @onclick="CloseNew">✕</button></div>
            <div class="form-grid">
                <label>Recomendación original<input @bind="NewItem.Recommendation" /></label>
                <label>Traducción<input @bind="NewItem.RecommendationSpanish" /></label>
                <label class="wide">Descripción<textarea rows="3" @bind="NewItem.DescriptionSpanish"></textarea></label>
                <label>Complejidad<select @bind="NewItem.Complexity"><option value="">Sin definir</option><option>Baja</option><option>Media</option><option>Alta</option></select></label>
                <label>Horas<input type="number" min="0" step="0.25" @bind="NewItem.ImplementationHours" /></label>
                <label>Minutos<input type="number" min="0" @bind="NewItem.ImplementationMinutes" /></label>
                <label>Costo<select @bind="NewItem.CostClassification"><option>Por validar</option><option>Con costo</option><option>Sin costo</option><option>Mixto</option></select></label>
                <label><input type="checkbox" @bind="NewItem.RequiresMaintenanceWindow" /> Requiere ventana</label>
                <label><input type="checkbox" @bind="NewItem.IsActive" /> Activo</label>
            </div>
            <div class="panel-actions"><button type="button" class="primary-button" @onclick="CreateAsync">Guardar</button><button type="button" @onclick="CloseNew">Cancelar</button></div>
        </div>
    }

    @if (ImportPreview is not null)
    {
        <div class="catalog-panel">
            <div class="panel-header"><h3>Vista previa de importación</h3><button type="button" @onclick="ClearImport">✕</button></div>
            <div class="import-summary">
                <span>Insertar <strong>@ImportPreview.Inserts</strong></span>
                <span>Actualizar <strong>@ImportPreview.Updates</strong></span>
                <span>Sin cambios <strong>@ImportPreview.Unchanged</strong></span>
                <span>Errores <strong>@ImportPreview.Errors</strong></span>
            </div>
            <div class="import-table"><table><thead><tr><th>Fila</th><th>Recomendación</th><th>Traducción</th><th>Acción</th><th>Error</th></tr></thead><tbody>
            @foreach (var row in ImportPreview.Rows.Take(100))
            {<tr><td>@row.ExcelRow</td><td>@row.Recommendation</td><td>@row.RecommendationSpanish</td><td>@row.Action</td><td class="error-text">@row.Error</td></tr>}
            </tbody></table></div>
            <div class="panel-actions">
                <button type="button" class="primary-button" @onclick="ConfirmImportAsync" disabled="@(ImportPreview.Errors > 0 || IsImporting)">@(IsImporting ? "Importando..." : "Confirmar importación")</button>
                <button type="button" @onclick="ClearImport">Cancelar</button>
            </div>
        </div>
    }

    <div class="catalog-kpis">
        <div><span>Total</span><strong>@Items.Count</strong></div>
        <div><span>Activos</span><strong>@Items.Count(x => x.IsActive)</strong></div>
        <div>
            <span>Sin complejidad</span>
            <strong>@Items.Count(x => string.IsNullOrWhiteSpace(x.Complexity))</strong>
        </div>
        <div>
            <span>Sin tiempo</span>
            <strong>
                @Items.Count(x =>
                    x.ImplementationMinutes <= 0 &&
                    (!x.ImplementationHours.HasValue ||
                     x.ImplementationHours <= 0))
            </strong>
        </div>
    </div>

    <div class="catalog-filters">
        <input type="search"
               @bind="SearchText"
               @bind:event="oninput"
               placeholder="Buscar recomendación o descripción..." />

        <select @bind="ComplexityFilter">
            <option value="">Todas las complejidades</option>
            <option value="Baja">Baja</option>
            <option value="Media">Media</option>
            <option value="Alta">Alta</option>
        </select>

        <select @bind="StatusFilter">
            <option value="">Todos los estados</option>
            <option value="active">Activos</option>
            <option value="inactive">Inactivos</option>
        </select>

        <select @bind="PageSize">
            <option value="10">10 por página</option>
            <option value="20">20 por página</option>
            <option value="50">50 por página</option>
            <option value="100">100 por página</option>
        </select>
    </div>

    @if (IsLoading)
    {
        <div class="catalog-state">Cargando catálogo...</div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>
                            <button type="button"
                                    class="sort-header"
                                    @onclick='() => SortBy("id")'>
                                ID @GetSortIcon("id")
                            </button>
                        </th>
                        <th>
                            <button type="button"
                                    class="sort-header"
                                    @onclick='() => SortBy("recommendation")'>
                                Recomendación original @GetSortIcon("recommendation")
                            </button>
                        </th>
                        <th>
                            <button type="button"
                                    class="sort-header"
                                    @onclick='() => SortBy("translation")'>
                                Traducción / descripción @GetSortIcon("translation")
                            </button>
                        </th>
                        <th>
                            <button type="button"
                                    class="sort-header"
                                    @onclick='() => SortBy("complexity")'>
                                Complejidad @GetSortIcon("complexity")
                            </button>
                        </th>
                        <th>
                            <button type="button"
                                    class="sort-header"
                                    @onclick='() => SortBy("hours")'>
                                Horas @GetSortIcon("hours")
                            </button>
                        </th>
                        <th>
                            <button type="button"
                                    class="sort-header"
                                    @onclick='() => SortBy("minutes")'>
                                Minutos @GetSortIcon("minutes")
                            </button>
                        </th>
                        <th>
                            <button type="button"
                                    class="sort-header"
                                    @onclick='() => SortBy("cost")'>
                                Costo @GetSortIcon("cost")
                            </button>
                        </th>
                        <th>
                            <button type="button"
                                    class="sort-header"
                                    @onclick='() => SortBy("window")'>
                                Ventana @GetSortIcon("window")
                            </button>
                        </th>
                        <th>
                            <button type="button"
                                    class="sort-header"
                                    @onclick='() => SortBy("active")'>
                                Activo @GetSortIcon("active")
                            </button>
                        </th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in PagedItems)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="original-cell">
                                <strong>@item.Recommendation</strong>
                                <small>
                                    @(item.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))
                                </small>
                            </td>
                            <td>
                                @if (item.IsEditing)
                                {
                                    <textarea rows="3"
                                              @bind="item.RecommendationSpanish"></textarea>
                                    <textarea rows="3"
                                              placeholder="Descripción"
                                              @bind="item.DescriptionSpanish"></textarea>
                                    <textarea rows="2"
                                              placeholder="Notas"
                                              @bind="item.Notes"></textarea>
                                }
                                else
                                {
                                    <strong>@item.RecommendationSpanish</strong>
                                    <p>@item.DescriptionSpanish</p>
                                    <small>@item.Notes</small>
                                }
                            </td>
                            <td>
                                @if (item.IsEditing)
                                {
                                    <select @bind="item.Complexity">
                                        <option value="">Sin definir</option>
                                        <option value="Baja">Baja</option>
                                        <option value="Media">Media</option>
                                        <option value="Alta">Alta</option>
                                    </select>
                                }
                                else
                                {
                                    @TextOrDash(item.Complexity)
                                }
                            </td>
                            <td>
                                @if (item.IsEditing)
                                {
                                    <input type="number"
                                           min="0"
                                           step="0.25"
                                           @bind="item.ImplementationHours" />
                                }
                                else
                                {
                                    @(item.ImplementationHours?.ToString("N2") ?? "0")
                                }
                            </td>
                            <td>
                                @if (item.IsEditing)
                                {
                                    <input type="number"
                                           min="0"
                                           @bind="item.ImplementationMinutes" />
                                }
                                else
                                {
                                    @item.ImplementationMinutes
                                }
                            </td>
                            <td>
                                @if (item.IsEditing)
                                {
                                    <select @bind="item.CostClassification">
                                        <option value="Por validar">Por validar</option>
                                        <option value="Con costo">Con costo</option>
                                        <option value="Sin costo">Sin costo</option>
                                        <option value="Mixto">Mixto</option>
                                    </select>
                                }
                                else
                                {
                                    @item.CostClassification
                                }
                            </td>
                            <td>
                                <input type="checkbox"
                                       @bind="item.RequiresMaintenanceWindow"
                                       disabled="@(!item.IsEditing)" />
                            </td>
                            <td>
                                <input type="checkbox"
                                       @bind="item.IsActive"
                                       disabled="@(!item.IsEditing)" />
                            </td>
                            <td class="actions">
                                @if (item.IsEditing)
                                {
                                    <button type="button"
                                            class="save-button"
                                            @onclick="() => SaveAsync(item)"
                                            disabled="@item.IsSaving">
                                        @(item.IsSaving ? "Guardando..." : "Guardar")
                                    </button>
                                    <button type="button"
                                            @onclick="() => Cancel(item)"
                                            disabled="@item.IsSaving">
                                        Cancelar
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            @onclick="() => Edit(item)">
                                        Editar
                                    </button>
                                }
                                <small>@item.StatusMessage</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination">
            <span>
                Mostrando @FirstRecord-@LastRecord
                de @Filtered.Count
            </span>
            <div>
                <button type="button"
                        @onclick="Previous"
                        disabled="@(CurrentPage <= 1)">
                    Anterior
                </button>
                <strong>Página @CurrentPage de @TotalPages</strong>
                <button type="button"
                        @onclick="Next"
                        disabled="@(CurrentPage >= TotalPages)">
                    Siguiente
                </button>
            </div>
        </div>
    }
</div>

@code {
    private List<AdvisorCatalogItem> Items { get; set; } = new();
    private Dictionary<int, AdvisorCatalogItem> Backups { get; } = new();
    private AdvisorCatalogItem NewItem { get; set; } = NewCatalogItem();
    private bool ShowNewForm { get; set; }
    private bool IsImporting { get; set; }
    private AdvisorCatalogImportPreview? ImportPreview { get; set; }
    private string SelectedExcelFileName { get; set; } = string.Empty;

    private string SearchText { get; set; } = string.Empty;
    private string CategoryFilter { get; set; } = string.Empty;
    private string ComplexityFilter { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = string.Empty;
    private string PageMessage { get; set; } = string.Empty;
    private bool PageMessageIsError { get; set; }
    private bool IsLoading { get; set; }

    private int CurrentPage { get; set; } = 1;
    private int _pageSize = 20;

    private string SortColumn { get; set; } = "active";
    private bool SortAscending { get; set; } = false;

    private int PageSize
    {
        get => _pageSize;
        set
        {
            _pageSize = value;
            CurrentPage = 1;
        }
    }

    private string PageMessageClass =>
        PageMessageIsError ? "message error" : "message success";

    private IEnumerable<string> Categories =>
        Items
            .Select(x => x.Category)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x);

    private List<AdvisorCatalogItem> Filtered
    {
        get
        {
            var query = Items.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                var search = SearchText.Trim();

                query = query.Where(x =>
                    Has(x.Recommendation, search) ||
                    Has(x.RecommendationSpanish, search) ||
                    Has(x.DescriptionSpanish, search) ||
                    Has(x.Category, search) ||
                    Has(x.Notes, search));
            }

            if (!string.IsNullOrWhiteSpace(CategoryFilter))
            {
                query = query.Where(x =>
                    string.Equals(
                        x.Category,
                        CategoryFilter,
                        StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(ComplexityFilter))
            {
                query = query.Where(x =>
                    string.Equals(
                        x.Complexity,
                        ComplexityFilter,
                        StringComparison.OrdinalIgnoreCase));
            }

            query = StatusFilter switch
            {
                "active" => query.Where(x => x.IsActive),
                "inactive" => query.Where(x => !x.IsActive),
                _ => query
            };

            query = SortColumn switch
            {
                "id" => SortAscending
                    ? query.OrderBy(x => x.Id)
                    : query.OrderByDescending(x => x.Id),

                "recommendation" => SortAscending
                    ? query.OrderBy(x => x.Recommendation)
                    : query.OrderByDescending(x => x.Recommendation),

                "translation" => SortAscending
                    ? query.OrderBy(x => x.RecommendationSpanish)
                    : query.OrderByDescending(x => x.RecommendationSpanish),

                "complexity" => SortAscending
                    ? query.OrderBy(x => ComplexityOrder(x.Complexity))
                        .ThenBy(x => x.RecommendationSpanish)
                    : query.OrderByDescending(x => ComplexityOrder(x.Complexity))
                        .ThenBy(x => x.RecommendationSpanish),

                "hours" => SortAscending
                    ? query.OrderBy(x => x.ImplementationHours ?? 0)
                    : query.OrderByDescending(x => x.ImplementationHours ?? 0),

                "minutes" => SortAscending
                    ? query.OrderBy(x => x.ImplementationMinutes)
                    : query.OrderByDescending(x => x.ImplementationMinutes),

                "cost" => SortAscending
                    ? query.OrderBy(x => x.CostClassification)
                    : query.OrderByDescending(x => x.CostClassification),

                "window" => SortAscending
                    ? query.OrderBy(x => x.RequiresMaintenanceWindow)
                    : query.OrderByDescending(x => x.RequiresMaintenanceWindow),

                "active" => SortAscending
                    ? query.OrderBy(x => x.IsActive)
                    : query.OrderByDescending(x => x.IsActive),

                _ => query.OrderByDescending(x => x.IsActive)
                    .ThenBy(x => x.RecommendationSpanish)
            };

            return query.ToList();
        }
    }

    private IEnumerable<AdvisorCatalogItem> PagedItems
    {
        get
        {
            ValidatePage();

            return Filtered
                .Skip((CurrentPage - 1) * PageSize)
                .Take(PageSize);
        }
    }

    private int TotalPages =>
        Math.Max(
            1,
            (int)Math.Ceiling(Filtered.Count / (double)PageSize));

    private int FirstRecord =>
        Filtered.Count == 0
            ? 0
            : ((CurrentPage - 1) * PageSize) + 1;

    private int LastRecord =>
        Math.Min(CurrentPage * PageSize, Filtered.Count);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        PageMessage = string.Empty;

        try
        {
            Items = (await AdvisorCatalogService.GetAllAsync()).ToList();
            Backups.Clear();
            CurrentPage = 1;
        }
        catch (Exception ex)
        {
            SetMessage(
                $"No fue posible cargar el catálogo: {ex.Message}",
                true);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void Edit(AdvisorCatalogItem item)
    {
        Backups[item.Id] = item.Clone();
        item.IsEditing = true;
        item.StatusMessage = string.Empty;
    }

    private void Cancel(AdvisorCatalogItem item)
    {
        if (Backups.TryGetValue(item.Id, out var backup))
        {
            CopyValues(backup, item);
            item.RowVersion = backup.RowVersion.ToArray();
            item.UpdatedAt = backup.UpdatedAt;
        }

        item.IsEditing = false;
        item.IsSaving = false;
        item.StatusMessage = string.Empty;
        Backups.Remove(item.Id);
    }

    private async Task SaveAsync(AdvisorCatalogItem item)
    {
        if (string.IsNullOrWhiteSpace(item.RecommendationSpanish))
        {
            item.StatusMessage =
                "La traducción es obligatoria.";
            return;
        }

        item.IsSaving = true;
        item.StatusMessage = string.Empty;

        try
        {
            var result =
                await AdvisorCatalogService.UpdateAsync(item);

            item.StatusMessage = result.Message;

            if (!result.Success)
            {
                return;
            }

            item.RowVersion = result.RowVersion;
            item.UpdatedAt = result.UpdatedAt;
            item.IsEditing = false;
            Backups.Remove(item.Id);

            SetMessage(
                $"Registro {item.Id} actualizado.",
                false);
        }
        catch (Exception ex)
        {
            item.StatusMessage = ex.Message;
        }
        finally
        {
            item.IsSaving = false;
        }
    }


    private static AdvisorCatalogItem NewCatalogItem() => new() { IsActive = true, CostClassification = "Por validar" };

    private void OpenNew() { NewItem = NewCatalogItem(); ShowNewForm = true; PageMessage = string.Empty; }
    private void CloseNew() { ShowNewForm = false; NewItem = NewCatalogItem(); }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(NewItem.Recommendation) || string.IsNullOrWhiteSpace(NewItem.RecommendationSpanish))
        { SetMessage("Recomendación original y traducción son obligatorias.", true); return; }
        var result = await AdvisorCatalogService.CreateAsync(NewItem);
        SetMessage(result.Message, !result.Success);
        if (result.Success) { CloseNew(); await LoadAsync(); }
    }

    private async Task ReadExcelAsync(InputFileChangeEventArgs e)
    {
        PageMessage = string.Empty;
        SelectedExcelFileName = e.File.Name;

        try
        {
            await using var stream = e.File.OpenReadStream(20 * 1024 * 1024);
            using var workbook = new XLWorkbook(stream);
            var ws = workbook.Worksheets.First();
            var headers = ws.Row(1).CellsUsed().ToDictionary(c => c.GetString().Trim(), c => c.Address.ColumnNumber, StringComparer.OrdinalIgnoreCase);
            string[] required = ["Recommendation", "RecommendationSpanish"];
            var missing = required.Where(x => !headers.ContainsKey(x)).ToArray();
            if (missing.Length > 0) throw new InvalidOperationException($"Faltan columnas: {string.Join(", ", missing)}");
            var rows = new List<AdvisorCatalogImportRow>();
            foreach (var r in ws.RowsUsed().Skip(1))
            {
                if (r.IsEmpty()) continue;
                string S(string name) => headers.TryGetValue(name, out var col) ? r.Cell(col).GetString().Trim() : string.Empty;
                bool B(string name, bool def=false) { var v=S(name); return string.IsNullOrWhiteSpace(v)?def:v.Equals("true",StringComparison.OrdinalIgnoreCase)||v.Equals("si",StringComparison.OrdinalIgnoreCase)||v=="1"; }
                int I(string name) => int.TryParse(S(name), out var v) ? v : 0;
                decimal? D(string name) => decimal.TryParse(S(name), out var v) ? v : null;
                rows.Add(new() { ExcelRow=r.RowNumber(), Recommendation=S("Recommendation"), RecommendationSpanish=S("RecommendationSpanish"), DescriptionSpanish=S("DescriptionSpanish"), CostClassification=string.IsNullOrWhiteSpace(S("CostClassification"))?"Por validar":S("CostClassification"), RequiresMaintenanceWindow=B("RequiresMaintenanceWindow"), ImplementationMinutes=I("ImplementationMinutes"), ImplementationHours=D("ImplementationHours"), Complexity=S("Complexity"), Notes=S("Notes"), IsActive=B("IsActive", true) });
            }
            ImportPreview = await AdvisorCatalogService.PreviewImportAsync(rows);
        }
        catch (Exception ex) { SetMessage($"No fue posible leer el Excel: {ex.Message}", true); }
    }

    private async Task ConfirmImportAsync()
    {
        if (ImportPreview is null) return;
        IsImporting = true;
        try
        {
            var result = await AdvisorCatalogService.ImportAsync(ImportPreview.Rows);
            SetMessage($"Importación completada: {result.Inserted} insertados, {result.Updated} actualizados, {result.Unchanged} sin cambios y {result.Errors} errores.", false);
            ImportPreview = null;
            await LoadAsync();
        }
        catch (Exception ex) { SetMessage($"La importación falló y fue revertida: {ex.Message}", true); }
        finally { IsImporting = false; }
    }

    private void ClearImport()
    {
        ImportPreview = null;
        SelectedExcelFileName = string.Empty;
    }

    private async Task DownloadTemplateAsync()
    {
        using var wb = new XLWorkbook(); var ws = wb.AddWorksheet("Catalogo");
        var headers = new[] { "Recommendation","RecommendationSpanish","DescriptionSpanish","Complexity","ImplementationHours","ImplementationMinutes","CostClassification","RequiresMaintenanceWindow","IsActive","Notes" };
        for (var i=0;i<headers.Length;i++) ws.Cell(1,i+1).Value=headers[i];
        ws.Cell(2,1).Value="Recommendation example"; ws.Cell(2,2).Value="Recomendación de ejemplo"; ws.Cell(2,4).Value="Baja"; ws.Cell(2,5).Value=0.5; ws.Cell(2,6).Value=30; ws.Cell(2,7).Value="Mixto"; ws.Cell(2,8).Value=false; ws.Cell(2,9).Value=true;
        ws.Columns().AdjustToContents(); await DownloadWorkbookAsync(wb,"Plantilla-AdvisorCatalog.xlsx");
    }

    private async Task ExportCatalogAsync()
    {
        using var wb = new XLWorkbook(); var ws = wb.AddWorksheet("Catalogo");
        var headers = new[] { "Id","Recommendation","RecommendationSpanish","DescriptionSpanish","Complexity","ImplementationHours","ImplementationMinutes","CostClassification","RequiresMaintenanceWindow","IsActive","Notes","UpdatedAt" };
        for (var i=0;i<headers.Length;i++) ws.Cell(1,i+1).Value=headers[i];
        var row=2; foreach(var x in Items) { ws.Cell(row,1).Value=x.Id; ws.Cell(row,2).Value=x.Recommendation; ws.Cell(row,3).Value=x.RecommendationSpanish; ws.Cell(row,4).Value=x.DescriptionSpanish; ws.Cell(row,5).Value=x.Complexity; ws.Cell(row,6).Value=x.ImplementationHours; ws.Cell(row,7).Value=x.ImplementationMinutes; ws.Cell(row,8).Value=x.CostClassification; ws.Cell(row,9).Value=x.RequiresMaintenanceWindow; ws.Cell(row,10).Value=x.IsActive; ws.Cell(row,11).Value=x.Notes; ws.Cell(row,12).Value=x.UpdatedAt; row++; }
        ws.Columns().AdjustToContents(); await DownloadWorkbookAsync(wb,$"AdvisorCatalog-{DateTime.Now:yyyyMMdd-HHmm}.xlsx");
    }

    private async Task DownloadWorkbookAsync(XLWorkbook wb, string fileName)
    {
        using var ms = new MemoryStream(); wb.SaveAs(ms);
        using var streamRef = new DotNetStreamReference(new MemoryStream(ms.ToArray()));
        await JS.InvokeVoidAsync("advisorCatalogDownload", fileName, streamRef);
    }

    private void SortBy(string column)
    {
        if (string.Equals(
            SortColumn,
            column,
            StringComparison.OrdinalIgnoreCase))
        {
            SortAscending = !SortAscending;
        }
        else
        {
            SortColumn = column;
            SortAscending = true;
        }

        CurrentPage = 1;
    }

    private string GetSortIcon(string column)
    {
        if (!string.Equals(
            SortColumn,
            column,
            StringComparison.OrdinalIgnoreCase))
        {
            return "↕";
        }

        return SortAscending ? "▲" : "▼";
    }

    private static int ComplexityOrder(string? complexity)
    {
        return complexity?.Trim().ToUpperInvariant() switch
        {
            "BAJA" => 1,
            "MEDIA" => 2,
            "ALTA" => 3,
            _ => 4
        };
    }

    private void Previous()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
        }
    }

    private void Next()
    {
        if (CurrentPage < TotalPages)
        {
            CurrentPage++;
        }
    }

    private void ValidatePage()
    {
        CurrentPage = Math.Clamp(
            CurrentPage,
            1,
            TotalPages);
    }

    private void SetMessage(string value, bool error)
    {
        PageMessage = value;
        PageMessageIsError = error;
    }

    private static bool Has(string? value, string search) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(search, StringComparison.OrdinalIgnoreCase);

    private static string TextOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static void CopyValues(
        AdvisorCatalogItem source,
        AdvisorCatalogItem target)
    {
        target.RecommendationSpanish = source.RecommendationSpanish;
        target.DescriptionSpanish = source.DescriptionSpanish;
        target.CostClassification = source.CostClassification;
        target.RequiresMaintenanceWindow = source.RequiresMaintenanceWindow;
        target.ImplementationMinutes = source.ImplementationMinutes;
        target.ImplementationHours = source.ImplementationHours;
        target.Category = source.Category;
        target.Complexity = source.Complexity;
        target.Notes = source.Notes;
        target.IsActive = source.IsActive;
    }
