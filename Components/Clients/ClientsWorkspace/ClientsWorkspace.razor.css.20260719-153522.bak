/* ===========================================================
   CLIENTS WORKSPACE
   ITQS Support Operations Center
=========================================================== */

.client-workspace {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 24px;
}

/*============================================================
HEADER
============================================================*/

.workspace-header {
    background: #ffffff;
    border-radius: 14px;
    padding: 28px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 10px 30px rgba(0,0,0,.06);
}

.workspace-title h1 {
    margin: 0;
    font-size: 34px;
    font-weight: 700;
    color: #0f172a;
}

.workspace-title p {
    margin-top: 8px;
    color: #64748b;
    font-size: 15px;
}

/*============================================================
SELECTORES
============================================================*/

.workspace-selector {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 20px;
    margin-top: 30px;
    align-items: end;
}

.workspace-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.workspace-field label {
    font-size: 13px;
    font-weight: 600;
    color: #475569;
}

.workspace-field select {
    height: 46px;
    border-radius: 10px;
    border: 1px solid #cbd5e1;
    padding: 0 14px;
    font-size: 14px;
    background: white;
    transition: .2s;
}

.workspace-field select:hover {
    border-color: #2563eb;
}

.workspace-field select:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37,99,235,.15);
}

/*============================================================
BOTÓN
============================================================*/

.workspace-refresh-button {
    height: 46px;
    border: none;
    border-radius: 10px;
    background: #2563eb;
    color: white;
    padding: 0 24px;
    font-weight: 600;
    cursor: pointer;
    transition: .2s;
}

.workspace-refresh-button:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
}

/*============================================================
RESUMEN
============================================================*/

.workspace-context {
    margin-top: 28px;

    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(180px,1fr));
    gap: 18px;
}

.workspace-context > div {

    background: #f8fafc;

    border: 1px solid #e2e8f0;

    border-radius: 12px;

    padding: 18px;
}

.workspace-context span {

    display: block;

    color: #64748b;

    font-size: 12px;

    text-transform: uppercase;

    letter-spacing: .05em;

    margin-bottom: 6px;
}

.workspace-context strong {

    color: #0f172a;

    font-size: 16px;
}

/*============================================================
TABS
============================================================*/

.workspace-tabs {

    display: flex;

    gap: 10px;

    flex-wrap: wrap;
}

.workspace-tab {

    border: none;

    background: white;

    border-radius: 10px;

    border: 1px solid #dbe4ef;

    padding: 12px 20px;

    cursor: pointer;

    font-weight: 600;

    color: #334155;

    transition: .2s;
}

.workspace-tab:hover {

    border-color: #2563eb;

    color: #2563eb;
}

.workspace-tab.active {

    background: #2563eb;

    color: white;

    border-color: #2563eb;
}

/*============================================================
CONTENIDO
============================================================*/

.workspace-content {

    background: white;

    border-radius: 14px;

    border: 1px solid #e5e7eb;

    padding: 28px;

    min-height: 420px;

    box-shadow: 0 8px 24px rgba(0,0,0,.05);
}

/*============================================================
RESPONSIVE
============================================================*/

@media (max-width:900px){

    .workspace-selector{

        grid-template-columns:1fr;
    }

    .workspace-refresh-button{

        width:100%;
    }

}