@page "/reporting/reserved-instances"

@using ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Models
@using ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Services
@using ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Components

@inject IReservedInstanceService ReservedInstanceService

<PageTitle>Reporte Instancias Reservadas</PageTitle>

<section class="ri-page">

    <section class="ri-hero">
        <div>
            <span class="ri-eyebrow">Azure Reserved Instances</span>
            <h1>Reporte Instancias Reservadas</h1>
            <p>Centro ejecutivo para validar utilización, vencimientos, cambios de SKU y estado operativo de reservas Azure.</p>

            @if (IsLoaded)
            {
                <div class="ri-meta">
                    <span>@Dashboard.Kpis.TotalResources recursos</span>
                    <span>@Dashboard.Kpis.TotalCustomers clientes</span>
                    <span>@Dashboard.Kpis.AvgUtilization.ToString("N2")% health score</span>
                </div>
            }
        </div>

        <div class="ri-actions">
                        <button type="button"
                    class="ri-header-info-btn"
                    @onclick='() => ActiveTab = "Information"'>
                ⓘ Información
            </button>
<button class="ri-btn ri-btn-primary" @onclick="LoadAsync" disabled="@IsLoading">
                @(IsLoading ? "Cargando..." : "Actualizar")
            </button>
        </div>
    </section>

    <div class="ri-tabs">
        <button class="@(ActiveTab == "Dashboard" ? "active" : "")" @onclick='() => ActiveTab = "Dashboard"'>
            Dashboard
        </button>

        <button class="@(ActiveTab == "Resources" ? "active" : "")" @onclick='() => ActiveTab = "Resources"'>
            Recursos
        </button>

        <button class="@(ActiveTab == "Action" ? "active" : "")" @onclick='() => ActiveTab = "Action"'>
            Requiere acción
        </button>

        <button class="@(ActiveTab == "Analysis" ? "active" : "")" @onclick='() => ActiveTab = "Analysis"'>
            Análisis IR
        </button>

        <button class="@(ActiveTab == "Coverage" ? "active" : "")"
                @onclick='() => ActiveTab = "Coverage"'>
            Cobertura IR
        </button>
    </div>

    @if (IsLoading && !IsLoaded)
    {
        <div class="ri-card">
            <h3>Cargando dashboard...</h3>
            <p>Consultando información de instancias reservadas.</p>
        </div>
    }
    else if (!IsLoaded)
    {
        <div class="ri-card">
            <h3>Dashboard listo</h3>
            <p>Presiona <strong>Actualizar</strong> para cargar la información.</p>
        </div>
    }
    else if (ActiveTab == "Dashboard")
    {
        <RIKpis Dashboard="Dashboard" OnOpenResources="OpenResources" OnOpenAction="OpenAction" />

        <div class="ri-dashboard-grid">
            <section class="ri-card">
                <div class="ri-card-header">
                    <div>
                        <h3>Distribución RI</h3>
                        <p>Estado operativo de las reservas.</p>
                    </div>
                </div>

                <div class="ri-bars">
                    @foreach (var item in Dashboard.Distribution)
                    {
                        var percent = Dashboard.Kpis.TotalResources == 0 ? 0 : Math.Round((decimal)item.Total / Dashboard.Kpis.TotalResources * 100, 2);

                        <div class="ri-bar-row">
                            <span>@item.StatusName</span>

                            <div class="ri-bar-track">
                                <div class="ri-bar-fill @GetDistributionClass(item.StatusName)" style="width:@percent%"></div>
                            </div>

                            <strong>@item.Total</strong>
                            <small>@percent.ToString("N2")%</small>
                        </div>
                    }
                </div>
            </section>

            <section class="ri-card">
                <div class="ri-card-header">
                    <div>
                        <h3>Top Clientes</h3>
                        <p>Clientes con mayor cantidad de reservas.</p>
                    </div>
                </div>

                <div class="ri-top-list">
                    @foreach (var item in Dashboard.TopCustomers.Take(8))
                    {
                        <div class="ri-top-row">
                            <div>
                                <strong>@item.Customer</strong>
                                <span>@item.TotalReservations reservas | @item.Issues issues</span>
                            </div>

                            <div class="ri-top-score">
                                <span>@item.AvgUtilization.ToString("N2")%</span>
                                <div class="ri-mini-track">
                                    <div class="ri-mini-fill" style="width:@item.AvgUtilization%"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        </div>

        <section class="ri-card ri-recommendations">
            <div class="ri-card-header">
                <div>
                    <h3>Recomendaciones</h3>
                    <p>Resumen ejecutivo de los principales hallazgos y acciones recomendadas.</p>
                </div>
            </div>

            <div class="ri-recommendation-grid">
                <div class="ri-recommendation success">
                    <div class="ri-icon">✔</div>
                    <div>
                        <strong>@Dashboard.Kpis.HealthyCount</strong>
                        <span>reservas funcionando correctamente</span>
                        <small>Sin problemas detectados.</small>
                    </div>
                </div>

                <div class="ri-recommendation warning">
                    <div class="ri-icon">⚠</div>
                    <div>
                        <strong>@Dashboard.Kpis.SkuMismatchCount</strong>
                        <span>reservas presentan cambio de SKU</span>
                        <small>Reserva vs VM diferente.</small>
                    </div>
                </div>

                <div class="ri-recommendation purple">
                    <div class="ri-icon">📉</div>
                    <div>
                        <strong>@Dashboard.Kpis.LowUtilizationCount</strong>
                        <span>reservas con utilización inferior al 80%</span>
                        <small>Evaluar liberación o ajuste.</small>
                    </div>
                </div>

                <div class="ri-recommendation info">
                    <div class="ri-icon">⌛</div>
                    <div>
                        <strong>@Dashboard.Kpis.ExpiringSoonCount</strong>
                        <span>reservas vencerán en menos de 90 días</span>
                        <small>Considerar renovación.</small>
                    </div>
                </div>

                <div class="ri-recommendation danger">
                    <div class="ri-icon">🚨</div>
                    <div>
                        <strong>@(Dashboard.Kpis.SkuMismatchCount + Dashboard.Kpis.DateMismatchCount + Dashboard.Kpis.LowUtilizationCount + Dashboard.Kpis.ExpiringSoonCount + Dashboard.Kpis.ExpiredCount)</strong>
                        <span>recursos requieren revisión</span>
                        <small>Revisar detalle en Recursos.</small>
                    </div>
                </div>
            </div>
        </section>
    }
    else if (ActiveTab == "Action")
    {
        <RIActionsTable Resources="Dashboard.Resources" />
    }
    else if (ActiveTab == "Analysis")
    {
        <RIAnalysisTable Resources="Dashboard.Resources" />
    }
    else if (ActiveTab == "Coverage")
    {
        <RICoverageTable
            Kpis="CoverageKpis"
            Resources="CoverageResources" />
    }
    else
    {
        <RIResourcesTable Resources="Dashboard.Resources" InitialFilter="@ResourcesInitialFilter" />
    }

</section>


@if (ShowInformation)
{
    <div class="ri-info-modal-backdrop" @onclick="CloseInformation"></div>

    <div class="ri-info-modal-shell">

        <div class="ri-info-modal-header">

            <h2>Información del módulo</h2>

            <button class="ri-info-modal-close"
                    @onclick="CloseInformation">
                ×
            </button>

        </div>

        <div class="ri-info-modal-body">

            <RIInformation />

        </div>

    </div>
}
@code {

    private bool ShowInformation { get; set; }

    private void OpenInformation()
    {
        ShowInformation = true;
    }

    private void CloseInformation()
    {
        ShowInformation = false;
    }

    private ReservedInstanceDashboard Dashboard { get; set; } = new();
    private RICoverageKpi CoverageKpis { get; set; } = new();
    private List<RICoverageResource> CoverageResources { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private bool IsLoaded { get; set; }
    private string ActiveTab { get; set; } = "Dashboard";
    private string ResourcesInitialFilter { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private void OpenResources(string filter)
    {
        ResourcesInitialFilter = filter;
        ActiveTab = "Resources";
    }

    private void OpenAction()
    {
        ActiveTab = "Action";
    }

    private void ChangeTab(string tab)
    {
        ActiveTab = tab;
    }

    private async Task LoadAsync()
    {
        IsLoading = true;

        try
        {
            var dashboardTask =
                ReservedInstanceService.GetDashboardAsync();

            var coverageKpisTask =
                ReservedInstanceService.GetCoverageKpisAsync();

            var coverageResourcesTask =
                ReservedInstanceService.GetCoverageResourcesAsync();

            await Task.WhenAll(
                dashboardTask,
                coverageKpisTask,
                coverageResourcesTask
            );

            Dashboard = await dashboardTask;
            CoverageKpis = await coverageKpisTask;
            CoverageResources = await coverageResourcesTask;

            IsLoaded = true;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private static string GetDistributionClass(string status) => status switch
    {
        "Healthy" => "success",
        "SKU cambiado" => "warning",
        "Fecha no coincide" => "danger",
        "Baja utilización" => "purple",
        "Por vencer" => "info",
        "Expiradas" => "muted",
        _ => "primary"
    };
}






























