@namespace ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Components
@using ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Models
@using Microsoft.JSInterop
@inject IJSRuntime JS

<section class="ri-card ri-resources">

    <div class="ri-card-header">
        <div>
            <h3>Reserved Instance Resources</h3>
            <p>Validación operativa de SKU, fechas, utilización, vencimiento y auditoría.</p>
        </div>

        <div class="ri-header-actions">
            <button class="ri-export-btn" type="button" @onclick="ExportCsv">
                Exportar CSV
            </button>
        </div>
    </div>

    <div class="ri-resource-summary">
        <div class="primary">
            <strong>@FilteredResources.Count()</strong>
            <span>Recursos filtrados</span>
        </div>

        <div class="danger">
            <strong>@FilteredResources.Count(x => x.OperationalStatus != "Healthy")</strong>
            <span>Issues filtrados</span>
        </div>

        <div class="success">
            <strong>@FilteredResources.Count(x => x.OperationalStatus == "Healthy")</strong>
            <span>Healthy filtrados</span>
        </div>

        <div class="info">
            <strong>@FilteredResources.Count(x => x.OperationalStatus == "Expiring Soon")</strong>
            <span>Por vencer filtrados</span>
        </div>
    </div>

    <div class="ri-resource-filters">
        <select @bind="CustomerFilter" @bind:after="ResetPage">
            <option value="">Todos los clientes</option>
            @foreach (var item in CustomerOptions)
            {
                <option value="@item">@item</option>
            }
        </select>

        <select @bind="SubscriptionFilter" @bind:after="ResetPage">
            <option value="">Todas las suscripciones</option>
            @foreach (var item in SubscriptionOptions)
            {
                <option value="@item">@item</option>
            }
        </select>

        <select @bind="StatusFilter" @bind:after="ResetPage">
            <option value="">Todos los estados</option>
            <option value="Healthy">Healthy</option>
            <option value="SKU Mismatch">SKU diferente</option>
            <option value="Date Mismatch">Fecha no coincide</option>
            <option value="Low Utilization">Baja utilización</option>
            <option value="Expiring Soon">Por vencer</option>
            <option value="Expired">Expirada</option>
        </select>

        <input placeholder="Buscar VM, cliente, suscripción o SKU..." @bind="SearchText" @bind:event="oninput" @bind:after="ResetPage" />

        <select @bind="PageSize" @bind:after="ResetPage">
            <option value="10">10 filas</option>
            <option value="20">20 filas</option>
            <option value="50">50 filas</option>
            <option value="100">100 filas</option>
        </select>

        <button class="ri-clear-btn" type="button" @onclick="ClearFilters">Limpiar</button>
    </div>

    <div class="ri-filter-summary">
        <span>Filtros activos:</span>
        <strong>@GetActiveFiltersText()</strong>
    </div>

    <div class="ri-table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Estado</th>
                    <th>Recurso</th>
                    <th>Cliente</th>
                    <th>Suscripción</th>
                    <th>SKU Reserva</th>
                    <th>SKU VM</th>
                    <th>Fecha Reserva</th>
                    <th>Fecha VM</th>
                    <th>Días</th>
                    <th>Utilización</th>
                    <th>Recomendación</th>
                    <th>Cambiado por</th>
                    <th>Fecha cambio</th>
                    <th>Acción</th>
                </tr>
            </thead>

            <tbody>
                @if (!PagedResources.Any())
                {
                    <tr>
                        <td colspan="15">
                            <div class="ri-empty-table">
                                No hay registros para los filtros seleccionados.
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in PagedResources)
                {
                    <tr class="@GetRowClass(item)">
                        <td>
                            <span class="@GetStatusClass(item.OperationalStatus)">
                                @GetStatusText(item.OperationalStatus)
                            </span>
                        </td>

                        <td>
                            <div class="ri-resource-name">@item.ResourceName</div>
                            <small>@(string.IsNullOrWhiteSpace(item.Region) ? "-" : item.Region)</small>
                        </td>

                        <td>@item.Customer</td>
                        <td>@item.Subscription</td>

                        <td><span class="ri-sku">@item.SKUReserva</span></td>
                        <td><span class="ri-sku">@item.SKUVM</span></td>

                        <td>@(item.FechaReserva?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td>@(item.FechaVM?.ToString("dd/MM/yyyy") ?? "-")</td>

                        <td>
                            <span class="@GetDaysClass(item)">
                                @(item.DaysRemaining?.ToString() ?? "-")
                            </span>
                        </td>

                        <td>
                            <div class="ri-util-wrap">
                                <div class="ri-util-track">
                                    <div class="@GetUtilBarClass(item.Utilization30d)" style="width:@GetUtilWidth(item.Utilization30d)"></div>
                                </div>

                                <span class="@GetUtilClass(item.Utilization30d)">
                                    @((item.Utilization30d ?? 0).ToString("N2"))%
                                </span>
                            </div>
                        </td>

                        <td>
                            <span class="ri-recommendation-pill">
                                @GetRecommendation(item)
                            </span>
                        </td>

                        <td>
                            @if (string.IsNullOrWhiteSpace(item.LastChangedBy))
                            {
                                <span class="ri-muted">Sin dato</span>
                            }
                            else
                            {
                                <span class="ri-user">@item.LastChangedBy</span>
                            }
                        </td>

                        <td>@(item.LastChangeDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>

                        <td>
                            <button class="ri-detail-btn ri-icon-btn" type="button" title="Ver detalle" @onclick="() => OpenDrawer(item)">
                                👁
                            </button>
                        </td>
                    </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="ri-table-footer">
        <div class="ri-table-footer-info">
            Mostrando <strong>@PagedResources.Count()</strong> de <strong>@TotalRecords</strong> registros
            <span>Página @CurrentPage de @TotalPages</span>
        </div>

        <div class="ri-pagination-actions">
            <button type="button" @onclick="FirstPage" disabled="@(CurrentPage == 1)">«</button>
            <button type="button" @onclick="PrevPage" disabled="@(CurrentPage == 1)">‹</button>

            @foreach (var pageNumber in VisiblePages)
            {
                <button type="button"
                        class="@(pageNumber == CurrentPage ? "active" : "")"
                        @onclick="() => GoToPage(pageNumber)">
                    @pageNumber
                </button>
            }

            <button type="button" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">›</button>
            <button type="button" @onclick="LastPage" disabled="@(CurrentPage >= TotalPages)">»</button>
        </div>
    </div>

</section>

@if (SelectedResource is not null)
{
    <div class="ri-drawer-backdrop" @onclick="CloseDrawer"></div>

    <aside class="ri-drawer">
        <div class="ri-drawer-header">
            <div>
                <span>Reserved Instance Detail</span>
                <h3>@SelectedResource.ResourceName</h3>
                <p>@SelectedResource.Customer | @SelectedResource.Subscription</p>
            </div>

            <button type="button" @onclick="CloseDrawer">×</button>
        </div>

        <div class="ri-drawer-section">
            <h4>Estado operativo</h4>

            <div class="ri-drawer-status">
                <span class="@GetStatusClass(SelectedResource.OperationalStatus)">
                    @GetStatusText(SelectedResource.OperationalStatus)
                </span>

                <strong>@SelectedResource.Issue</strong>
            </div>
        </div>

        <div class="ri-drawer-grid">
            <div>
                <span>SKU Reserva</span>
                <strong>@SelectedResource.SKUReserva</strong>
            </div>

            <div>
                <span>SKU VM</span>
                <strong>@SelectedResource.SKUVM</strong>
            </div>

            <div>
                <span>Fecha Reserva</span>
                <strong>@(SelectedResource.FechaReserva?.ToString("dd/MM/yyyy") ?? "-")</strong>
            </div>

            <div>
                <span>Fecha VM</span>
                <strong>@(SelectedResource.FechaVM?.ToString("dd/MM/yyyy") ?? "-")</strong>
            </div>

            <div>
                <span>Días para vencer</span>
                <strong>@(SelectedResource.DaysRemaining?.ToString() ?? "-")</strong>
            </div>

            <div>
                <span>Utilización 30 días</span>
                <strong>@((SelectedResource.Utilization30d ?? 0).ToString("N2"))%</strong>
            </div>
        </div>

        <div class="ri-drawer-section">
            <h4>Auditoría</h4>

            <div class="ri-audit-list">
                <div>
                    <span>Cambiado por</span>
                    <strong>@(string.IsNullOrWhiteSpace(SelectedResource.LastChangedBy) ? "Sin dato" : SelectedResource.LastChangedBy)</strong>
                </div>

                <div>
                    <span>Fecha cambio</span>
                    <strong>@(SelectedResource.LastChangeDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</strong>
                </div>

                <div>
                    <span>Último scan</span>
                    <strong>@(SelectedResource.LastScanDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</strong>
                </div>
            </div>
        </div>

        <div class="ri-drawer-section">
            <h4>Reserva</h4>

            <div class="ri-audit-list">
                <div>
                    <span>Reservation Name</span>
                    <strong>@(string.IsNullOrWhiteSpace(SelectedResource.ReservationName) ? "-" : SelectedResource.ReservationName)</strong>
                </div>

                <div>
                    <span>Reservation ID</span>
                    <strong>@(string.IsNullOrWhiteSpace(SelectedResource.ReservationId) ? "-" : SelectedResource.ReservationId)</strong>
                </div>

                <div>
                    <span>Order ID</span>
                    <strong>@(string.IsNullOrWhiteSpace(SelectedResource.ReservationOrderId) ? "-" : SelectedResource.ReservationOrderId)</strong>
                </div>

                <div>
                    <span>Scope</span>
                    <strong>@(string.IsNullOrWhiteSpace(SelectedResource.AppliedScope) ? "-" : SelectedResource.AppliedScope)</strong>
                </div>
            </div>
        </div>
    </aside>
}

@code {
    [Parameter] public List<ReservedInstanceResource> Resources { get; set; } = new();

    private string CustomerFilter { get; set; } = "";
    private string SubscriptionFilter { get; set; } = "";
    private string StatusFilter { get; set; } = "";
    private string SearchText { get; set; } = "";

    private ReservedInstanceResource? SelectedResource { get; set; }

private int CurrentPage = 1;
private int PageSize = 20;

private int TotalPages =>
    Math.Max(1, (int)Math.Ceiling((double)FilteredResources.Count() / PageSize));

private IEnumerable<ReservedInstanceResource> PagedResources =>
    FilteredResources
        .Skip((CurrentPage - 1) * PageSize)
        .Take(PageSize);


    private IEnumerable<string> CustomerOptions =>
        Resources.Select(x => x.Customer)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .OrderBy(x => x);

    private IEnumerable<string> SubscriptionOptions =>
        Resources.Select(x => x.Subscription)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .OrderBy(x => x);

    private IEnumerable<ReservedInstanceResource> FilteredResources =>
        Resources.Where(x =>
            (string.IsNullOrWhiteSpace(CustomerFilter) || x.Customer == CustomerFilter) &&
            (string.IsNullOrWhiteSpace(SubscriptionFilter) || x.Subscription == SubscriptionFilter) &&
            (string.IsNullOrWhiteSpace(StatusFilter) || x.OperationalStatus == StatusFilter) &&
            (
                string.IsNullOrWhiteSpace(SearchText) ||
                x.ResourceName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                x.Customer.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                x.Subscription.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                x.SKUReserva.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                x.SKUVM.Contains(SearchText, StringComparison.OrdinalIgnoreCase)
            )
        );

    private string GetActiveFiltersText()
    {
        var filters = new List<string>();

        if (!string.IsNullOrWhiteSpace(CustomerFilter))
            filters.Add($"Cliente: {CustomerFilter}");

        if (!string.IsNullOrWhiteSpace(SubscriptionFilter))
            filters.Add($"Suscripción: {SubscriptionFilter}");

        if (!string.IsNullOrWhiteSpace(StatusFilter))
            filters.Add($"Estado: {GetStatusText(StatusFilter)}");

        if (!string.IsNullOrWhiteSpace(SearchText))
            filters.Add($"Búsqueda: {SearchText}");

        return filters.Count == 0 ? "Ninguno" : string.Join(" | ", filters);
    }
    private void FirstPage() => CurrentPage = 1;

private void PreviousPage()
{
    if (CurrentPage > 1)
        CurrentPage--;
}

private void NextPage()
{
    if (CurrentPage < TotalPages)
        CurrentPage++;
}

private void LastPage()
{
    CurrentPage = TotalPages;
}

private void ResetPage()
{
    CurrentPage = 1;
}

private void ClearFilters()
    {
        CustomerFilter = "";
        SubscriptionFilter = "";
        StatusFilter = "";
        SearchText = "";
    }

    private async Task ExportCsv()
    {
        var rows = FilteredResources.ToList();

        var csv = new System.Text.StringBuilder();

        csv.AppendLine("Estado,Riesgo,Recurso,Cliente,Suscripcion,SKU Reserva,SKU VM,Fecha Reserva,Fecha VM,Dias,Utilizacion,Recomendacion,Cambiado Por,Fecha Cambio");

        foreach (var item in rows)
        {
            csv.AppendLine(string.Join(",",
                Csv(GetStatusText(item.OperationalStatus)),
                Csv(GetRiskText(item)),
                Csv(item.ResourceName),
                Csv(item.Customer),
                Csv(item.Subscription),
                Csv(item.SKUReserva),
                Csv(item.SKUVM),
                Csv(item.FechaReserva?.ToString("dd/MM/yyyy") ?? ""),
                Csv(item.FechaVM?.ToString("dd/MM/yyyy") ?? ""),
                Csv(item.DaysRemaining?.ToString() ?? ""),
                Csv((item.Utilization30d ?? 0).ToString("N2") + "%"),
                Csv(GetRecommendation(item)),
                Csv(item.LastChangedBy),
                Csv(item.LastChangeDate?.ToString("dd/MM/yyyy HH:mm") ?? "")
            ));
        }

        var bytes = System.Text.Encoding.UTF8.GetBytes(csv.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"reserved-instance-resources-{DateTime.Now:yyyyMMddHHmm}.csv";

        await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, "text/csv;charset=utf-8", base64);
    }

    private static string Csv(string? value)
    {
        value ??= "";
        value = value.Replace("\"", "\"\"");
        return $"\"{value}\"";
    }
    private void OpenDrawer(ReservedInstanceResource item)
    {
        SelectedResource = item;
    }

    private void CloseDrawer()
    {
        SelectedResource = null;
    }

    private static string GetRecommendation(ReservedInstanceResource item)
    {
        if (item.OperationalStatus == "Expired") return "Renovar o validar reemplazo";
        if (item.OperationalStatus == "SKU Mismatch") return "Validar SKU asociado";
        if (item.OperationalStatus == "Date Mismatch") return "Revisar fechas de reserva";
        if (item.OperationalStatus == "Low Utilization") return "Revisar ajuste o intercambio";
        if (item.OperationalStatus == "Expiring Soon") return "Planificar renovación";
        if ((item.Utilization30d ?? 0) >= 80) return "Mantener reserva";

        return "Monitorear";
    }
    private static string GetRowClass(ReservedInstanceResource item)
    {
        return item.OperationalStatus switch
        {
            "Expired" => "ri-row-danger",
            "SKU Mismatch" => "ri-row-warning",
            "Date Mismatch" => "ri-row-warning",
            "Low Utilization" => "ri-row-purple",
            "Expiring Soon" => "ri-row-info",
            _ => ""
        };
    }

    private static string GetRiskText(ReservedInstanceResource item)
    {
        if (item.OperationalStatus == "Expired") return "Crítico";
        if (item.OperationalStatus == "SKU Mismatch") return "Alto";
        if (item.OperationalStatus == "Date Mismatch") return "Alto";
        if (item.DaysRemaining <= 30) return "Alto";
        if (item.DaysRemaining <= 90) return "Medio";
        if ((item.Utilization30d ?? 0) < 50) return "Medio";

        return "Bajo";
    }
    private static string GetStatusText(string status) => status switch
    {
        "Healthy" => "Healthy",
        "SKU Mismatch" => "SKU diferente",
        "Date Mismatch" => "Fecha no coincide",
        "Low Utilization" => "Baja utilización",
        "Expiring Soon" => "Por vencer",
        "Expired" => "Expirada",
        _ => status
    };

    private static string GetStatusClass(string status) => status switch
    {
        "Healthy" => "ri-badge success",
        "SKU Mismatch" => "ri-badge warning",
        "Date Mismatch" => "ri-badge danger",
        "Low Utilization" => "ri-badge purple",
        "Expiring Soon" => "ri-badge info",
        "Expired" => "ri-badge danger",
        _ => "ri-badge"
    };

    private static string GetUtilClass(decimal? value)
    {
        var v = value ?? 0;
        return v < 80 ? "ri-pill danger" : "ri-pill success";
    }

    private static string GetUtilBarClass(decimal? value)
    {
        var v = value ?? 0;

        if (v < 50) return "ri-util-fill danger";
        if (v < 80) return "ri-util-fill warning";
        return "ri-util-fill success";
    }

    private static string GetUtilWidth(decimal? value)
    {
        var v = value ?? 0;

        if (v < 0) v = 0;
        if (v > 100) v = 100;

        return $"{v:N0}%";
    }

    private static string GetDaysClass(ReservedInstanceResource item)
    {
        if (item.DaysRemaining is null) return "ri-pill muted";
        if (item.DaysRemaining < 0) return "ri-pill danger";
        if (item.DaysRemaining <= 90) return "ri-pill warning";
        return "ri-pill success";
    }
    private int TotalRecords => FilteredResources.Count();

    private IEnumerable<int> VisiblePages
    {
        get
        {
            var start = Math.Max(1, CurrentPage - 2);
            var end = Math.Min(TotalPages, CurrentPage + 2);

            for (var i = start; i <= end; i++)
            {
                yield return i;
            }
        }
    }

    private void GoToPage(int pageNumber)
    {
        CurrentPage = pageNumber;
    }
private void PrevPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
        }
    }

}


