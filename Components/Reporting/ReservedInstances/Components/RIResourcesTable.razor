@namespace ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Components

@using System.Text
@using System.Globalization
@using Microsoft.JSInterop
@using ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Models

@inject IJSRuntime JS

<section class="ri-card ri-resources">

    <div class="ri-card-header ri-resource-header">
        <div>
            <h3>Reserved Instance Resources</h3>
            <p>Validación operativa de SKU, fechas, utilización, vencimiento y auditoría.</p>
        </div>

        <button class="ri-export-btn" type="button" @onclick="ExportCsvAsync">
            Exportar CSV
        </button>
    </div>

        <div class="ri-resource-summary">
        <button class="primary ri-summary-action" type="button" @onclick='() => ApplyQuickFilter("")'>
            <strong>@Resources.Count</strong>
            <span>Total de recursos</span>
        </button>

        <button class="danger ri-summary-action" type="button" @onclick='() => ApplyQuickFilter("Action")'>
            <strong>@Resources.Count(x => x.OperationalStatus != "Healthy")</strong>
            <span>Requiere accion</span>
        </button>

        <button class="success ri-summary-action" type="button" @onclick='() => ApplyQuickFilter("Healthy")'>
            <strong>@Resources.Count(x => x.OperationalStatus == "Healthy")</strong>
            <span>Recursos Healthy</span>
        </button>

        <button class="info ri-summary-action" type="button" @onclick='() => ApplyQuickFilter("ExpiringSoon")'>
            <strong>@Resources.Count(x => x.ExpiresSoon == true || x.OperationalStatus == "Expiring Soon")</strong>
            <span>IR por vencer</span>
        </button>
    </div>

    <div class="ri-resource-filters">
        <select @bind="SubscriptionFilter">
            <option value="">Todas las suscripciones</option>
            @foreach (var item in SubscriptionOptions)
            {
                <option value="@item">@item</option>
            }
        </select>

        <select @bind="StatusFilter">
            <option value="">Todos los estados</option>
            <option value="Healthy">Healthy</option>
            <option value="SKU Mismatch">SKU diferente</option>
            <option value="Date Mismatch">Fecha no coincide</option>
            <option value="Low Utilization">Baja utilización</option>
            <option value="Expiring Soon">Por vencer</option>
            <option value="Expired">Expirada</option>
            <option value="Validate">Validar</option>
        </select>

        <input placeholder="Buscar VM, cliente, suscripción o SKU..." @bind="SearchText" @bind:event="oninput" />

        <select @onchange="ChangePageSize" value="@PageSize">
            <option value="20">20 filas</option>
            <option value="50">50 filas</option>
            <option value="100">100 filas</option>
        </select>

        <button class="ri-clear-btn" type="button" @onclick="ClearFilters">Limpiar</button>
    </div>

    <div class="ri-active-filters">
        Filtros activos:
        <strong>@GetActiveFiltersText()</strong>
    </div>

    <div class="ri-table-wrap">
        <table>
                        <thead>
                <tr>
                    <th><button class="ri-sort" @onclick='() => SortBy("Subscription")'>Suscripción @GetSortIcon("Subscription")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("Resource")'>Recurso @GetSortIcon("Resource")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("SKUReserva")'>SKU Reserva @GetSortIcon("SKUReserva")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("SKUVM")'>SKU VM @GetSortIcon("SKUVM")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("FechaReserva")'>Fecha Reserva @GetSortIcon("FechaReserva")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("FechaVM")'>Fecha VM @GetSortIcon("FechaVM")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("Days")'>Días @GetSortIcon("Days")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("Utilization")'>Utilización @GetSortIcon("Utilization")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("Status")'>Estado @GetSortIcon("Status")</button></th>
                    <th>Recomendación</th>
                </tr>
            </thead>

                        <tbody>
                @foreach (var item in PagedResources)
                {
                    <tr>
                        <td>@Normalize(item.Subscription)</td>

                        <td>
                            <div class="ri-resource-name">@Normalize(item.ResourceName)</div>
                            <small>@Normalize(item.Region)</small>
                        </td>

                        <td><span class="ri-sku">@Normalize(item.SKUReserva)</span></td>
                        <td><span class="ri-sku">@Normalize(item.SKUVM)</span></td>
                        <td>@(item.FechaReserva?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td>@(item.FechaVM?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td><span class="@GetDaysClass(item)">@(item.DaysRemaining?.ToString() ?? "-")</span></td>
                        <td><span class="@GetUtilClass(item.Utilization30d)">@((item.Utilization30d ?? 0).ToString("N2"))%</span></td>
                        <td><span class="@GetStatusClass(item.OperationalStatus)">@GetStatusText(item.OperationalStatus)</span></td>
                        <td><span class="@GetRecommendationClass(item)">@GetRecommendation(item)</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="ri-table-footer">
        <div class="ri-table-footer-info">
            Mostrando <strong>@PagedResources.Count()</strong> de <strong>@TotalRecords</strong> registros
            <span>Página @CurrentPage de @TotalPages</span>
        </div>

        <div class="ri-pagination-actions">
            <button type="button" @onclick="FirstPage" disabled="@(CurrentPage == 1)">«</button>
            <button type="button" @onclick="PrevPage" disabled="@(CurrentPage == 1)">‹</button>

            @foreach (var pageNumber in VisiblePages)
            {
                <button type="button"
                        class="@(pageNumber == CurrentPage ? "active" : "")"
                        @onclick="() => GoToPage(pageNumber)">
                    @pageNumber
                </button>
            }

            <button type="button" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">›</button>
            <button type="button" @onclick="LastPage" disabled="@(CurrentPage >= TotalPages)">»</button>
        </div>
    </div>

</section>

@if (SelectedResource is not null)
{
    <div class="ri-drawer-backdrop" @onclick="CloseDrawer"></div>

    <aside class="ri-drawer">
        <div class="ri-drawer-header">
            <div>
                <span>Reserved Instance Detail</span>
                <h3>@SelectedResource.ResourceName</h3>
                <p>@SelectedResource.Customer | @SelectedResource.Subscription</p>
            </div>

            <button type="button" @onclick="CloseDrawer">×</button>
        </div>

        <div class="ri-drawer-section">
            <h4>Estado operativo</h4>
            <div class="ri-drawer-status">
                <span class="@GetStatusClass(SelectedResource.OperationalStatus)">
                    @GetStatusText(SelectedResource.OperationalStatus)
                </span>
                <strong>@SelectedResource.Issue</strong>
                <small>@GetRecommendation(SelectedResource)</small>
            </div>
        </div>

        <div class="ri-drawer-section">
            <h4>Comparación</h4>

            <div class="ri-drawer-grid">
                <div><span>SKU Reserva</span><strong>@Normalize(SelectedResource.SKUReserva)</strong></div>
                <div><span>SKU Actual</span><strong>@Normalize(SelectedResource.SKUVM)</strong></div>
                <div><span>Fecha Reserva</span><strong>@(SelectedResource.FechaReserva?.ToString("dd/MM/yyyy") ?? "-")</strong></div>
                <div><span>Fecha VM</span><strong>@(SelectedResource.FechaVM?.ToString("dd/MM/yyyy") ?? "-")</strong></div>
                <div><span>Días para vencer</span><strong>@(SelectedResource.DaysRemaining?.ToString() ?? "-")</strong></div>
                <div><span>Utilización 30 días</span><strong>@((SelectedResource.Utilization30d ?? 0).ToString("N2"))%</strong></div>
            </div>
        </div>

        <div class="ri-drawer-section">
            <h4>Auditoría</h4>

            <div class="ri-audit-list">
                <div><span>Cambiado por</span><strong>@(string.IsNullOrWhiteSpace(SelectedResource.LastChangedBy) ? "Sin dato" : SelectedResource.LastChangedBy)</strong></div>
                <div><span>Fecha cambio</span><strong>@(SelectedResource.LastChangeDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</strong></div>
                <div><span>Último scan</span><strong>@(SelectedResource.LastScanDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</strong></div>
            </div>
        </div>
    </aside>
}

@code {
    [Parameter] public List<ReservedInstanceResource> Resources { get; set; } = new();
    [Parameter] public string InitialFilter { get; set; } = "";
    [Parameter] public EventCallback<string> OnChangeTab { get; set; }

    private string SubscriptionFilter { get; set; } = "";
    private string StatusFilter { get; set; } = "";
    private string QuickFilter { get; set; } = "";
    private string SearchText { get; set; } = "";

    private ReservedInstanceResource? SelectedResource { get; set; }

    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 20;
    private string SortColumn { get; set; } = "Status";
    private bool SortAscending { get; set; } = true;

    private IEnumerable<string> SubscriptionOptions =>
        Resources.Select(x => x.Subscription)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .OrderBy(x => x);

    private IEnumerable<ReservedInstanceResource> QuickFilteredResources =>
        QuickFilter switch
        {
            "Action" => Resources.Where(x => x.OperationalStatus != "Healthy"),
            "Healthy" => Resources.Where(x => x.OperationalStatus == "Healthy"),
            "ExpiringSoon" => Resources.Where(x => x.ExpiresSoon == true || x.OperationalStatus == "Expiring Soon"),
            _ => Resources
        };

    private IEnumerable<ReservedInstanceResource> FilteredResources =>
        QuickFilteredResources.Where(x =>
            (string.IsNullOrWhiteSpace(SubscriptionFilter) || x.Subscription == SubscriptionFilter) &&
            (string.IsNullOrWhiteSpace(StatusFilter) || x.OperationalStatus == StatusFilter) &&
            (
                string.IsNullOrWhiteSpace(SearchText) ||
                ContainsSafe(x.ResourceName, SearchText) ||
                ContainsSafe(x.Customer, SearchText) ||
                ContainsSafe(x.Subscription, SearchText) ||
                ContainsSafe(x.SKUReserva, SearchText) ||
                ContainsSafe(x.SKUVM, SearchText)
            )
        );

    private IEnumerable<ReservedInstanceResource> OrderedResources =>
        SortColumn switch
        {
            "Subscription" => SortAscending ? FilteredResources.OrderBy(x => x.Subscription) : FilteredResources.OrderByDescending(x => x.Subscription),
            "Resource" => SortAscending ? FilteredResources.OrderBy(x => x.ResourceName) : FilteredResources.OrderByDescending(x => x.ResourceName),
            "SKUReserva" => SortAscending ? FilteredResources.OrderBy(x => x.SKUReserva) : FilteredResources.OrderByDescending(x => x.SKUReserva),
            "SKUVM" => SortAscending ? FilteredResources.OrderBy(x => x.SKUVM) : FilteredResources.OrderByDescending(x => x.SKUVM),
            "FechaReserva" => SortAscending ? FilteredResources.OrderBy(x => x.FechaReserva) : FilteredResources.OrderByDescending(x => x.FechaReserva),
            "FechaVM" => SortAscending ? FilteredResources.OrderBy(x => x.FechaVM) : FilteredResources.OrderByDescending(x => x.FechaVM),
            "Days" => SortAscending ? FilteredResources.OrderBy(x => x.DaysRemaining) : FilteredResources.OrderByDescending(x => x.DaysRemaining),
            "Utilization" => SortAscending ? FilteredResources.OrderBy(x => x.Utilization30d) : FilteredResources.OrderByDescending(x => x.Utilization30d),
            "Status" => SortAscending ? FilteredResources.OrderBy(x => x.OperationalStatus) : FilteredResources.OrderByDescending(x => x.OperationalStatus),
            _ => FilteredResources.OrderBy(x => x.Subscription).ThenBy(x => x.ResourceName)
        };
    private IEnumerable<ReservedInstanceResource> PagedResources =>
        OrderedResources.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private int TotalRecords => FilteredResources.Count();

    private int TotalPages =>
        Math.Max(1, (int)Math.Ceiling(TotalRecords / (double)PageSize));

    private IEnumerable<int> VisiblePages
    {
        get
        {
            var start = Math.Max(1, CurrentPage - 2);
            var end = Math.Min(TotalPages, CurrentPage + 2);

            for (var i = start; i <= end; i++)
            {
                yield return i;
            }
        }
    }

    private void SortBy(string column)
    {
        if (SortColumn == column)
        {
            SortAscending = !SortAscending;
        }
        else
        {
            SortColumn = column;
            SortAscending = true;
        }

        CurrentPage = 1;
    }

    private string GetSortIcon(string column)
    {
        if (SortColumn != column)
        {
            return "↕";
        }

        return SortAscending ? "↑" : "↓";
    }

    private void GoToPage(int pageNumber) => CurrentPage = pageNumber;
    private void FirstPage() => CurrentPage = 1;
    private void LastPage() => CurrentPage = TotalPages;
    private void NextPage() { if (CurrentPage < TotalPages) CurrentPage++; }
    private void PrevPage() { if (CurrentPage > 1) CurrentPage--; }

    private async Task OpenResourcesTab()
    {
        await OnChangeTab.InvokeAsync("Resources");
    }

    private async Task OpenActionTab()
    {
        await OnChangeTab.InvokeAsync("Action");
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(InitialFilter))
        {
            QuickFilter = InitialFilter;
            StatusFilter = "";
            CurrentPage = 1;
        }
    }

    private void ApplyQuickFilter(string filter)
    {
        QuickFilter = filter;
        StatusFilter = "";
        SubscriptionFilter = "";
        SearchText = "";
        CurrentPage = 1;
    }

    private void ClearFilters()
    {
        SubscriptionFilter = "";
        StatusFilter = "";
        QuickFilter = "";
        SearchText = "";
        QuickFilter = "";
        CurrentPage = 1;
    }

    private void ChangePageSize(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
        {
            PageSize = value;
            CurrentPage = 1;
        }
    }

    private void OpenDrawer(ReservedInstanceResource item) => SelectedResource = item;
    private void CloseDrawer() => SelectedResource = null;

    private string GetActiveFiltersText()
    {
        var filters = new List<string>();

        if (!string.IsNullOrWhiteSpace(SubscriptionFilter)) filters.Add($"Suscripción: {SubscriptionFilter}");
        if (!string.IsNullOrWhiteSpace(StatusFilter)) filters.Add($"Estado: {GetStatusText(StatusFilter)}");
        if (!string.IsNullOrWhiteSpace(SearchText)) filters.Add($"Búsqueda: {SearchText}");

        return filters.Any() ? string.Join(" | ", filters) : "Ninguno";
    }

    private async Task ExportCsvAsync()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Estado,Recurso,Cliente,Suscripcion,SKUReserva,SKUActual,FechaReserva,FechaVM,Dias,Utilizacion,Recomendacion,CambiadoPor,FechaCambio");

        foreach (var item in OrderedResources)
        {
            sb.AppendLine(string.Join(",",
                Csv(GetStatusText(item.OperationalStatus)),
                Csv(item.ResourceName),
                Csv(item.Customer),
                Csv(item.Subscription),
                Csv(item.SKUReserva),
                Csv(item.SKUVM),
                Csv(item.FechaReserva?.ToString("dd/MM/yyyy") ?? "-"),
                Csv(item.FechaVM?.ToString("dd/MM/yyyy") ?? "-"),
                Csv(item.DaysRemaining?.ToString() ?? "-"),
                Csv((item.Utilization30d ?? 0).ToString("N2")),
                Csv(GetRecommendation(item)),
                Csv(string.IsNullOrWhiteSpace(item.LastChangedBy) ? "Sin dato" : item.LastChangedBy),
                Csv(item.LastChangeDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")
            ));
        }

        var fileName = $"reserved-instances-{DateTime.Now:yyyyMMddHHmm}.csv";
        var data = Uri.EscapeDataString(sb.ToString());

        await JS.InvokeVoidAsync("eval", $"const a=document.createElement('a');a.href='data:text/csv;charset=utf-8,{data}';a.download='{fileName}';document.body.appendChild(a);a.click();a.remove();");
    }

    private static string Csv(string? value)
    {
        value ??= "";
        return "\"" + value.Replace("\"", "\"\"") + "\"";
    }

    private static bool ContainsSafe(string? value, string search) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(search, StringComparison.OrdinalIgnoreCase);

    private static string Normalize(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string GetStatusText(string? status) => status switch
    {
        "Healthy" => "Healthy",
        "SKU Mismatch" => "SKU diferente",
        "Date Mismatch" => "Fecha no coincide",
        "Low Utilization" => "Baja utilización",
        "Expiring Soon" => "Por vencer",
        "Expired" => "Expirada",
        "Validate" => "Validar",
        _ => string.IsNullOrWhiteSpace(status) ? "Sin estado" : status
    };

    private static string GetStatusClass(string? status) => status switch
    {
        "Healthy" => "ri-badge success",
        "SKU Mismatch" => "ri-badge warning",
        "Date Mismatch" => "ri-badge purple",
        "Low Utilization" => "ri-badge danger",
        "Expiring Soon" => "ri-badge info",
        "Expired" => "ri-badge danger",
        "Validate" => "ri-badge muted",
        _ => "ri-badge muted"
    };

    private static string GetUtilClass(decimal? value)
    {
        var v = value ?? 0;
        return v < 80 ? "ri-pill danger" : "ri-pill success";
    }

    private static string GetDaysClass(ReservedInstanceResource item)
    {
        if (item.DaysRemaining is null) return "ri-pill muted";
        if (item.DaysRemaining < 0) return "ri-pill danger";
        if (item.DaysRemaining <= 90) return "ri-pill warning";
        return "ri-pill success";
    }

    private static string GetRecommendationClass(ReservedInstanceResource item) => item.OperationalStatus switch
    {
        "SKU Mismatch" => "ri-recommendation-pill danger",
        "Date Mismatch" => "ri-recommendation-pill danger",
        "Low Utilization" => "ri-recommendation-pill danger",
        "Expired" => "ri-recommendation-pill danger",
        "Validate" => "ri-recommendation-pill danger",
        "Expiring Soon" => "ri-recommendation-pill warning",
        "Healthy" => "ri-recommendation-pill success",
        _ => "ri-recommendation-pill"
    };

    private static string GetRecommendation(ReservedInstanceResource item) => item.OperationalStatus switch
    {
        "Healthy" => "Mantener reserva",
        "SKU Mismatch" => "Validar SKU asociado",
        "Date Mismatch" => "Revisar fechas de reserva",
        "Low Utilization" => "Revisar baja utilización",
        "Expiring Soon" => "Planificar renovación",
        "Expired" => "Renovar o liberar reserva",
        "Validate" => "Validación manual requerida",
        _ => "Revisar recurso"
    };
}














