@namespace ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Components
@using ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Models

<div class="ri-kpi-grid">

    <div class="ri-kpi">
        <span>Recursos RI</span>
        <strong>@Dashboard.Kpis.TotalResources</strong>
        <small>Recursos monitoreados</small>
    </div>

    <div class="ri-kpi">
        <span>Clientes con RI</span>
        <strong>@Dashboard.Kpis.TotalCustomers</strong>
        <small>Clientes con reservas</small>
    </div>

    <div class="ri-kpi ri-kpi-health">
        <span>Health Score</span>
        <strong>@Dashboard.Kpis.AvgUtilization.ToString("N2")%</strong>
        <small>Estado general</small>
    </div>

    <div class="ri-kpi ri-kpi-success">
        <span>Healthy</span>
        <strong>@Dashboard.Kpis.HealthyCount</strong>
        <small>Sin problemas detectados</small>
    </div>

    <div class="ri-kpi ri-kpi-danger">
        <span>Reservas con problemas</span>
        <strong>@(Dashboard.Kpis.SkuMismatchCount + Dashboard.Kpis.DateMismatchCount + Dashboard.Kpis.LowUtilizationCount + Dashboard.Kpis.ExpiringSoonCount + Dashboard.Kpis.ExpiredCount)</strong>
        <small>Requieren revisión</small>
    </div>

    <div class="ri-kpi ri-kpi-warning">
        <span>Por vencer</span>
        <strong>@Dashboard.Kpis.ExpiringSoonCount</strong>
        <small>Menos de 90 días</small>
    </div>

</div>

@code {
    [Parameter] public ReservedInstanceDashboard Dashboard { get; set; } = new();
}
