@namespace ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Components

@using System.Text
@using Microsoft.JSInterop
@using ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Models

@inject IJSRuntime JS

<section class="ri-analysis-page">

    <div class="ri-analysis-hero">
        <div>
            <h2>Análisis IR</h2>
            <p>Análisis de causa raíz, prioridad, categoría de optimización y recomendación operativa.</p>
        </div>

        <button class="ri-export-btn" type="button" @onclick="ExportCsvAsync">
    <svg xmlns="http://www.w3.org/2000/svg"
         width="18"
         height="18"
         viewBox="0 0 24 24"
         fill="none"
         stroke="currentColor"
         stroke-width="2">

        <path d="M12 3v12"/>
        <path d="M7 10l5 5 5-5"/>
        <path d="M4 21h16"/>

    </svg>

    <span>Exportar CSV</span>
</button>
    </div>

    <div class="ri-analysis-kpis">
        <button type="button" class="ri-analysis-kpi danger" @onclick='() => ApplyQuickFilter("")'>
            <strong>@AnalysisResources.Count</strong>
            <span>Total análisis</span>
        </button>

        <button type="button" class="ri-analysis-kpi warning" @onclick='() => ApplyQuickFilter("High")'>
            <strong>@AnalysisResources.Count(x => x.PriorityLevel == "High")</strong>
            <span>Alta prioridad</span>
        </button>

        <button type="button" class="ri-analysis-kpi info" @onclick='() => ApplyQuickFilter("Review")'>
            <strong>@AnalysisResources.Count(x => x.OptimizationCategory == "Review" || x.OptimizationCategory == "PendingReview")</strong>
            <span>Revisión</span>
        </button>

        <button type="button" class="ri-analysis-kpi success" @onclick='() => ApplyQuickFilter("Healthy")'>
            <strong>@AnalysisResources.Count(x => x.OptimizationCategory == "Healthy" || x.CauseCode == "NORMAL_UTILIZATION")</strong>
            <span>Healthy</span>
        </button>
    </div>

    <div class="ri-analysis-filters">
        
        <select @bind="SubscriptionFilter">
            <option value="">Todas las suscripciones</option>
            @foreach (var item in SubscriptionOptions)
            {
                <option value="@item">@item</option>
            }
        </select>

        <select @bind="PriorityFilter">
            <option value="">Todas las prioridades</option>
            <option value="High">High</option>
            <option value="Medium">Medium</option>
            <option value="Low">Low</option>
        </select>

        <select @bind="CategoryFilter">
            <option value="">Todas las categorías</option>
            <option value="Healthy">Healthy</option>
            <option value="Review">Review</option>
            <option value="PendingReview">PendingReview</option>
            <option value="Waste">Waste</option>
            <option value="Oversized">Oversized</option>
        </select>

        <input placeholder="Buscar recurso, causa, recomendación o SKU..." @bind="SearchText" @bind:event="oninput" />

        <button class="ri-clear-btn" type="button" @onclick="ClearFilters">Limpiar</button>
    </div>

    <div class="ri-active-filters">
        Filtros activos:
        <strong>@GetActiveFiltersText()</strong>
    </div>

    <div class="ri-table-wrap">
        <table>
            <thead>
                <tr>
                    <th><button class="ri-sort" @onclick='() => SortBy("Priority")'>Prioridad @GetSortIcon("Priority")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("Subscription")'>Suscripción @GetSortIcon("Subscription")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("Resource")'>Recurso @GetSortIcon("Resource")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("Sku")'>SKU @GetSortIcon("Sku")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("Cause")'>Causa @GetSortIcon("Cause")</button></th>
                    <th><button class="ri-sort" @onclick='() => SortBy("Category")'>Categoría @GetSortIcon("Category")</button></th>
                    <th>Recomendación</th>

                    <th>Notas</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in PagedResources)
                {
                    <tr>
                        <td><span class="@GetPriorityClass(item.PriorityLevel)">@Normalize(item.PriorityLevel)</span></td>
                        <td>
                            <div class="ri-analysis-main">@Normalize(item.Subscription)</div>
                            <small>@Normalize(item.Customer)</small>
                        </td>
                        <td>
                            <div class="ri-analysis-resource">@Normalize(item.ResourceName)</div>
                            <small>@Normalize(item.ServiceType)</small>
                        </td>
                        <td><span class="ri-analysis-sku">@Normalize(item.SKUReserva)</span></td>
                        <td>
                            <div class="ri-analysis-cause">@Normalize(item.CauseCode)</div>
                            <small>@Normalize(item.CauseDescription)</small>
                        </td>
                        <td><span class="@GetCategoryClass(item.OptimizationCategory)">@Normalize(item.OptimizationCategory)</span></td>
                        <td><div class="ri-analysis-recommendation">@Normalize(item.AnalysisRecommendation)</div></td>
                        <td>@(item.AnalysisUpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="ri-table-footer">
        <div>
            Mostrando <strong>@PagedResources.Count()</strong> de <strong>@FilteredResources.Count()</strong> registros
        </div>

        <div class="ri-pagination-actions">
            <button class="ri-page-btn" @onclick="PrevPage" disabled="@(CurrentPage == 1)">‹</button>

            @foreach (var pageNumber in VisiblePages)
            {
                <button class="ri-page-btn @(pageNumber == CurrentPage ? "active" : "")" @onclick="() => GoToPage(pageNumber)">
                    @pageNumber
                </button>
            }

            <button class="ri-page-btn" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">›</button>
        </div>
    </div>

</section>

@code {
    [Parameter] public List<ReservedInstanceResource> Resources { get; set; } = new();

    private string SearchText { get; set; } = "";
    private string SubscriptionFilter { get; set; } = "";
    private string PriorityFilter { get; set; } = "";
    private string CategoryFilter { get; set; } = "";
    private string QuickFilter { get; set; } = "";
    private string SortColumn { get; set; } = "Priority";
    private bool SortAscending { get; set; } = false;
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 20;

    private List<string> SubscriptionOptions =>
        AnalysisResources
            .Select(x => x.Subscription)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .OrderBy(x => x)
            .ToList()!;

    private List<ReservedInstanceResource> AnalysisResources =>
        Resources
            .Where(x => !string.IsNullOrWhiteSpace(x.CauseCode) || !string.IsNullOrWhiteSpace(x.AnalysisRecommendation))
            .ToList();

    private IEnumerable<ReservedInstanceResource> QuickFilteredResources =>
        QuickFilter switch
        {
            "High" => AnalysisResources.Where(x => x.PriorityLevel == "High"),
            "Review" => AnalysisResources.Where(x => x.OptimizationCategory == "Review" || x.OptimizationCategory == "PendingReview"),
            "Healthy" => AnalysisResources.Where(x => x.OptimizationCategory == "Healthy" || x.CauseCode == "NORMAL_UTILIZATION"),
            _ => AnalysisResources
        };

    private IEnumerable<ReservedInstanceResource> FilteredResources =>
        QuickFilteredResources.Where(x =>
            (string.IsNullOrWhiteSpace(PriorityFilter) || x.PriorityLevel == PriorityFilter) &&
            (string.IsNullOrWhiteSpace(CategoryFilter) || x.OptimizationCategory == CategoryFilter) &&
            (
                string.IsNullOrWhiteSpace(SearchText) ||
                ContainsSafe(x.ResourceName, SearchText) ||
                ContainsSafe(x.Subscription, SearchText) ||
                ContainsSafe(x.Customer, SearchText) ||
                ContainsSafe(x.SKUReserva, SearchText) ||
                ContainsSafe(x.SKUVM, SearchText) ||
                ContainsSafe(x.CauseCode, SearchText) ||
                ContainsSafe(x.AnalysisRecommendation, SearchText)
            )
        );

    private IEnumerable<ReservedInstanceResource> OrderedResources =>
        SortColumn switch
        {
            "Priority" => SortAscending ? FilteredResources.OrderBy(x => GetPriorityRank(x.PriorityLevel)) : FilteredResources.OrderByDescending(x => GetPriorityRank(x.PriorityLevel)),
            "Subscription" => SortAscending ? FilteredResources.OrderBy(x => x.Subscription) : FilteredResources.OrderByDescending(x => x.Subscription),
            "Resource" => SortAscending ? FilteredResources.OrderBy(x => x.ResourceName) : FilteredResources.OrderByDescending(x => x.ResourceName),
            "Sku" => SortAscending ? FilteredResources.OrderBy(x => x.SKUReserva) : FilteredResources.OrderByDescending(x => x.SKUReserva),
            "Cause" => SortAscending ? FilteredResources.OrderBy(x => x.CauseCode) : FilteredResources.OrderByDescending(x => x.CauseCode),
            "Category" => SortAscending ? FilteredResources.OrderBy(x => x.OptimizationCategory) : FilteredResources.OrderByDescending(x => x.OptimizationCategory),
            _ => FilteredResources
        };

    private IEnumerable<ReservedInstanceResource> PagedResources =>
        OrderedResources.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredResources.Count() / (double)PageSize));

    private IEnumerable<int> VisiblePages
    {
        get
        {
            var start = Math.Max(1, CurrentPage - 2);
            var end = Math.Min(TotalPages, CurrentPage + 2);

            for (var i = start; i <= end; i++)
                yield return i;
        }
    }

    private string GetActiveFiltersText()
    {
        var filters = new List<string>();

        if (!string.IsNullOrWhiteSpace(QuickFilter))
            filters.Add($"Filtro rápido: {QuickFilter}");

        if (!string.IsNullOrWhiteSpace(PriorityFilter))
            filters.Add($"Prioridad: {PriorityFilter}");

        if (!string.IsNullOrWhiteSpace(CategoryFilter))
            filters.Add($"Categoría: {CategoryFilter}");

        if (!string.IsNullOrWhiteSpace(SearchText))
            filters.Add($"Búsqueda: {SearchText}");

        return filters.Count == 0 ? "Ninguno" : string.Join(" | ", filters);
    }

    private void ApplyQuickFilter(string filter)
    {
        QuickFilter = filter;
        PriorityFilter = "";
        SubscriptionFilter = "";
        CategoryFilter = "";
        SearchText = "";
        CurrentPage = 1;
    }

    private void ClearFilters()
    {
        QuickFilter = "";
        PriorityFilter = "";
        SubscriptionFilter = "";
        CategoryFilter = "";
        SearchText = "";
        CurrentPage = 1;
    }

    private void SortBy(string column)
    {
        if (SortColumn == column)
            SortAscending = !SortAscending;
        else
        {
            SortColumn = column;
            SortAscending = true;
        }

        CurrentPage = 1;
    }

    private string GetSortIcon(string column)
    {
        if (SortColumn != column) return "↕";
        return SortAscending ? "↑" : "↓";
    }

    private void PrevPage()
    {
        if (CurrentPage > 1)
            CurrentPage--;
    }

    private void NextPage()
    {
        if (CurrentPage < TotalPages)
            CurrentPage++;
    }

    private void GoToPage(int page)
    {
        CurrentPage = page;
    }

    private static bool ContainsSafe(string? value, string search)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;
        return value.Contains(search, StringComparison.OrdinalIgnoreCase);
    }

    private static string Normalize(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static int GetPriorityRank(string? priority) => priority switch
    {
        "High" => 3,
        "Medium" => 2,
        "Low" => 1,
        _ => 0
    };

    private static string GetPriorityClass(string? priority) => priority switch
    {
        "High" => "ri-priority high",
        "Medium" => "ri-priority medium",
        "Low" => "ri-priority low",
        _ => "ri-priority muted"
    };

    private static string GetCategoryClass(string? category) => category switch
    {
        "Healthy" => "ri-category healthy",
        "Review" => "ri-category review",
        "PendingReview" => "ri-category review",
        "Waste" => "ri-category danger",
        "Oversized" => "ri-category warning",
        _ => "ri-category muted"
    };

    private async Task ExportCsvAsync()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Customer,Subscription,ResourceName,SKUReserva,CauseCode,Recommendation,PriorityLevel,OptimizationCategory");

        foreach (var item in FilteredResources)
        {
            sb.AppendLine(string.Join(",",
                Csv(item.Customer),
                Csv(item.Subscription),
                Csv(item.ResourceName),
                Csv(item.SKUReserva),

                Csv(item.CauseCode),
                Csv(item.AnalysisRecommendation),
                Csv(item.PriorityLevel),
                Csv(item.OptimizationCategory),

                Csv(item.OptimizationCategory)
            ));
        }

        var bytes = Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFileFromBase64", "analisis-ir.csv", base64);
    }

    private static string Csv(string? value)
    {
        value ??= "";
        value = value.Replace("\"", "\"\"");
        return $"\"{value}\"";
    }
}
















