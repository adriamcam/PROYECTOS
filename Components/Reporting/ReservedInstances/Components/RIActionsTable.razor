@namespace ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Components

@using System.Text
@using Microsoft.JSInterop
@using ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Models
@using ITQS.SupportOperationsCenter.Components.Reporting.ReservedInstances.Services

@inject IJSRuntime JS
@inject IReservedInstanceService ReservedInstanceService

<section class="ri-action-page">

    <div class="ri-action-hero">
        <div>
            <h2>Centro Operativo - Recursos que requieren acción</h2>
            <p>Recursos que requieren intervención inmediata del equipo de operaciones.</p>
        </div>

        <button class="ri-export-btn" type="button" @onclick="ExportCsvAsync">
            Exportar CSV
        </button>
    </div>

    <div class="ri-action-kpis">
        <div class="critical">
            <strong>@ActionResources.Count</strong>
            <span>Requieren acción</span>
        </div>

        <div class="critical">
            <strong>@ActionResources.Count(x => x.OperationalStatus == "SKU Mismatch")</strong>
            <span>SKU diferente</span>
        </div>

        <div class="high">
            <strong>@ActionResources.Count(x => x.OperationalStatus == "Low Utilization")</strong>
            <span>Baja utilización</span>
        </div>

        <div class="medium">
            <strong>@ActionResources.Count(x => x.OperationalStatus == "Expiring Soon")</strong>
            <span>Por vencer</span>
        </div>

        <div class="critical">
            <strong>@ActionResources.Count(x => x.OperationalStatus == "Date Mismatch")</strong>
            <span>Fecha no coincide</span>
        </div>
    </div>

    <div class="ri-action-panel">
        <div class="ri-action-filters">
            <input placeholder="Buscar recurso, cliente, suscripción o SKU..." @bind="SearchText" @bind:event="oninput" />

            <select @bind="ProblemFilter">
                <option value="">Todos los problemas</option>
                <option value="Expired">Expirada</option>
                <option value="SKU Mismatch">SKU diferente</option>
                <option value="Date Mismatch">Fecha no coincide</option>
                <option value="Low Utilization">Baja utilización</option>
                <option value="Expiring Soon">Por vencer</option>
            </select>

            <select @bind="PriorityFilter">
                <option value="">Todas las prioridades</option>
                <option value="Crítica">Crítica</option>
                <option value="Alta">Alta</option>
                <option value="Media">Media</option>
            </select>

            <select @bind="SubscriptionFilter">
                <option value="">Todas las suscripciones</option>
                @foreach (var item in SubscriptionOptions)
                {
                    <option value="@item">@item</option>
                }
            </select>

            <button class="ri-clear-btn" type="button" @onclick="ClearFilters">Limpiar filtros</button>
        </div>

        <div class="ri-table-wrap">
            <table>
                                                <thead>
                    <tr>
                        <th><button class="ri-action-sort" @onclick='() => SortBy("Priority")'>Prioridad @GetSortIcon("Priority")</button></th>
                        <th><button class="ri-action-sort" @onclick='() => SortBy("Subscription")'>Suscripción @GetSortIcon("Subscription")</button></th>
                        <th><button class="ri-action-sort" @onclick='() => SortBy("Resource")'>Recurso @GetSortIcon("Resource")</button></th>
                        <th><button class="ri-action-sort" @onclick='() => SortBy("SKUReserva")'>SKU Reserva @GetSortIcon("SKUReserva")</button></th>
                        <th><button class="ri-action-sort" @onclick='() => SortBy("SKUVM")'>SKU VM @GetSortIcon("SKUVM")</button></th>
                        <th><button class="ri-action-sort" @onclick='() => SortBy("Problem")'>Problema @GetSortIcon("Problem")</button></th>
                        <th><button class="ri-action-sort" @onclick='() => SortBy("Detail")'>Detalle @GetSortIcon("Detail")</button></th>
                        <th>Recomendación MS</th>
                        <th><button class="ri-action-sort" @onclick='() => SortBy("ChangedBy")'>Cambiado por @GetSortIcon("ChangedBy")</button></th>
                        <th><button class="ri-action-sort" @onclick='() => SortBy("ChangeDate")'>Fecha cambio @GetSortIcon("ChangeDate")</button></th>
                        <th>Detalle</th>
                    </tr>
                </thead>

                                <tbody>
                    @foreach (var item in PagedResources)
                    {
                        <tr>
                            <td>
                                <span class="@GetPriorityClass(item)">
                                    @GetPriority(item)
                                </span>
                            </td>

                            <td>
                                <div class="ri-action-main">@Normalize(item.Subscription)</div>
                                <small>@Normalize(item.Customer)</small>
                            </td>

                            <td>
                                <div class="ri-action-resource">@Normalize(item.ResourceName)</div>
                                <small>@GetStatusText(item.OperationalStatus)</small>
                            </td>

                            <td><span class="ri-action-sku">@Normalize(item.SKUReserva)</span></td>
                            <td><span class="ri-action-sku">@Normalize(item.SKUVM)</span></td>

                            <td>
                                <span class="@GetStatusClass(item.OperationalStatus)">
                                    @GetProblem(item)
                                </span>
                            </td>

                            <td>
                                <div class="ri-action-detail">
                                    @GetDetail(item)
                                </div>
                            </td>

                            <td>
                                <span class="ri-action-user">
                                    @(string.IsNullOrWhiteSpace(item.LastChangedBy) ? "Sin dato" : item.LastChangedBy)
                                </span>
                            </td>

                            <td>
                                <span class="ri-action-date">
                                    @(item.LastChangeDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                </span>
                            </td>

                            <td>
                                <button class="ri-history-btn" type="button" @onclick="() => OpenHistory(item)">
                                    Historial
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="ri-table-footer">

    <div class="ri-table-footer-left">
        Mostrando <strong>@PagedResources.Count()</strong> de
        <strong>@FilteredResources.Count()</strong> recursos
    </div>

    <div class="ri-table-footer-right">

        <span class="ri-page-info">
            Página <strong>@CurrentPage</strong> de <strong>@TotalPages</strong>
        </span>

        <button class="ri-page-btn"
                @onclick="PrevPage"
                disabled="@(CurrentPage==1)">
            ‹
        </button>

        @foreach(var pageNumber in VisiblePages)
        {
            <button class="ri-page-btn @(pageNumber==CurrentPage?"active":"")"
                    @onclick="()=>GoToPage(pageNumber)">
                @pageNumber
            </button>
        }

        <button class="ri-page-btn"
                @onclick="NextPage"
                disabled="@(CurrentPage>=TotalPages)">
            ›
        </button>

    </div>

</div>
    </div>

</section>

@if (SelectedResource is not null)
{
    <div class="ri-history-backdrop" @onclick="CloseHistory"></div>

    <div class="ri-history-modal">
        <div class="ri-history-header">
            <div>
                <span>Línea de tiempo</span>
                <h3>@SelectedResource.ResourceName</h3>
                <p>@SelectedResource.Subscription</p>
            </div>

            <button type="button" @onclick="CloseHistory">×</button>
        </div>

        <div class="ri-timeline">
            <div class="ri-timeline-item">
                <strong>Problema detectado</strong>
                <span>@GetProblem(SelectedResource)</span>
                <small>@GetDetail(SelectedResource)</small>
            </div>

            <div class="ri-timeline-item">
                <strong>Cambiado por</strong>
                <span>@(string.IsNullOrWhiteSpace(SelectedResource.LastChangedBy) ? "Sin dato" : SelectedResource.LastChangedBy)</span>
                <small>@(SelectedResource.LastChangeDate?.ToString("dd/MM/yyyy HH:mm") ?? "Sin fecha de cambio")</small>
            </div>

            <div class="ri-timeline-item">
                <strong>Último scan</strong>
                <span>@(SelectedResource.LastScanDate?.ToString("dd/MM/yyyy HH:mm") ?? "Sin dato")</span>
                <small>Validación automática de Reserved Instances</small>
            </div>

            <div class="ri-timeline-item">
                <strong>Recomendación</strong>
                <span>@GetProblem(SelectedResource)</span>
                <small>@GetDetail(SelectedResource)</small>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public List<ReservedInstanceResource> Resources { get; set; } = new();

    private ReservedInstanceResource? SelectedResource { get; set; }
    private List<ReservedInstanceChangeHistory> ChangeHistory { get; set; } = new();

    private string SearchText { get; set; } = "";
    private string ProblemFilter { get; set; } = "";
    private string PriorityFilter { get; set; } = "";
    private string SubscriptionFilter { get; set; } = "";

    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 20;
    private string SortColumn { get; set; } = "Priority";
    private bool SortAscending { get; set; } = true;

    private List<ReservedInstanceResource> ActionResources =>
        Resources
            .Where(x => x.OperationalStatus != "Healthy")
            .OrderBy(GetPriorityRank)
            .ThenBy(x => x.Customer)
            .ThenBy(x => x.ResourceName)
            .ToList();

    private IEnumerable<string> SubscriptionOptions =>
        ActionResources
            .Select(x => x.Subscription)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .OrderBy(x => x);

    private IEnumerable<ReservedInstanceResource> FilteredResources =>
        ActionResources.Where(x =>
            (string.IsNullOrWhiteSpace(ProblemFilter) || x.OperationalStatus == ProblemFilter) &&
            (string.IsNullOrWhiteSpace(PriorityFilter) || GetPriority(x) == PriorityFilter) &&
            (string.IsNullOrWhiteSpace(SubscriptionFilter) || x.Subscription == SubscriptionFilter) &&
            (
                string.IsNullOrWhiteSpace(SearchText) ||
                ContainsSafe(x.ResourceName, SearchText) ||
                ContainsSafe(x.Customer, SearchText) ||
                ContainsSafe(x.Subscription, SearchText) ||
                ContainsSafe(x.SKUReserva, SearchText) ||
                ContainsSafe(x.SKUVM, SearchText)
            )
        );


    private IEnumerable<ReservedInstanceResource> OrderedResources =>
        SortColumn switch
        {
            "Priority" => SortAscending ? FilteredResources.OrderBy(GetPriorityRank) : FilteredResources.OrderByDescending(GetPriorityRank),
            "Subscription" => SortAscending ? FilteredResources.OrderBy(x => x.Subscription) : FilteredResources.OrderByDescending(x => x.Subscription),
            "Resource" => SortAscending ? FilteredResources.OrderBy(x => x.ResourceName) : FilteredResources.OrderByDescending(x => x.ResourceName),
            "SKUReserva" => SortAscending ? FilteredResources.OrderBy(x => x.SKUReserva) : FilteredResources.OrderByDescending(x => x.SKUReserva),
            "SKUVM" => SortAscending ? FilteredResources.OrderBy(x => x.SKUVM) : FilteredResources.OrderByDescending(x => x.SKUVM),
            "Problem" => SortAscending ? FilteredResources.OrderBy(GetProblem) : FilteredResources.OrderByDescending(GetProblem),
            "Detail" => SortAscending ? FilteredResources.OrderBy(GetDetail) : FilteredResources.OrderByDescending(GetDetail),
            "ChangedBy" => SortAscending ? FilteredResources.OrderBy(x => x.LastChangedBy) : FilteredResources.OrderByDescending(x => x.LastChangedBy),
            "ChangeDate" => SortAscending ? FilteredResources.OrderBy(x => x.LastChangeDate) : FilteredResources.OrderByDescending(x => x.LastChangeDate),
            _ => FilteredResources.OrderBy(GetPriorityRank)
        };
    private IEnumerable<ReservedInstanceResource> PagedResources =>
        OrderedResources.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private int TotalPages =>
        Math.Max(1, (int)Math.Ceiling(FilteredResources.Count() / (double)PageSize));

    private IEnumerable<int> VisiblePages
    {
        get
        {
            var start = Math.Max(1, CurrentPage - 2);
            var end = Math.Min(TotalPages, CurrentPage + 2);

            for (var i = start; i <= end; i++)
                yield return i;
        }
    }


    private void SortBy(string column)
    {
        if (SortColumn == column)
        {
            SortAscending = !SortAscending;
        }
        else
        {
            SortColumn = column;
            SortAscending = true;
        }

        CurrentPage = 1;
    }

    private string GetSortIcon(string column)
    {
        if (SortColumn != column)
        {
            return "↕";
        }

        return SortAscending ? "↑" : "↓";
    }
    private void OpenHistory(ReservedInstanceResource item)
    {
        SelectedResource = item;
    }

    private void CloseHistory()
    {
        SelectedResource = null;
    }

    private void ClearFilters()
    {
        SearchText = "";
        ProblemFilter = "";
        PriorityFilter = "";
        SubscriptionFilter = "";
        CurrentPage = 1;
    }

    private void GoToPage(int pageNumber) => CurrentPage = pageNumber;
    private void NextPage() { if (CurrentPage < TotalPages) CurrentPage++; }
    private void PrevPage() { if (CurrentPage > 1) CurrentPage--; }

    private async Task ExportCsvAsync()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Prioridad,Estado,Cliente,Suscripcion,Recurso,SKUReserva,SKUVM,Problema,Detalle,Dias,CambiadoPor,FechaCambio");

        foreach (var item in FilteredResources)
        {
            sb.AppendLine(string.Join(",",
                Csv(GetPriority(item)),
                Csv(GetStatusText(item.OperationalStatus)),
                Csv(item.Customer),
                Csv(item.Subscription),
                Csv(item.ResourceName),
                Csv(item.SKUReserva),
                Csv(item.SKUVM),
                Csv(GetProblem(item)),
                Csv(GetDetail(item)),
                Csv(item.DaysRemaining?.ToString() ?? "-"),
                Csv(string.IsNullOrWhiteSpace(item.LastChangedBy) ? "Sin dato" : item.LastChangedBy),
                Csv(item.LastChangeDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")
            ));
        }

        var fileName = $"ri-requiere-accion-{DateTime.Now:yyyyMMddHHmm}.csv";
        var data = Uri.EscapeDataString(sb.ToString());

        await JS.InvokeVoidAsync("eval", $"const a=document.createElement('a');a.href='data:text/csv;charset=utf-8,{data}';a.download='{fileName}';document.body.appendChild(a);a.click();a.remove();");
    }

    private static int GetPriorityRank(ReservedInstanceResource item) => item.OperationalStatus switch
    {
        "Expired" => 1,
        "SKU Mismatch" => 2,
        "Date Mismatch" => 3,
        "Low Utilization" => 4,
        "Expiring Soon" => 5,
        _ => 9
    };

    private static string GetPriority(ReservedInstanceResource item) => item.OperationalStatus switch
    {
        "Expired" => "Crítica",
        "SKU Mismatch" => "Crítica",
        "Date Mismatch" => "Crítica",
        "Low Utilization" => "Alta",
        "Expiring Soon" => "Media",
        _ => "Media"
    };

    private static string GetPriorityClass(ReservedInstanceResource item) => item.OperationalStatus switch
    {
        "Expired" => "ri-priority critical",
        "SKU Mismatch" => "ri-priority critical",
        "Date Mismatch" => "ri-priority critical",
        "Low Utilization" => "ri-priority high",
        "Expiring Soon" => "ri-priority medium",
        _ => "ri-priority medium"
    };

    private static string GetProblem(ReservedInstanceResource item) => item.OperationalStatus switch
    {
        "Expired" => "Reserva expirada",
        "SKU Mismatch" => "SKU diferente",
        "Date Mismatch" => "Fecha no coincide",
        "Low Utilization" => "Baja utilización",
        "Expiring Soon" => "Por vencer",
        _ => "Revisar recurso"
    };

    private static string GetDetail(ReservedInstanceResource item) => item.OperationalStatus switch
    {
        "Expired" => "Reserva vencida",
        "SKU Mismatch" => "Los SKUs no coinciden",
        "Date Mismatch" => "Fechas no coinciden",
        "Low Utilization" => $"Utilización promedio {(item.Utilization30d ?? 0).ToString("N2")}%",
        "Expiring Soon" => $"Vence en {item.DaysRemaining} días",
        _ => "Validar recurso"
    };

    private static string GetStatusText(string? status) => status switch
    {
        "Expired" => "Expirada",
        "SKU Mismatch" => "SKU diferente",
        "Date Mismatch" => "Fecha no coincide",
        "Low Utilization" => "Baja utilización",
        "Expiring Soon" => "Por vencer",
        _ => status ?? "Sin estado"
    };

    private static string GetStatusClass(string? status) => status switch
    {
        "Expired" => "ri-badge danger",
        "SKU Mismatch" => "ri-badge danger",
        "Date Mismatch" => "ri-badge danger",
        "Low Utilization" => "ri-badge warning",
        "Expiring Soon" => "ri-badge info",
        _ => "ri-badge muted"
    };

    private static string GetDaysClass(ReservedInstanceResource item)
    {
        if (item.DaysRemaining is null) return "ri-pill muted";
        if (item.DaysRemaining < 0) return "ri-pill danger";
        if (item.DaysRemaining <= 90) return "ri-pill warning";
        return "ri-pill success";
    }

    private static bool ContainsSafe(string? value, string search) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(search, StringComparison.OrdinalIgnoreCase);

    private static string Normalize(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;


    private static string GetLifecycleRecommendation(ReservedInstanceResource item)
    {
        if (!string.IsNullOrWhiteSpace(item.LifecycleRecommendation))
            return item.LifecycleRecommendation;

        if (!string.IsNullOrWhiteSpace(item.RetirementStatus))
            return item.RetirementStatus;

        return "Sin recomendación de lifecycle";
    }

    private static string GetLifecycleClass(ReservedInstanceResource item)
    {
        if (item.Ri3YearAvailable == false)
            return "ri-ms-recommendation warning";

        if (!string.IsNullOrWhiteSpace(item.RetirementStatus))
            return "ri-ms-recommendation danger";

        return "ri-ms-recommendation muted";
    }
    private static string Csv(string? value)
    {
        value ??= "";
        return "\"" + value.Replace("\"", "\"\"") + "\"";
    }
}












