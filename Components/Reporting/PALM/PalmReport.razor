@page "/reporting/palm"

@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Components
@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Models
@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Services

@inject IPalmService PalmService

<PageTitle>Reporte PALM</PageTitle>

<section class="palm-page">

    <section class="palm-hero">
        <div class="palm-hero-content">
            <span class="palm-eyebrow">
                Microsoft Partner Association
            </span>

            <h1>Reporte PALM</h1>

            <p>
                Centro ejecutivo para validar la asociación de Partner ID,
                identificar clientes que requieren atención y consultar la
                trazabilidad de las ejecuciones PALM.
            </p>

            @if (reportData is not null)
            {
                <div class="palm-meta">
                    <span>
                        <i class="bi bi-buildings"></i>
                        @reportData.Dashboard.TotalCustomers.ToString("N0")
                        clientes
                    </span>

                    <span>
                        <i class="bi bi-check-circle"></i>
                        @reportData.Dashboard.TotalOK.ToString("N0")
                        correctos
                    </span>

                    <span>
                        <i class="bi bi-exclamation-triangle"></i>
                        @reportData.Dashboard.RequiresAction.ToString("N0")
                        requieren acción
                    </span>

                    <span>
                        <i class="bi bi-speedometer2"></i>
                        @reportData.Dashboard.CompliancePercent.ToString("N2")%
                        cumplimiento
                    </span>
                </div>
            }
        </div>

        <div class="palm-hero-actions">
            @if (lastLoadedAt.HasValue)
            {
                <span class="palm-consulted">
                    Última consulta
                    <strong>
                        @lastLoadedAt.Value.ToString("dd/MM/yyyy HH:mm:ss")
                    </strong>
                </span>
            }

            <button type="button"
                    class="palm-btn palm-btn-primary"
                    disabled="@isLoading"
                    @onclick="LoadReportAsync">

                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm"
                          aria-hidden="true">
                    </span>

                    <span>Actualizando...</span>
                }
                else
                {
                    <i class="bi bi-arrow-clockwise"></i>
                    <span>Actualizar</span>
                }
            </button>
        </div>
    </section>

    <nav class="palm-tabs"
         aria-label="Secciones del reporte PALM">

        <button type="button"
                class="@GetTabClass("Dashboard")"
                @onclick='() => ChangeTab("Dashboard")'>

            <i class="bi bi-speedometer2"></i>
            Dashboard
        </button>

        <button type="button"
                class="@GetTabClass("Results")"
                @onclick='() => ChangeTab("Results")'>

            <i class="bi bi-list-check"></i>
            Resultados

            @if (reportData is not null)
            {
                <span class="palm-tab-counter">
                    @reportData.Results.Count
                </span>
            }
        </button>

        <button type="button"
                class="@GetTabClass("Action")"
                @onclick='() => ChangeTab("Action")'>

            <i class="bi bi-exclamation-triangle"></i>
            Requieren acción

            @if (reportData is not null &&
                 reportData.RequiresAction.Count > 0)
            {
                <span class="palm-tab-counter palm-tab-counter-warning">
                    @reportData.RequiresAction.Count
                </span>
            }
        </button>

        <button type="button"
                class="@GetTabClass("History")"
                @onclick='() => ChangeTab("History")'>

            <i class="bi bi-clock-history"></i>
            Historial

            @if (reportData is not null)
            {
                <span class="palm-tab-counter">
                    @reportData.RunHistory.Count
                </span>
            }
        </button>
    </nav>

    @if (isLoading && reportData is null)
    {
        <section class="palm-state-card">
            <div class="spinner-border text-primary"
                 role="status">

                <span class="visually-hidden">Cargando...</span>
            </div>

            <h3>Cargando reporte PALM</h3>

            <p>
                Consultando dashboard, resultados, incidencias e historial.
            </p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <section class="palm-error-card">
            <div class="palm-error-icon">
                <i class="bi bi-exclamation-octagon-fill"></i>
            </div>

            <div>
                <h3>No fue posible cargar el reporte</h3>

                <p>@errorMessage</p>

                <button type="button"
                        class="palm-btn palm-btn-danger"
                        disabled="@isLoading"
                        @onclick="LoadReportAsync">

                    <i class="bi bi-arrow-clockwise"></i>
                    Reintentar
                </button>
            </div>
        </section>
    }
    else if (reportData is not null)
    {
        @if (activeTab == "Dashboard")
        {
            <section class="palm-tab-content">

                <div class="palm-content-heading">
                    <div>
                        <span>Resumen ejecutivo</span>
                        <h2>Estado general de cumplimiento</h2>

                        <p>
                            Indicadores consolidados de clientes,
                            suscripciones y asociación de Partner ID.
                        </p>
                    </div>

                    <div class="@GetComplianceBadgeClass()">
                        @reportData.Dashboard.CompliancePercent.ToString("N2")%
                        cumplimiento
                    </div>
                </div>

                <PalmDashboardSummary
                    Dashboard="@reportData.Dashboard" />

                <section class="palm-dashboard-footer">
                    <div>
                        <span>Última ejecución</span>
                        <strong>@FormatLatestRunDate()</strong>
                    </div>

                    <button type="button"
                            class="palm-dashboard-history-button"
                            @onclick='() => ChangeTab("History")'>
                        <i class="bi bi-clock-history"></i>
                        Consultar historial
                    </button>
                </section>
            </section>
        }
        else if (activeTab == "Results")
        {
            <section class="palm-tab-content">

                <div class="palm-content-heading">
                    <div>
                        <span>Inventario validado</span>
                        <h2>Resultados de asociación</h2>

                        <p>
                            Consulta el resultado completo por cliente,
                            tenant, suscripción y Partner ID.
                        </p>
                    </div>

                    <div class="palm-heading-counter">
                        @reportData.Results.Count registros
                    </div>
                </div>

                <div class="palm-summary-strip">
                    <article>
                        <span>Total evaluados</span>
                        <strong>
                            @reportData.Dashboard.TotalCustomers.ToString("N0")
                        </strong>
                    </article>

                    <article class="success">
                        <span>Correctos</span>
                        <strong>
                            @reportData.Dashboard.TotalOK.ToString("N0")
                        </strong>
                    </article>

                    <article class="danger">
                        <span>Con error</span>
                        <strong>
                            @reportData.Dashboard.TotalNOK.ToString("N0")
                        </strong>
                    </article>

                    <article class="info">
                        <span>Suscripciones</span>
                        <strong>
                            @reportData.Dashboard.TotalVisibleSubscriptions.ToString("N0")
                        </strong>
                    </article>
                </div>

                <PalmResults Resources="@reportData.Results" />
            </section>
        }
        else if (activeTab == "Action")
        {
            <section class="palm-tab-content">

                <div class="palm-content-heading">
                    <div>
                        <span>Seguimiento operativo</span>
                        <h2>Registros que requieren acción</h2>

                        <p>
                            Clientes con ausencia de Partner ID,
                            diferencias de asociación o errores de lectura.
                        </p>
                    </div>

                    <div class="palm-heading-counter warning">
                        @reportData.RequiresAction.Count pendientes
                    </div>
                </div>

                <div class="palm-action-banner">
                    <div class="palm-action-banner-icon">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>

                    <div>
                        <strong>
                            @reportData.RequiresAction.Count registros
                            requieren revisión
                        </strong>

                        <span>
                            Valida permisos, acceso a las suscripciones y
                            asociación del Partner ID esperado.
                        </span>
                    </div>
                </div>

                <PalmRequiresAction
                    Resources="@reportData.RequiresAction" />
            </section>
        }
        else if (activeTab == "History")
        {
            <section class="palm-tab-content">

                <div class="palm-content-heading">
                    <div>
                        <span>Trazabilidad</span>
                        <h2>Historial de ejecuciones</h2>

                        <p>
                            Consulta duración, resultados, porcentaje de éxito
                            y estado de cada ejecución PALM.
                        </p>
                    </div>

                    <div class="palm-heading-counter">
                        @reportData.RunHistory.Count ejecuciones
                    </div>
                </div>

                <div class="palm-history-summary">
                    <article>
                        <div class="palm-history-icon">
                            <i class="bi bi-clock-history"></i>
                        </div>

                        <div>
                            <span>Ejecuciones registradas</span>
                            <strong>
                                @reportData.RunHistory.Count.ToString("N0")
                            </strong>
                        </div>
                    </article>

                    <article>
                        <div class="palm-history-icon success">
                            <i class="bi bi-graph-up-arrow"></i>
                        </div>

                        <div>
                            <span>Último porcentaje de éxito</span>
                            <strong>
                                @(reportData.LatestRun?.SuccessPercent.ToString("N2") ?? "0.00")%
                            </strong>
                        </div>
                    </article>

                    <article>
                        <div class="palm-history-icon info">
                            <i class="bi bi-calendar-check"></i>
                        </div>

                        <div>
                            <span>Última ejecución</span>
                            <strong>
                                @FormatLatestRunDate()
                            </strong>
                        </div>
                    </article>
                </div>

                <PalmInformation LatestRun="@reportData.LatestRun" />

                <PalmHistory Runs="@reportData.RunHistory" />
            </section>
        }
    }
</section>

@code {
    private PalmReportData? reportData;
    private bool isLoading;
    private string? errorMessage;
    private DateTime? lastLoadedAt;
    private string activeTab = "Dashboard";

    protected override async Task OnInitializedAsync()
    {
        await LoadReportAsync();
    }

    private async Task LoadReportAsync()
    {
        if (isLoading)
        {
            return;
        }

        try
        {
            isLoading = true;
            errorMessage = null;

            reportData = await PalmService.GetReportAsync();
            lastLoadedAt = DateTime.Now;
        }
        catch (Exception ex)
        {
            errorMessage =
                "Se produjo un error consultando las vistas PALM. " +
                ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ChangeTab(string tab)
    {
        activeTab = tab;
    }

    private string GetTabClass(string tab)
    {
        return string.Equals(
            activeTab,
            tab,
            StringComparison.OrdinalIgnoreCase)
                ? "active"
                : string.Empty;
    }

    private string GetComplianceBadgeClass()
    {
        if (reportData is null)
        {
            return "palm-compliance-badge neutral";
        }

        var value = reportData.Dashboard.CompliancePercent;

        if (value >= 95m)
        {
            return "palm-compliance-badge success";
        }

        if (value >= 80m)
        {
            return "palm-compliance-badge warning";
        }

        return "palm-compliance-badge danger";
    }

    private string FormatLatestRunDate()
    {
        return reportData?.LatestRun is null
            ? "No disponible"
            : reportData.LatestRun.StartedAt
                .ToString("dd/MM/yyyy HH:mm");
    }
}


