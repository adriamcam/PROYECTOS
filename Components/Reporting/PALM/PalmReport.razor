@page "/reporting/palm"

@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Components
@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Models
@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Services

@inject IPalmService PalmService

<PageTitle>Reporte PALM</PageTitle>

<div class="palm-report-page">

    <header class="palm-report-header">
        <div>
            <div class="palm-report-eyebrow">
                Microsoft Partner Association
            </div>

            <h1>Reporte PALM</h1>

            <p>
                Validación centralizada de la asociación de Partner ID
                para clientes y suscripciones administradas.
            </p>
        </div>

        <div class="palm-report-header-actions">
            @if (lastLoadedAt.HasValue)
            {
                <span class="palm-last-update">
                    Consultado:
                    <strong>
                        @lastLoadedAt.Value.ToString("dd/MM/yyyy HH:mm:ss")
                    </strong>
                </span>
            }

            <button type="button"
                    class="btn btn-outline-primary"
                    disabled="@isLoading"
                    @onclick="LoadReportAsync">

                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"
                          aria-hidden="true">
                    </span>

                    <span>Actualizando...</span>
                }
                else
                {
                    <i class="bi bi-arrow-clockwise me-2"></i>
                    <span>Actualizar</span>
                }
            </button>
        </div>
    </header>

    @if (isLoading && reportData is null)
    {
        <div class="palm-loading-state">
            <div class="spinner-border text-primary"
                 role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>

            <h3>Cargando reporte PALM</h3>

            <p>
                Consultando el dashboard, los resultados y el historial.
            </p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger shadow-sm"
             role="alert">

            <div class="d-flex align-items-start gap-3">
                <i class="bi bi-exclamation-octagon-fill fs-4"></i>

                <div class="flex-grow-1">
                    <h5 class="alert-heading mb-1">
                        No fue posible cargar el reporte
                    </h5>

                    <p class="mb-3">
                        @errorMessage
                    </p>

                    <button type="button"
                            class="btn btn-danger"
                            disabled="@isLoading"
                            @onclick="LoadReportAsync">

                        <i class="bi bi-arrow-clockwise me-2"></i>
                        Reintentar
                    </button>
                </div>
            </div>
        </div>
    }
    else if (reportData is not null)
    {
        <PalmInformation LatestRun="@reportData.LatestRun" />

        <section class="palm-section">
            <div class="palm-section-title">
                <div>
                    <span>Resumen ejecutivo</span>
                    <h2>Estado general de cumplimiento</h2>
                </div>

                <i class="bi bi-speedometer2"></i>
            </div>

            <PalmDashboardSummary Dashboard="@reportData.Dashboard" />
        </section>

        <section class="palm-section">
            <div class="palm-section-title">
                <div>
                    <span>Seguimiento operativo</span>
                    <h2>Registros que requieren acción</h2>
                </div>

                <div class="palm-section-counter palm-counter-warning">
                    @reportData.RequiresAction.Count registros
                </div>
            </div>

            <PalmRequiresAction Resources="@reportData.RequiresAction" />
        </section>

        <section class="palm-section">
            <div class="palm-section-title">
                <div>
                    <span>Inventario validado</span>
                    <h2>Resultados de asociación</h2>
                </div>

                <div class="palm-section-counter">
                    @reportData.Results.Count registros
                </div>
            </div>

            <PalmResults Resources="@reportData.Results" />
        </section>

        <section class="palm-section">
            <div class="palm-section-title">
                <div>
                    <span>Trazabilidad</span>
                    <h2>Historial de ejecuciones</h2>
                </div>

                <div class="palm-section-counter">
                    @reportData.RunHistory.Count ejecuciones
                </div>
            </div>

            <PalmHistory Runs="@reportData.RunHistory" />
        </section>
    }
</div>

@code {
    private PalmReportData? reportData;
    private bool isLoading;
    private string? errorMessage;
    private DateTime? lastLoadedAt;

    protected override async Task OnInitializedAsync()
    {
        await LoadReportAsync();
    }

    private async Task LoadReportAsync()
    {
        if (isLoading)
        {
            return;
        }

        try
        {
            isLoading = true;
            errorMessage = null;

            reportData = await PalmService.GetReportAsync();
            lastLoadedAt = DateTime.Now;
        }
        catch (Exception ex)
        {
            errorMessage =
                "Se produjo un error consultando las vistas PALM. " +
                ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
