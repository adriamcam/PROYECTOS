@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Models

<div class="card shadow-sm border-0 mt-4">

    <div class="card-header bg-white">

        <div class="d-flex justify-content-between align-items-center">

            <div>

                <h5 class="mb-0">
                    <i class="bi bi-table me-2"></i>
                    Resultados PALM
                </h5>

                <small class="text-muted">
                    Clientes analizados durante la última ejecución.
                </small>

            </div>

            <span class="badge bg-primary">
                @Resources.Count registros
            </span>

        </div>

    </div>

    <div class="table-responsive">

        <table class="table table-hover table-sm align-middle mb-0">

            <thead class="table-light">

                <tr>

                    <th>Cliente</th>

                    <th>Status</th>

                    <th>Acción</th>

                    <th>Partner Actual</th>

                    <th>Partner Esperado</th>

                    <th>Suscripciones</th>

                    <th>Escaneo</th>

                </tr>

            </thead>

            <tbody>

                @if (Resources.Count == 0)
                {
                    <tr>

                        <td colspan="7" class="text-center p-5 text-muted">

                            No existen registros.

                        </td>

                    </tr>
                }
                else
                {
                    @foreach (var item in Resources)
                    {
                        <tr>

                            <td>

                                <strong>@item.CustomerName</strong>

                                <div class="small text-muted">

                                    @item.TenantId

                                </div>

                            </td>

                            <td>

                                @if (item.Status == "OK")
                                {
                                    <span class="badge bg-success">
                                        OK
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        NOK
                                    </span>
                                }

                            </td>

                            <td>

                                @item.Action

                            </td>

                            <td>

                                @item.PartnerIdCurrent

                            </td>

                            <td>

                                @item.PartnerIdTarget

                            </td>

                            <td>

                                @item.VisibleSubscriptions

                            </td>

                            <td>

                                @item.ScanDate.ToString("dd/MM/yyyy HH:mm")

                            </td>

                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

</div>

@code {

    [Parameter]

    public IReadOnlyList<PalmResource> Resources { get; set; }
        = Array.Empty<PalmResource>();

}
