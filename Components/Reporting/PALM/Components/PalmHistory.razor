@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Models

<section class="palm-history-table">

    <div class="palm-history-toolbar">
        <div>
            <span>Historial consolidado</span>

            <strong>
                @Runs.Count.ToString("N0") ejecuciones
            </strong>
        </div>

        <div class="palm-history-toolbar-status">

            <span class="success">
                <i class="bi bi-check-circle-fill"></i>
                @CompletedCount completadas
            </span>

            <span class="warning">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @CompletedWithErrorsCount con errores
            </span>

            <span class="danger">
                <i class="bi bi-x-octagon-fill"></i>
                @FailedCount fallidas
            </span>

        </div>
    </div>

    <div class="palm-history-table-shell">

        <div class="palm-history-table-scroll">
            <table>
                <thead>
                    <tr>
                        <th>Inicio</th>
                        <th>Finalización</th>
                        <th>Duración</th>
                        <th>Clientes</th>
                        <th>Suscripciones</th>
                        <th>OK</th>
                        <th>NOK</th>
                        <th>Éxito</th>
                        <th>Estado</th>
                        <th>Run ID</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Runs.Count == 0)
                    {
                        <tr>
                            <td colspan="10">
                                <div class="palm-history-empty">
                                    <div>
                                        <i class="bi bi-clock-history"></i>
                                    </div>

                                    <strong>
                                        No existen ejecuciones registradas
                                    </strong>

                                    <span>
                                        El historial se mostrará después de
                                        la primera ejecución PALM.
                                    </span>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var run in OrderedRuns)
                        {
                            <tr>
                                <td>
                                    <div class="palm-history-date">
                                        <strong>
                                            @run.StartedAt.ToString("dd/MM/yyyy")
                                        </strong>

                                        <span>
                                            @run.StartedAt.ToString("HH:mm:ss")
                                        </span>
                                    </div>
                                </td>

                                <td>
                                    <div class="palm-history-date">
                                        <strong>
                                            @FormatDate(run.FinishedAt)
                                        </strong>

                                        <span>
                                            @FormatTime(run.FinishedAt)
                                        </span>
                                    </div>
                                </td>

                                <td>
                                    <span class="palm-history-duration">
                                        <i class="bi bi-stopwatch"></i>
                                        @FormatDuration(run.DurationSeconds)
                                    </span>
                                </td>

                                <td>
                                    <span class="palm-history-count">
                                        @run.TotalCustomers.ToString("N0")
                                    </span>
                                </td>

                                <td>
                                    <span class="palm-history-count info">
                                        @run.TotalSubscriptions.ToString("N0")
                                    </span>
                                </td>

                                <td>
                                    <span class="palm-history-count success">
                                        @run.TotalOK.ToString("N0")
                                    </span>
                                </td>

                                <td>
                                    <span class="palm-history-count danger">
                                        @run.TotalNOK.ToString("N0")
                                    </span>
                                </td>

                                <td>
                                    <div class="palm-history-success">
                                        <strong>
                                            @run.SuccessPercent.ToString("N2")%
                                        </strong>

                                        <div>
                                            <span style="@GetSuccessStyle(run.SuccessPercent)">
                                            </span>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="@GetStatusClass(run.Status)">
                                        <i class="@GetStatusIcon(run.Status)"></i>
                                        @GetStatusText(run.Status)
                                    </span>
                                </td>

                                <td>
                                    <code title="@run.RunId">
                                        @FormatRunId(run.RunId)
                                    </code>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public IReadOnlyList<PalmRun> Runs { get; set; }
        = Array.Empty<PalmRun>();

    private IEnumerable<PalmRun> OrderedRuns =>
        Runs.OrderByDescending(run => run.StartedAt);

    private int CompletedCount =>
        Runs.Count(run =>
            string.Equals(
                run.Status,
                "Completed",
                StringComparison.OrdinalIgnoreCase));

    private int CompletedWithErrorsCount =>
        Runs.Count(run =>
            string.Equals(
                run.Status,
                "CompletedWithErrors",
                StringComparison.OrdinalIgnoreCase));

    private int FailedCount =>
        Runs.Count(run =>
            string.Equals(
                run.Status,
                "Failed",
                StringComparison.OrdinalIgnoreCase));

    private static string FormatDate(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToString("dd/MM/yyyy")
            : "En proceso";
    }

    private static string FormatTime(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToString("HH:mm:ss")
            : string.Empty;
    }

    private static string FormatDuration(int? seconds)
    {
        if (!seconds.HasValue)
        {
            return "No disponible";
        }

        var duration = TimeSpan.FromSeconds(seconds.Value);

        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours} h " +
                   $"{duration.Minutes} min " +
                   $"{duration.Seconds} s";
        }

        if (duration.TotalMinutes >= 1)
        {
            return $"{duration.Minutes} min " +
                   $"{duration.Seconds} s";
        }

        return $"{duration.Seconds} s";
    }

    private static string FormatRunId(Guid runId)
    {
        var value = runId.ToString();

        return value.Length > 16
            ? $"{value[..8]}...{value[^6..]}"
            : value;
    }

    private static string GetSuccessStyle(decimal value)
    {
        var normalized = Math.Clamp(value, 0m, 100m);

        return FormattableString.Invariant(
            $"width: {normalized}%;");
    }

    private static string GetStatusText(string? status)
    {
        return status?.Trim().ToUpperInvariant() switch
        {
            "COMPLETED" => "Completado",
            "COMPLETEDWITHERRORS" => "Completado con errores",
            "FAILED" => "Fallido",
            "RUNNING" => "En ejecución",
            _ => string.IsNullOrWhiteSpace(status)
                ? "Sin estado"
                : status
        };
    }

    private static string GetStatusClass(string? status)
    {
        return status?.Trim().ToUpperInvariant() switch
        {
            "COMPLETED" =>
                "palm-history-status success",

            "COMPLETEDWITHERRORS" =>
                "palm-history-status warning",

            "FAILED" =>
                "palm-history-status danger",

            "RUNNING" =>
                "palm-history-status info",

            _ =>
                "palm-history-status neutral"
        };
    }

    private static string GetStatusIcon(string? status)
    {
        return status?.Trim().ToUpperInvariant() switch
        {
            "COMPLETED" =>
                "bi bi-check-circle-fill",

            "COMPLETEDWITHERRORS" =>
                "bi bi-exclamation-triangle-fill",

            "FAILED" =>
                "bi bi-x-octagon-fill",

            "RUNNING" =>
                "bi bi-arrow-repeat",

            _ =>
                "bi bi-dash-circle-fill"
        };
    }
}
