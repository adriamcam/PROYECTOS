@using System.Globalization
@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Models

<div class="palm-dashboard-layout">

    <button type="button"
            class="palm-kpi-card palm-kpi-primary"
            title="Ver todos los clientes evaluados"
            @onclick='() => NavigateAsync("Results")'>

        <div class="palm-kpi-icon">
            <i class="bi bi-buildings"></i>
        </div>

        <div class="palm-kpi-content">
            <span>Clientes evaluados</span>

            <strong>
                @FormatNumber(Dashboard.TotalCustomers)
            </strong>

            <small>
                Ver inventario completo
                <i class="bi bi-arrow-right"></i>
            </small>
        </div>
    </button>

    <button type="button"
            class="palm-kpi-card palm-kpi-success"
            title="Ver resultados correctos"
            @onclick='() => NavigateAsync("Results")'>

        <div class="palm-kpi-icon">
            <i class="bi bi-check-circle-fill"></i>
        </div>

        <div class="palm-kpi-content">
            <span>Resultados OK</span>

            <strong>
                @FormatNumber(Dashboard.TotalOK)
            </strong>

            <small>
                Ver resultados correctos
                <i class="bi bi-arrow-right"></i>
            </small>
        </div>
    </button>

    <button type="button"
            class="palm-kpi-card palm-kpi-danger"
            title="Ver resultados con error"
            @onclick='() => NavigateAsync("Results")'>

        <div class="palm-kpi-icon">
            <i class="bi bi-x-circle-fill"></i>
        </div>

        <div class="palm-kpi-content">
            <span>Resultados NOK</span>

            <strong>
                @FormatNumber(Dashboard.TotalNOK)
            </strong>

            <small>
                Ver resultados con error
                <i class="bi bi-arrow-right"></i>
            </small>
        </div>
    </button>

    <button type="button"
            class="palm-kpi-card palm-kpi-warning"
            title="Ver registros que requieren acción"
            @onclick='() => NavigateAsync("Action")'>

        <div class="palm-kpi-icon">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>

        <div class="palm-kpi-content">
            <span>Requieren acción</span>

            <strong>
                @FormatNumber(Dashboard.RequiresAction)
            </strong>

            <small>
                Revisar registros pendientes
                <i class="bi bi-arrow-right"></i>
            </small>
        </div>
    </button>

    <section class="palm-panel">
        <div class="palm-panel-heading">
            <div>
                <span>Distribución actual</span>
                <h3>Estado de asociación</h3>
            </div>

            <div class="palm-panel-icon">
                <i class="bi bi-pie-chart-fill"></i>
            </div>
        </div>

        <div class="palm-status-list">

            <button type="button"
                    class="palm-status-row"
                    @onclick='() => NavigateAsync("Results")'>

                <div>
                    <span class="palm-status-dot success"></span>
                    Partner ID correcto
                </div>

                <div class="palm-status-value">
                    <strong>
                        @FormatNumber(Dashboard.PartnerIdCorrect)
                    </strong>

                    <i class="bi bi-chevron-right"></i>
                </div>
            </button>

            <button type="button"
                    class="palm-status-row"
                    @onclick='() => NavigateAsync("Action")'>

                <div>
                    <span class="palm-status-dot danger"></span>
                    Sin Partner ID
                </div>

                <div class="palm-status-value">
                    <strong>
                        @FormatNumber(Dashboard.WithoutPartnerId)
                    </strong>

                    <i class="bi bi-chevron-right"></i>
                </div>
            </button>

            <button type="button"
                    class="palm-status-row"
                    @onclick='() => NavigateAsync("Action")'>

                <div>
                    <span class="palm-status-dot warning"></span>
                    Partner ID diferente
                </div>

                <div class="palm-status-value">
                    <strong>
                        @FormatNumber(Dashboard.DifferentPartnerId)
                    </strong>

                    <i class="bi bi-chevron-right"></i>
                </div>
            </button>

        </div>
    </section>

    <section class="palm-panel">
        <div class="palm-panel-heading">
            <div>
                <span>Información de inventario</span>
                <h3>Resumen de validación</h3>
            </div>

            <div class="palm-panel-icon">
                <i class="bi bi-clipboard-data-fill"></i>
            </div>
        </div>

        <div class="palm-summary-list">

            <button type="button"
                    @onclick='() => NavigateAsync("Results")'>

                <span>Registros actualizados</span>

                <div>
                    <strong>
                        @FormatNumber(Dashboard.TotalRefreshed)
                    </strong>

                    <i class="bi bi-chevron-right"></i>
                </div>
            </button>

            <button type="button"
                    @onclick='() => NavigateAsync("Results")'>

                <span>Suscripciones visibles</span>

                <div>
                    <strong>
                        @FormatNumber(Dashboard.TotalVisibleSubscriptions)
                    </strong>

                    <i class="bi bi-chevron-right"></i>
                </div>
            </button>

            <div>
                <span>Primer análisis</span>

                <strong>
                    @FormatNullableDateTime(Dashboard.FirstScanDate)
                </strong>
            </div>

            <div>
                <span>Último análisis</span>

                <strong>
                    @FormatNullableDateTime(Dashboard.LastScanDate)
                </strong>
            </div>

            <div>
                <span>Última actualización</span>

                <strong>
                    @FormatNullableDateTime(Dashboard.LastUpdatedAt)
                </strong>
            </div>

        </div>
    </section>

    <section class="palm-panel palm-panel-wide">
        <div class="palm-panel-heading">
            <div>
                <span>Cumplimiento general</span>
                <h3>Asociación de Partner ID</h3>
            </div>

            <div class="palm-panel-icon">
                <i class="bi bi-speedometer2"></i>
            </div>
        </div>

        <div class="palm-compliance-container">

            <div class="palm-compliance-value">
                <strong>
                    @Dashboard.CompliancePercent.ToString(
                        "N2",
                        CultureInfo.InvariantCulture)%
                </strong>

                <span>
                    Porcentaje general de cumplimiento
                </span>
            </div>

            <div class="palm-progress"
                 role="progressbar"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 aria-valuenow="@GetComplianceAriaValue()">

                <div class="palm-progress-bar"
                     style="@GetComplianceStyle()">
                </div>
            </div>

            <div class="palm-compliance-footer">

                <button type="button"
                        class="palm-compliance-link success"
                        @onclick='() => NavigateAsync("Results")'>

                    <i class="bi bi-check-circle-fill"></i>

                    <span>
                        @FormatNumber(Dashboard.PartnerIdCorrect)
                        correctos
                    </span>

                    <i class="bi bi-arrow-right"></i>
                </button>

                <button type="button"
                        class="palm-compliance-link warning"
                        @onclick='() => NavigateAsync("Action")'>

                    <i class="bi bi-exclamation-triangle-fill"></i>

                    <span>
                        @FormatNumber(Dashboard.RequiresAction)
                        requieren acción
                    </span>

                    <i class="bi bi-arrow-right"></i>
                </button>

            </div>
        </div>
    </section>
</div>

@code {
    [Parameter]
    public PalmDashboard Dashboard { get; set; } = new();

    [Parameter]
    public EventCallback<string> OnNavigate { get; set; }

    private async Task NavigateAsync(string tab)
    {
        if (OnNavigate.HasDelegate)
        {
            await OnNavigate.InvokeAsync(tab);
        }
    }

    private static string FormatNumber(long value)
    {
        return value.ToString("N0");
    }

    private static string FormatNullableDateTime(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToString("dd/MM/yyyy HH:mm")
            : "No disponible";
    }

    private int GetComplianceAriaValue()
    {
        return Convert.ToInt32(
            Math.Clamp(
                Dashboard.CompliancePercent,
                0m,
                100m));
    }

    private string GetComplianceStyle()
    {
        var percentage = Math.Clamp(
            Dashboard.CompliancePercent,
            0m,
            100m);

        return FormattableString.Invariant(
            $"width: {percentage}%;");
    }
}
