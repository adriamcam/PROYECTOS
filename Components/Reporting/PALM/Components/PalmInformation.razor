@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Models

<div class="palm-information">

    <div class="palm-information-header">
        <div>
            <span class="palm-information-eyebrow">
                Ejecución PALM
            </span>

            <h3>Información de la última ejecución</h3>
        </div>

        <span class="@GetStatusClass(LatestRun?.Status)">
            @GetStatusText(LatestRun?.Status)
        </span>
    </div>

    @if (LatestRun is null)
    {
        <div class="palm-information-empty">
            <i class="bi bi-clock-history"></i>

            <div>
                <strong>Sin ejecuciones registradas</strong>

                <p>
                    No se encontró información de una ejecución PALM.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="palm-information-grid">

            <div class="palm-information-item">
                <span>Inicio</span>

                <strong>
                    @FormatDateTime(LatestRun.StartedAt)
                </strong>
            </div>

            <div class="palm-information-item">
                <span>Finalización</span>

                <strong>
                    @FormatDateTime(LatestRun.FinishedAt)
                </strong>
            </div>

            <div class="palm-information-item">
                <span>Duración</span>

                <strong>
                    @FormatDuration(LatestRun.DurationSeconds)
                </strong>
            </div>

            <div class="palm-information-item">
                <span>Clientes</span>

                <strong>
                    @LatestRun.TotalCustomers
                </strong>
            </div>

            <div class="palm-information-item">
                <span>Suscripciones</span>

                <strong>
                    @LatestRun.TotalSubscriptions
                </strong>
            </div>

            <div class="palm-information-item">
                <span>Correctos</span>

                <strong class="text-success">
                    @LatestRun.TotalOK
                </strong>
            </div>

            <div class="palm-information-item">
                <span>Con error</span>

                <strong class="text-danger">
                    @LatestRun.TotalNOK
                </strong>
            </div>

            <div class="palm-information-item">
                <span>Éxito</span>

                <strong>
                    @LatestRun.SuccessPercent.ToString("N2")%
                </strong>
            </div>

        </div>

        <div class="palm-information-run">
            <div>
                <span>Run ID</span>

                <code>@LatestRun.RunId</code>
            </div>

            @if (!string.IsNullOrWhiteSpace(LatestRun.Detail))
            {
                <div>
                    <span>Detalle</span>

                    <p>@LatestRun.Detail</p>
                </div>
            }
        </div>
    }

</div>

@code {
    [Parameter]
    public PalmRun? LatestRun { get; set; }

    private static string FormatDateTime(DateTime value)
    {
        return value.ToString("dd/MM/yyyy HH:mm:ss");
    }

    private static string FormatDateTime(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToString("dd/MM/yyyy HH:mm:ss")
            : "En proceso";
    }

    private static string FormatDuration(int? seconds)
    {
        if (!seconds.HasValue)
        {
            return "No disponible";
        }

        var duration = TimeSpan.FromSeconds(seconds.Value);

        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours} h " +
                   $"{duration.Minutes} min " +
                   $"{duration.Seconds} s";
        }

        if (duration.TotalMinutes >= 1)
        {
            return $"{duration.Minutes} min " +
                   $"{duration.Seconds} s";
        }

        return $"{duration.Seconds} s";
    }

    private static string GetStatusText(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "Sin estado";
        }

        return status switch
        {
            "Completed" => "Completado",
            "CompletedWithErrors" => "Completado con errores",
            "Failed" => "Fallido",
            "Running" => "En ejecución",
            _ => status
        };
    }

    private static string GetStatusClass(string? status)
    {
        return status?.ToUpperInvariant() switch
        {
            "COMPLETED" =>
                "palm-information-status status-success",

            "COMPLETEDWITHERRORS" =>
                "palm-information-status status-warning",

            "FAILED" =>
                "palm-information-status status-danger",

            "RUNNING" =>
                "palm-information-status status-info",

            _ =>
                "palm-information-status status-neutral"
        };
    }
}