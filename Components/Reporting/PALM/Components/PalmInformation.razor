@if (Visible)
{
    <div class="palm-info-overlay" @onclick="Close">
        <div class="palm-info-dialog" @onclick:stopPropagation="true">

            <div class="palm-info-header">

                <div>

                    <h3>
                        <i class="bi bi-info-circle-fill"></i>
                        Reporte PALM / MPOR
                    </h3>

                    <small>
                        Microsoft Partner Association Lifecycle Management
                    </small>

                </div>

                <button class="btn-close"
                        @onclick="Close">
                </button>

            </div>

            <div class="palm-info-body">
                <h5>Objetivo</h5>

                <p>
                    Validar la correcta asociación del Partner ID
                    de ITQS sobre todos los clientes administrados.
                </p>

                <hr/>

                <h5>Fuentes de Información</h5>

                <ul>

                    <li>vw_PALM_Dashboard</li>

                    <li>vw_PALM_Results</li>

                    <li>vw_PALM_RequiresAction</li>

                    <li>vw_PALM_LatestRun</li>

                    <li>vw_PALM_RunHistory</li>

                </ul>

                <hr/>

                <h5>Estados</h5>

                <table class="table table-sm">

                    <thead>

                        <tr>

                            <th>Estado</th>

                            <th>Descripción</th>

                        </tr>

                    </thead>

                    <tbody>

                        <tr>

                            <td>PARTNER_ID_CORRECTO</td>

                            <td>El cliente tiene asociado el Partner ID correcto.</td>

                        </tr>

                        <tr>

                            <td>SIN_PARTNER_ID</td>

                            <td>No existe ningún Partner ID asociado.</td>

                        </tr>

                        <tr>

                            <td>PARTNER_ID_DIFERENTE</td>

                            <td>Existe otro Partner ID asociado.</td>

                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>
}

@code{

    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

}
