@using ITQS.SupportOperationsCenter.Components.Reporting.PALM.Models

<section class="palm-run-card">

    <header class="palm-run-header">
        <div class="palm-run-title">
            <div class="palm-run-icon">
                <i class="bi bi-terminal-fill"></i>
            </div>

            <div>
                <span>Ejecución PALM</span>
                <h3>Información de la última ejecución</h3>

                <p>
                    Resumen operativo de la ejecución más reciente.
                </p>
            </div>
        </div>

        <span class="@GetStatusClass(LatestRun?.Status)">
            <i class="@GetStatusIcon(LatestRun?.Status)"></i>
            @GetStatusText(LatestRun?.Status)
        </span>
    </header>

    @if (LatestRun is null)
    {
        <div class="palm-run-empty">
            <div>
                <i class="bi bi-clock-history"></i>
            </div>

            <strong>Sin ejecuciones registradas</strong>

            <span>
                No se encontró información de una ejecución PALM.
            </span>
        </div>
    }
    else
    {
        <div class="palm-run-metrics">

            <article>
                <div class="palm-run-metric-icon primary">
                    <i class="bi bi-play-circle-fill"></i>
                </div>

                <div>
                    <span>Inicio</span>

                    <strong>
                        @FormatDateTime(LatestRun.StartedAt)
                    </strong>
                </div>
            </article>

            <article>
                <div class="palm-run-metric-icon info">
                    <i class="bi bi-stop-circle-fill"></i>
                </div>

                <div>
                    <span>Finalización</span>

                    <strong>
                        @FormatDateTime(LatestRun.FinishedAt)
                    </strong>
                </div>
            </article>

            <article>
                <div class="palm-run-metric-icon purple">
                    <i class="bi bi-stopwatch-fill"></i>
                </div>

                <div>
                    <span>Duración</span>

                    <strong>
                        @FormatDuration(LatestRun.DurationSeconds)
                    </strong>
                </div>
            </article>

            <article>
                <div class="palm-run-metric-icon blue">
                    <i class="bi bi-buildings-fill"></i>
                </div>

                <div>
                    <span>Clientes</span>

                    <strong>
                        @LatestRun.TotalCustomers.ToString("N0")
                    </strong>
                </div>
            </article>

            <article>
                <div class="palm-run-metric-icon cyan">
                    <i class="bi bi-cloud-fill"></i>
                </div>

                <div>
                    <span>Suscripciones</span>

                    <strong>
                        @LatestRun.TotalSubscriptions.ToString("N0")
                    </strong>
                </div>
            </article>

            <article>
                <div class="palm-run-metric-icon success">
                    <i class="bi bi-check-circle-fill"></i>
                </div>

                <div>
                    <span>Correctos</span>

                    <strong>
                        @LatestRun.TotalOK.ToString("N0")
                    </strong>
                </div>
            </article>

            <article>
                <div class="palm-run-metric-icon danger">
                    <i class="bi bi-x-circle-fill"></i>
                </div>

                <div>
                    <span>Con error</span>

                    <strong>
                        @LatestRun.TotalNOK.ToString("N0")
                    </strong>
                </div>
            </article>

            <article>
                <div class="palm-run-metric-icon warning">
                    <i class="bi bi-speedometer2"></i>
                </div>

                <div>
                    <span>Éxito</span>

                    <strong>
                        @LatestRun.SuccessPercent.ToString("N2")%
                    </strong>
                </div>
            </article>

        </div>

        <div class="palm-run-details">

            <div class="palm-run-detail">
                <span>Run ID</span>

                <div>
                    <code title="@LatestRun.RunId">
                        @LatestRun.RunId
                    </code>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(LatestRun.Detail))
            {
                <div class="palm-run-detail">
                    <span>Detalle</span>

                    <p>@LatestRun.Detail</p>
                </div>
            }

        </div>
    }
</section>

@code {
    [Parameter]
    public PalmRun? LatestRun { get; set; }

    private static string FormatDateTime(DateTime value)
    {
        return value.ToString("dd/MM/yyyy HH:mm:ss");
    }

    private static string FormatDateTime(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToString("dd/MM/yyyy HH:mm:ss")
            : "En proceso";
    }

    private static string FormatDuration(int? seconds)
    {
        if (!seconds.HasValue)
        {
            return "No disponible";
        }

        var duration = TimeSpan.FromSeconds(seconds.Value);

        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours} h " +
                   $"{duration.Minutes} min " +
                   $"{duration.Seconds} s";
        }

        if (duration.TotalMinutes >= 1)
        {
            return $"{duration.Minutes} min " +
                   $"{duration.Seconds} s";
        }

        return $"{duration.Seconds} s";
    }

    private static string GetStatusText(string? status)
    {
        return status?.Trim().ToUpperInvariant() switch
        {
            "COMPLETED" => "Completado",
            "COMPLETEDWITHERRORS" => "Completado con errores",
            "FAILED" => "Fallido",
            "RUNNING" => "En ejecución",
            _ => string.IsNullOrWhiteSpace(status)
                ? "Sin estado"
                : status
        };
    }

    private static string GetStatusClass(string? status)
    {
        return status?.Trim().ToUpperInvariant() switch
        {
            "COMPLETED" =>
                "palm-run-status success",

            "COMPLETEDWITHERRORS" =>
                "palm-run-status warning",

            "FAILED" =>
                "palm-run-status danger",

            "RUNNING" =>
                "palm-run-status info",

            _ =>
                "palm-run-status neutral"
        };
    }

    private static string GetStatusIcon(string? status)
    {
        return status?.Trim().ToUpperInvariant() switch
        {
            "COMPLETED" =>
                "bi bi-check-circle-fill",

            "COMPLETEDWITHERRORS" =>
                "bi bi-exclamation-triangle-fill",

            "FAILED" =>
                "bi bi-x-octagon-fill",

            "RUNNING" =>
                "bi bi-arrow-repeat",

            _ =>
                "bi bi-dash-circle-fill"
        };
    }
}
