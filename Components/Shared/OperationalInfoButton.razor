<div class="operational-info">

    <button class="info-button" @onclick="Open" title="Información Operativa">
        <span>i</span>
    </button>

    @if (IsOpen)
    {
        <div class="soc-modal-overlay" @onclick="Close">

            <div class="soc-modal" @onclick:stopPropagation="true">

                <div class="soc-modal-header">

                    <h2>ℹ Información Operativa</h2>

                    <button class="soc-close" @onclick="Close">
                        ✕
                    </button>

                </div>

                <div class="soc-modal-body">

                    <h3>@Title</h3>

                    <p>@Description</p>

                    @if (!string.IsNullOrWhiteSpace(Tables))
                    {
                        <div class="tables-box">

                            <strong>Tablas utilizadas</strong>

                            <ul>

                                @foreach (var t in Tables.Split(','))
                                {
                                    <li>@t.Trim()</li>
                                }

                            </ul>

                        </div>
                    }

                </div>

                <div class="soc-modal-footer">

                    <button class="primary-btn" @onclick="Close">
                        Cerrar
                    </button>

                </div>

            </div>

        </div>
    }

</div>

@code {

    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string Tables { get; set; } = "";

    bool IsOpen;

    void Open() => IsOpen = true;

    void Close() => IsOpen = false;

}
