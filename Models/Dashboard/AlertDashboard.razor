@using ITQS.SupportOperationsCenter.Models.Dashboard
@using ITQS.SupportOperationsCenter.Services.Interfaces

@inject IAlertMonitoringDashboardService AlertMonitoringService

<h1>Monitoreo de Alertas</h1>
<p>Vista general del estado actual de las alertas en todos los clientes y entornos.</p>

<div class="cloud-divider"></div>

@if (IsLoading)
{
    <div class="monitor-card loading-card">Cargando monitoreo de alertas...</div>
}
else
{
    <section class="monitor-kpis">
        <div class="monitor-kpi"><span class="kpi-icon blue">🏢</span><div><small>Clientes afectados</small><b>@Dashboard.Kpis.AffectedClients</b><em>Con alertas activas</em></div></div>
        <div class="monitor-kpi"><span class="kpi-icon red">⚠</span><div><small>Críticas activas</small><b>@Dashboard.Kpis.CriticalAlerts</b><em>Sev0 / Sev1</em></div></div>
        <div class="monitor-kpi"><span class="kpi-icon green">👥</span><div><small>Ingenieros con carga</small><b>@Dashboard.Kpis.EngineersWithLoad</b><em>Con alertas asignadas</em></div></div>
        <div class="monitor-kpi"><span class="kpi-icon amber">🧩</span><div><small>Recursos afectados</small><b>@Dashboard.Kpis.AffectedResources</b><em>Recursos únicos</em></div></div>
        <div class="monitor-kpi"><span class="kpi-icon purple">⏱</span><div><small>Tiempo promedio resolución</small><b>@FormatHours(Dashboard.Kpis.AverageResolutionHours)</b><em>Últimos 7 días</em></div></div>
        <div class="monitor-kpi"><span class="kpi-icon green">✅</span><div><small>Resueltas hoy</small><b>@Dashboard.Kpis.ResolvedToday</b><em>Alertas cerradas hoy</em></div></div>
    </section>

    <section class="monitor-secondary">
        <div class="monitor-card">
            <div class="card-title"><h3>Distribución por fuente</h3><small>Management vs Backup</small></div>
            @foreach (var item in Dashboard.SourceDistribution)
            {
                <div class="metric-row"><span>@item.SourceType</span><div class="bar-wrap"><div class="bar-fill source" style="width:@ClampPercent(item.Percentage)%"></div></div><b>@item.TotalAlerts</b><small>@item.Percentage.ToString("0.0")%</small></div>
            }
        </div>

        <div class="monitor-card">
            <div class="card-title"><h3>Tendencia de alertas</h3><small>Últimos 7 días</small></div>
            <div class="trend-grid">
                @foreach (var item in Dashboard.Trends)
                {
                    var max = MaxTrendValue;
                    var newHeight = max == 0 ? 0 : Math.Max(6, item.NewAlerts * 100 / max);
                    var criticalHeight = max == 0 ? 0 : Math.Max(6, item.CriticalAlerts * 100 / max);
                    var closedHeight = max == 0 ? 0 : Math.Max(6, item.ClosedAlerts * 100 / max);
                    <div class="trend-day"><div class="trend-bars"><i class="new" style="height:@newHeight%"></i><i class="critical" style="height:@criticalHeight%"></i><i class="closed" style="height:@closedHeight%"></i></div><small>@item.TrendDate.ToString("dd/MM")</small></div>
                }
            </div>
            <div class="legend"><span><i class="new"></i> Nuevas</span><span><i class="critical"></i> Críticas</span><span><i class="closed"></i> Cerradas</span></div>
        </div>

        <div class="monitor-card">
            <div class="card-title"><h3>Top clientes por alertas activas</h3><small>Mayor volumen</small></div>
            @foreach (var client in Dashboard.TopClients)
            {
                var pct = MaxClientAlerts == 0 ? 0 : Math.Max(3, client.TotalAlerts * 100 / MaxClientAlerts);
                <div class="ranking-row"><div><b>@client.ClientName</b><small>Críticas: @client.CriticalAlerts</small></div><div class="bar-wrap"><div class="bar-fill danger" style="width:@pct%"></div></div><strong>@client.TotalAlerts</strong></div>
            }
        </div>
    </section>

    <section class="monitor-bottom">
        <div class="monitor-card">
            <div class="card-title"><h3>Alertas por severidad</h3><small>Distribución actual</small></div>
            @foreach (var severity in Dashboard.SeverityDistribution)
            {
                <div class="severity-row"><span class="@GetSeverityDot(severity.SeverityGroup)"></span><b>@severity.SeverityGroup</b><div class="bar-wrap"><div class="bar-fill @GetSeverityBar(severity.SeverityGroup)" style="width:@ClampPercent(severity.Percentage)%"></div></div><strong>@severity.TotalAlerts</strong><small>@severity.Percentage.ToString("0.0")%</small></div>
            }
        </div>

        <div class="monitor-card">
            <div class="card-title"><h3>Actividad reciente</h3><small>Últimos eventos</small></div>
            @foreach (var activity in Dashboard.RecentActivity)
            {
                <div class="activity-row"><span class="@GetActivityIcon(activity.ActivityType)">@GetActivitySymbol(activity.ActivityType)</span><div><b>@activity.AlertName</b><small>@activity.ClientName · @activity.ResourceName</small></div><em>@activity.Severity</em><strong>@FormatDate(activity.ActivityDate)</strong></div>
            }
        </div>

        <div class="monitor-card">
            <div class="card-title"><h3>Top alertas activas</h3><small>Reglas con más recurrencia</small></div>
            @foreach (var alert in Dashboard.TopAlerts)
            {
                var pct = MaxTopAlertEvents == 0 ? 0 : Math.Max(3, alert.TotalAlerts * 100 / MaxTopAlertEvents);
                <div class="ranking-row"><div><b>@alert.AlertName</b><small>@alert.SourceType</small></div><div class="bar-wrap"><div class="bar-fill warning" style="width:@pct%"></div></div><strong>@alert.TotalAlerts</strong></div>
            }
        </div>
    </section>
}

<style>
