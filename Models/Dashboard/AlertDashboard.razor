fill.high{background:#f97316}.bar-fill.medium{background:#f59e0b}.bar-fill.low{background:#22c55e}.bar-fill.info{background:#3b82f6}.trend-grid{height:220px;display:grid;grid-template-columns:repeat(7,1fr);gap:12px;align-items:end;border-bottom:1px solid #dbe4f0;padding:16px 0}.trend-day{height:100%;display:flex;flex-direction:column;justify-content:end;align-items:center;gap:8px}.trend-bars{height:180px;display:flex;align-items:end;gap:5px}.trend-bars i{width:8px;border-radius:999px;display:block}.trend-bars .new,.legend .new{background:#2563eb}.trend-bars .critical,.legend .critical{background:#ef4444}.trend-bars .closed,.legend .closed{background:#16a34a}.legend{display:flex;gap:18px;margin-top:12px;color:#64748b;font-weight:800}.legend i{display:inline-block;width:10px;height:10px;border-radius:50%;margin-right:6px}.sev-dot-critical,.sev-dot-high,.sev-dot-medium,.sev-dot-low,.sev-dot-info{width:11px;height:11px;border-radius:50%;display:inline-block}.sev-dot-critical{background:#ef4444}.sev-dot-high{background:#f97316}.sev-dot-medium{background:#f59e0b}.sev-dot-low{background:#22c55e}.sev-dot-info{background:#3b82f6}.activity-icon{width:28px;height:28px;border-radius:9px;display:grid;place-items:center;font-weight:900}.activity-icon.close{color:#166534;background:#dcfce7}.activity-icon.active{color:#b45309;background:#fef3c7}.loading-card{font-weight:900;color:#64748b}@@media(max-width:1500px){.monitor-kpis{grid-template-columns:repeat(3,1fr)}.monitor-secondary,.monitor-bottom{grid-template-columns:1fr}}@@media(max-width:760px){.monitor-kpis{grid-template-columns:1fr}.metric-row,.severity-row,.ranking-row,.activity-row{grid-template-columns:1fr}.trend-grid{overflow-x:auto}}
</style>

@code {
    private AlertMonitoringDashboardModel Dashboard = new();
    private bool IsLoading = true;

    private int MaxTrendValue => Dashboard.Trends.Count == 0 ? 0 : Dashboard.Trends.Max(x => Math.Max(x.NewAlerts, Math.Max(x.CriticalAlerts, x.ClosedAlerts)));
    private int MaxClientAlerts => Dashboard.TopClients.Count == 0 ? 0 : Dashboard.TopClients.Max(x => x.TotalAlerts);
    private int MaxTopAlertEvents => Dashboard.TopAlerts.Count == 0 ? 0 : Dashboard.TopAlerts.Max(x => x.TotalAlerts);

    protected override async Task OnInitializedAsync()
    {
        Dashboard = await AlertMonitoringService.GetDashboardAsync();
        IsLoading = false;
    }

    private static string ClampPercent(decimal value)
    {
        if (value <= 0) return "0";
        if (value > 100) return "100";
        return value.ToString("0.##");
    }

    private static string FormatHours(decimal hours)
    {
        var totalMinutes = (int)Math.Round(hours * 60, 0);
        var h = totalMinutes / 60;
        var m = totalMinutes % 60;
        return $"{h}h {m}m";
    }

    private static string FormatDate(DateTime? value) => value.HasValue ? value.Value.ToString("HH:mm") : "-";

    private static string GetSeverityDot(string severity)
    {
        var normalized = severity.ToLowerInvariant();
        if (normalized.Contains("critical") || normalized.Contains("sev0")) return "sev-dot-critical";
        if (normalized.Contains("high") || normalized.Contains("sev1")) return "sev-dot-high";
        if (normalized.Contains("medium") || normalized.Contains("sev2")) return "sev-dot-medium";
        if (normalized.Contains("low") || normalized.Contains("sev3")) return "sev-dot-low";
        return "sev-dot-info";
    }

    private static string GetSeverityBar(string severity)
    {
        var normalized = severity.ToLowerInvariant();
        if (normalized.Contains("critical") || normalized.Contains("sev0")) return "critical";
        if (normalized.Contains("high") || normalized.Contains("sev1")) return "high";
        if (normalized.Contains("medium") || normalized.Contains("sev2")) return "medium";
        if (normalized.Contains("low") || normalized.Contains("sev3")) return "low";
        return "info";
    }

    private static string GetActivityIcon(string activityType) => activityType.Equals("Cierre", StringComparison.OrdinalIgnoreCase) ? "activity-icon close" : "activity-icon active";
    private static string GetActivitySymbol(string activityType) => activityType.Equals("Cierre", StringComparison.OrdinalIgnoreCase) ? "✓" : "!";
}
